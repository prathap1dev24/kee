datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  SHOP_ADMIN
}

enum Plan {
  TRIAL
  MONTHLY
  HALF_YEARLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum KeyStatus {
  ACTIVE
  INACTIVE
}

enum AdType {
  POPUP
  BANNER
  NOTICE
}

enum PromotionType {
  AD
  PRODUCT
  OFFER
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         Role
  shopId       String?
  shop         Shop?         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  activityLogs ActivityLog[]
  promotions   Promotion[]

  // Soft delete: a non-null value means this record is deactivated/deleted but
  // retained for audit/referential-integrity purposes. All reads made through
  // TenantService.prisma automatically exclude rows where deletedAt is set.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([deletedAt])
}

model Shop {
  id             String  @id @default(uuid())
  name           String
  logoUrl        String?
  companyDetails String? // Stores JSON or text details (GST, address, phone, etc. - NOT documents, see ShopDocument)
  themeColor     String  @default("#9C27B0")
  isActive       Boolean @default(true)
  storageUsed    BigInt  @default(0) // bytes

  users         User[]
  subscriptions Subscription[]
  customers     Customer[]
  activityLogs  ActivityLog[]
  notifications Notification[]
  orders        Order[]
  masterKeys    MasterKey[]
  documents     ShopDocument[]
  promotions    Promotion[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
}

model Subscription {
  id        String             @id @default(uuid())
  shopId    String
  shop      Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  plan      Plan
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([shopId, status])
}

model MasterKey {
  id            String    @id @default(uuid())
  keyNumber     String
  brand         String
  category      String
  blankNumber   String
  frontImageUrl String?
  backImageUrl  String?
  description   String?
  notes         String?
  status        KeyStatus @default(ACTIVE)

  // Null shopId = legacy/global catalog entry. Shop admins create keys scoped
  // to their own shop during customer registration; super admin sees all.
  shopId String?
  shop   Shop?   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  customers Customer[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, keyNumber])
  @@index([shopId])
  @@index([deletedAt])
}

model Customer {
  id              String             @id @default(uuid())
  shopId          String
  shop            Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name            String
  phone           String
  address         String?
  idProofType     String?
  idProofNumber   String? // Encrypted PII at rest
  reason          String?
  keyNumber       String
  vehicleNumber   String?
  masterKeyId     String?
  masterKey       MasterKey?         @relation(fields: [masterKeyId], references: [id], onDelete: SetNull)
  latitude        Float?
  longitude       Float?
  mapsLink        String?
  capturedAddress String?
  photoUrl        String?
  signatureUrl    String?
  documents       CustomerDocument[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([masterKeyId])
  @@index([shopId, deletedAt])
  @@index([shopId, phone])
}

model CustomerDocument {
  id           String   @id @default(uuid())
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  documentType String
  fileUrl      String // Local/object-storage path
  fileKey      String // Unique file key
  fileSize     Int // bytes

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([deletedAt])
}

// Relational replacement for the legacy Shop.companyDetails.{shopPhoto,shopLicense,ownerAadhaar}
// base64-embedded JSON fields. Mirrors CustomerDocument's shape/pattern so both entities are
// managed consistently. documentType is a free-form string (not an enum) to allow new document
// categories to be added without a schema migration; the application currently uses the
// conventional values 'SHOP_PHOTO', 'SHOP_LICENSE' and 'OWNER_AADHAAR'.
model ShopDocument {
  id           String @id @default(uuid())
  shopId       String
  shop         Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  documentType String
  fileUrl      String // Local/object-storage path
  fileKey      String // Unique file key
  fileSize     Int    @default(0) // bytes

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([shopId, documentType])
  @@index([deletedAt])
}

model OtpCode {
  id         String   @id @default(uuid())
  identifier String
  method     String
  purpose    String
  codeHash   String
  consumed   Boolean  @default(false)
  expiresAt  DateTime

  createdAt DateTime @default(now())

  @@index([identifier, purpose])
}

model Advertisement {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  type        AdType
  startDate   DateTime
  endDate     DateTime
  priority    Int      @default(0)
  targetAll   Boolean  @default(true)
  targetShops String[] // Shop IDs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Cross-shop marketplace listing: an advertisement or promotional product created
// by a Shop Admin that is visible to every shop on the platform (not just the
// creator's own shop). Deliberately kept separate from `Advertisement` (Super-Admin
// only campaign banners/popups) and `Product` (the internal KEE supply-store
// catalog) to avoid conflating three distinct concerns. Intentionally NOT added to
// TENANT_SCOPED_MODELS in tenant.service.ts - reads must span all shops. Ownership
// for update/delete is instead enforced explicitly in PromotionService via a
// findFirst({ where: { id, shopId } }) check, mirroring ShopService.deleteShopDocument.
model Promotion {
  id          String        @id @default(uuid())
  type        PromotionType
  title       String
  description String?
  imageUrl    String?
  price       Float?

  // Only meaningful for type === OFFER: a percentage discount and/or an expiry
  // (validUntil null = no expiry). The cross-shop feed excludes expired offers
  // by default - see PromotionService.getAllPromotions.
  discountPercentage Float?
  validUntil         DateTime?

  // Optional: an OFFER may reference the specific PRODUCT/AD listing (usually
  // from the same shop) that it is discounting. Nullable so a shop can also
  // publish a standalone/general offer with no specific linked listing.
  linkedPromotionId String?
  linkedPromotion   Promotion?  @relation("PromotionOffers", fields: [linkedPromotionId], references: [id], onDelete: SetNull)
  offers            Promotion[] @relation("PromotionOffers")

  shopId      String
  shop        Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
  @@index([deletedAt])
  @@index([type])
  @@index([linkedPromotionId])
}

model ActivityLog {
  id        String  @id @default(uuid())
  shopId    String?
  shop      Shop?   @relation(fields: [shopId], references: [id], onDelete: SetNull)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String // e.g. LOGIN, CUSTOMER_CREATE
  details   String // JSON string or description, PII masked
  ipAddress String?

  createdAt DateTime @default(now())

  // ActivityLog is an immutable audit trail: entries are never soft- or hard-deleted
  // by application code (no deletedAt field), and shopId/userId indexes keep the
  // Super Admin / Shop Admin activity views fast.
  @@index([shopId])
  @@index([userId])
  @@index([action])
}

model Notification {
  id      String  @id @default(uuid())
  shopId  String? // null for system-wide notifications (see `audience` for who those reach)
  shop    Shop?   @relation(fields: [shopId], references: [id], onDelete: SetNull)
  title   String
  message String
  type    String // e.g. SUB_EXPIRY, NEW_KEY, SHOP_REGISTRATION, ORDER_STATUS

  // Only meaningful when shopId is null (a shop-specific notification is always
  // scoped to that one shop regardless of this field). Distinguishes two different
  // kinds of "no specific shop" notifications that must NOT be conflated:
  //   'SHOP'        - a true global broadcast intended for every shop admin
  //                    (e.g. a platform-wide announcement/maintenance notice).
  //   'SUPER_ADMIN' - an internal/system notification for the Super Admin panel
  //                    only (e.g. "new shop X requests approval") - must never
  //                    be visible to any shop admin, including the shop that
  //                    triggered it.
  audience String @default("SHOP")

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([shopId, audience])
}

model RevenueRecord {
  id     String  @id @default(uuid())
  month  Int
  year   Int
  amount Float
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                 String      @id @default(uuid())
  name               String
  description        String?
  price              Float
  discountPercentage Float       @default(0)
  offerPrice         Float?
  imageUrl           String?
  category           String // "Key Blanks", "Machines", "Accessories"
  stock              Int         @default(0)
  status             KeyStatus   @default(ACTIVE)
  orderItems         OrderItem[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
}

// Orders and OrderItems are transactional/financial records, not user-managed
// entities, so they intentionally have no soft-delete field: they are never
// deleted by application code, only status-transitioned (see updateOrderStatus).
model Order {
  id          String      @id @default(uuid())
  shopId      String
  shop        Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  totalAmount Float
  status      String      @default("PENDING") // PENDING, DISPATCHED, DELIVERED, CANCELLED
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([shopId])
  @@index([shopId, status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  price     Float

  @@index([orderId])
  @@index([productId])
}

DATABASE_URL="postgresql://postgres:password@localhost:5435/keedb?schema=public"
JWT_SECRET="your-jwt-secret-key"
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef" # 64 hex chars (32 bytes)
PORT=4000
NODE_ENV=development
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadminpassword"
MINIO_BUCKET="kee-documents"

# Customer/shop document uploads (photos, ID/license PDFs).
# Leave both unset for local dev — falls back to local disk (public/uploads).
# On ephemeral hosts (Render, Railway, Cloud Run) these MUST be set, since
# local disk doesn't survive container restarts/redeploys.
#   FIREBASE_STORAGE_BUCKET   — e.g. "your-project.appspot.com" (Firebase
#     console → Storage → your bucket name, after enabling Storage)
#   FIREBASE_SERVICE_ACCOUNT_KEY — base64-encoded contents of a service
#     account JSON key (Firebase console → Project Settings → Service
#     Accounts → Generate new private key), e.g.:
#       base64 -w0 service-account.json   (Linux/macOS)
#       [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))  (PowerShell)
FIREBASE_STORAGE_BUCKET=""
FIREBASE_SERVICE_ACCOUNT_KEY=""

# Auto-seeded Super Admin (created once, only if zero Super Admins exist in
# the DB). Leave unset for local dev to use the default admin@kee.com /
# adminpassword — ALWAYS set real values in production.
SEED_SUPER_ADMIN_EMAIL="admin@kee.com"
SEED_SUPER_ADMIN_PASSWORD="adminpassword"
SEED_SUPER_ADMIN_NAME="KEE Platform Administrator"

# Real email OTP delivery (SMTP). Leave unset to fall back to console-logged
# dev OTP codes.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="\"KEE Key Space Platform\" <no-reply@kee.com>"

# Real SMS OTP delivery (Twilio). Leave unset to fall back to console-logged
# dev OTP codes.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build output
dist/
backend/dist/
frontend/dist/

# Environment / secrets
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Logs
*.log
npm-debug.log*
backend/dev-server.log

# OS / editor junk
.DS_Store
Thumbs.db
.vscode/
.idea/
.claude/

# Local scratch/backup files (pre-refactor snapshots, temp assets, etc.)
.design-backup/
*.bak

# Firebase CLI local deploy cache
.firebase/

# Prisma
backend/prisma/*.db

# User-uploaded documents (shop licenses, Aadhaar cards, shop photos, etc.)
# — potentially sensitive PII, kept out of version control.
backend/public/uploads/

# Built Android APK output (regenerate via: cd frontend && npx cap sync android &&
# cd android && ./gradlew assembleDebug) — binary build artifact, not source.
*.apk

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  body {
    font-family: 'Outfit', 'Inter', sans-serif;
  }
}

/* Glassmorphism Premium Utility Classes */
.glass-panel {
  background: rgba(18, 14, 28, 0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.glass-panel-hover {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.glass-panel-hover:hover {
  background: rgba(22, 17, 36, 0.85);
  border-color: rgba(140, 36, 255, 0.3);
  box-shadow: 0 10px 30px -10px rgba(140, 36, 255, 0.25);
  transform: translateY(-2px);
}

.glass-input {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s ease-in-out;
}

.glass-input:focus {
  background: rgba(140, 36, 255, 0.05);
  border-color: rgba(140, 36, 255, 0.6);
  box-shadow: 0 0 0 2px rgba(140, 36, 255, 0.25);
  outline: none;
}

.glass-button-primary {
  background: linear-gradient(135deg, #a340ff 0%, #7513e6 100%);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.glass-button-primary:hover:not(:disabled) {
  box-shadow: 0 0 20px 2px rgba(140, 36, 255, 0.4);
  transform: scale(1.02);
}

.glass-button-primary:active:not(:disabled) {
  transform: scale(0.98);
}

/* Custom Scrollbar */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: rgba(11, 8, 19, 0.5);
}

::-webkit-scrollbar-thumb {
  background: rgba(140, 36, 255, 0.3);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(140, 36, 255, 0.6);
}

/* Background Mesh Gradients & Glow Effects */
.mesh-gradient-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -10;
  background-color: #080610;
  background-image: 
    radial-gradient(at 10% 20%, rgba(140, 36, 255, 0.15) 0px, transparent 50%),
    radial-gradient(at 90% 10%, rgba(59, 130, 246, 0.1) 0px, transparent 50%),
    radial-gradient(at 50% 80%, rgba(236, 72, 153, 0.08) 0px, transparent 50%);
  overflow: hidden;
}

/* Animating background blobs */
.glow-sphere {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.4;
  z-index: -9;
}

.glow-purple {
  width: 400px;
  height: 400px;
  background: rgba(140, 36, 255, 0.3);
  top: -100px;
  left: -100px;
  animation: float 20s infinite alternate;
}

.glow-blue {
  width: 500px;
  height: 500px;
  background: rgba(59, 130, 246, 0.2);
  bottom: -200px;
  right: -100px;
  animation: float 25s infinite alternate-reverse;
}

@keyframes float {
  0% {
    transform: translate(0, 0) scale(1);
  }
  50% {
    transform: translate(40px, 30px) scale(1.1);
  }
  100% {
    transform: translate(-20px, -40px) scale(0.95);
  }
}

/* Micro-animations */
.animate-fade-in {
  animation: fadeIn 0.4s ease-out forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Custom Signature Canvas Pad */
.signature-canvas-container {
  touch-action: none;
  background: rgba(255, 255, 255, 0.02);
  border: 1.5px dashed rgba(255, 255, 255, 0.15);
  border-radius: 8px;
  cursor: crosshair;
}

.signature-canvas-container:hover {
  border-color: rgba(140, 36, 255, 0.4);
}

    hostStorage: 'ಹೋಸ್ಟ್ ಶೇಖರಣಾ ಪೂಲ್',
    annualRevenue: 'ವಾರ್ಷಿಕ ಆದಾಯ',
    provisionNewShop: 'ಹೊಸ ಅಂಗಡಿ ಸೇರಿಸಿ',
    inventoryStock: 'ದಾಸ್ತಾನು ಸ್ಟಾಕ್',
    incomingOrders: 'ಒಳಬರುವ ಆದೇಶಗಳ ಲಾಗ್',
    dashboard: 'ಡ್ಯಾಶ್‌ಬೋರ್ಡ್',
    shops: 'ಅಂಗಡಿ ನಿರ್ವಹಣೆ',
    customers: 'ಗ್ರಾಹಕರ ನೋಂದಣಿ',
    keys: 'ಮಾಸ್ಟರ್ ಕ್ಯಾಟಲಾಗ್',
    inventory: 'ದಾಸ್ತಾನು',
    pricing: 'ಬೆಲೆ ಮತ್ತು ಕೊಡುಗೆಗಳು',
    revenue: 'ಆದಾಯ ದಾಖಲೆ',
    searchKeys: 'ಖಾಲಿ ಕೀಲಿ ಹುಡುಕಾಟ',
    register: 'ಗ್ರಾಹಕ ನೋಂದಣಿ',
    history: 'ಗ್ರಾಹಕ ಇತಿಹಾಸ',
    store: 'ಪ್ಲಾಟ್‌ಫಾರ್ಮ್ ಸ್ಟೋರ್',
    reports: 'ವರದಿಗಳು',
    settings: 'ಅಂಗಡಿ ಸೆಟ್ಟಿಂಗ್‌ಗಳು',
    logout: 'ಲಾಗ್ ಔಟ್',
    welcome: 'ಕೀ ವರ್ಕ್‌ಸ್ಪೇಸ್',
    superAdmin: 'ಸೂಪರ್ ಅಡ್ಮಿನ್',
    shopTerminal: 'ಅಂಗಡಿ ಟರ್ಮಿನಲ್',
  },
  ml: {
    shopsRegistered: 'രജിസ്റ്റർ ചെയ്ത കടകൾ',
    complianceRegistry: 'കസ്റ്റമർ രജിസ്ട്രി',
    hostStorage: 'ഹോസ്റ്റ് സംഭരണ പൂൾ',
    annualRevenue: 'വാർഷിക വരുമാനം',
    provisionNewShop: 'പുതിയ ഷോപ്പ് ചേർക്കുക',
    inventoryStock: 'ഇൻവെന്ററി സ്റ്റോക്ക്',
    incomingOrders: 'ഇൻകമിംഗ് ഓർഡറുകൾ',
    dashboard: 'ഡാഷ്‌ബോർഡ്',
    shops: 'ഷോപ്പ് മാനേജ്‌മെന്റ്',
    customers: 'കസ്റ്റമർ രജിസ്ട്രി',
    keys: 'മാസ്റ്റർ കാറ്റലോഗ്',
    inventory: 'സ്റ്റോർ ഇൻവെന്ററി',
    pricing: 'വിലയും ഓഫറുകളും',
    revenue: 'വരുമാന ലോഗ്',
    searchKeys: 'ബ്ലാങ്ക് കീ സെർച്ച്',
    register: 'കസ്റ്റമർ രജിസ്റ്റർ',
    history: 'കസ്റ്റമർ ഹിസ്റ്ററി',
    store: 'പ്ലാറ്റ്ഫോം സ്റ്റോർ',
    reports: 'റിപ്പോർട്ടുകൾ',
    settings: 'ഷോപ്പ് ക്രമീകരണങ്ങൾ',
    logout: 'ലോഗ് ഔട്ട്',
    welcome: 'കീ വർക്ക്സ്പേസ്',
    superAdmin: 'സൂപ്പർ അഡ്മിൻ',
    shopTerminal: 'ഷോപ്പ് ടെർമിനൽ',
  }
};

export default function App() {
  const { user, isAuthenticated, isDemoMode, loading, login, logout, toggleMode, api } = useAuth();
  const [lang, setLang] = useState(localStorage.getItem('kee_lang') || 'en');
  const t = (key) => LANGUAGES[lang]?.[key] || LANGUAGES['en']?.[key] || key;

  const [activeTab, setActiveTab] = useState('dashboard');
  const [authEmail, setAuthEmail] = useState('');
  const [authPassword, setAuthPassword] = useState('');
  const [authError, setAuthError] = useState('');
  const [authLoading, setAuthLoading] = useState(false);
  const [notifications, setNotifications] = useState([]);
  const [unreadCount, setUnreadCount] = useState(0);
  const [showNotifDropdown, setShowNotifDropdown] = useState(false);
  const [autoOpenShopModal, setAutoOpenShopModal] = useState(false);

  // Forgot password flow states
  const [showForgotPassword, setShowForgotPassword] = useState(false);
  const [resetMethod, setResetMethod] = useState(null); // 'email' | 'phone' | null
  const [resetIdentifier, setResetIdentifier] = useState('');
  const [resetOtpInput, setResetOtpInput] = useState('');
  const [generatedOtp, setGeneratedOtp] = useState('');
  const [otpSent, setOtpSent] = useState(false);
  const [otpVerified, setOtpVerified] = useState(false);
  const [newPassword, setNewPassword] = useState('');
  const [confirmPassword, setConfirmPassword] = useState('');
  const [resetLoading, setResetLoading] = useState(false);
  const [resetError, setResetError] = useState('');
  const [resetSuccess, setResetSuccess] = useState(false);

  // Shop Self-Registration states
  const [showRegisterShop, setShowRegisterShop] = useState(false);
  const [regShopName, setRegShopName] = useState('');
  const [regOwnerName, setRegOwnerName] = useState('');
  const [regEmail, setRegEmail] = useState('');
  const [regPhone, setRegPhone] = useState('');
  const [regWhatsapp, setRegWhatsapp] = useState('');
  const [sameAsPhone, setSameAsPhone] = useState(false);
  const [regLocation, setRegLocation] = useState('');
  const [regPassword, setRegPassword] = useState('');
  const [regPlan, setRegPlan] = useState('TRIAL'); // 'TRIAL' | 'MONTHLY' | 'YEARLY'
  const [regLoading, setRegLoading] = useState(false);
  const [regError, setRegError] = useState('');
  const [regSuccessMessage, setRegSuccessMessage] = useState('');
  const [regStep, setRegStep] = useState(1); // 1: Info, 2: OTP, 3: Password & Plan, 4: Payment

  // Self-Registration OTP states
  const [regOtpSent, setRegOtpSent] = useState(false);
  const [regOtpVerified, setRegOtpVerified] = useState(false);
  const [regOtpCode, setRegOtpCode] = useState('');
  const [regOtpInput, setRegOtpInput] = useState('');
  const [regOtpError, setRegOtpError] = useState('');
  const [regOtpLoading, setRegOtpLoading] = useState(false);

  // Self-Registration Payment states
  const [regShowPayment, setRegShowPayment] = useState(false);
  const [regPayMethod, setRegPayMethod] = useState('card');
  const [regCardNumber, setRegCardNumber] = useState('');
  const [regCardExpiry, setRegCardExpiry] = useState('');
  const [regCardCvv, setRegCardCvv] = useState('');
  const [regCardHolder, setRegCardHolder] = useState('');
  const [regUpiId, setRegUpiId] = useState('');
  const [regPayProcessing, setRegPayProcessing] = useState(false);
  const [regPaySuccess, setRegPaySuccess] = useState(false);

  const [regShopPhoto, setRegShopPhoto] = useState('');
  const [regShopLicense, setRegShopLicense] = useState('');
  const [regOwnerAadhaar, setRegOwnerAadhaar] = useState('');

  // Password visibility states
  const [showAuthPassword, setShowAuthPassword] = useState(false);
  const [showRegPassword, setShowRegPassword] = useState(false);
  const [showVerifyPass, setShowVerifyPass] = useState(false);

  useEffect(() => {
    if (isAuthenticated) {
      fetchNotifications();
    }
  }, [isAuthenticated, user]);



  const fetchNotifications = async () => {
    try {
      let res;
      if (user?.role === 'SUPER_ADMIN') {
        res = await api.getSuperNotifications();
      } else {
        res = await api.getNotifications();
      }
      const sorted = [...res].sort((a, b) => new Date(b.createdAt || 0) - new Date(a.createdAt || 0));
      setNotifications(sorted);
      setUnreadCount(sorted.filter(n => !n.isRead).length);
    } catch (e) {
      console.error(e);
    }
  };

  const handleLoginSubmit = async (e) => {
    e.preventDefault();
    setAuthError('');
    setAuthLoading(true);
    try {
      await login(authEmail, authPassword);
      setActiveTab('dashboard');
    } catch (err) {
      setAuthError(err.message || 'Login failed. Please check credentials.');
    } finally {
      setAuthLoading(false);
    }
  };

  const handleSendOtp = async (e) => {
    e.preventDefault();
    setResetError('');
    setResetLoading(true);
    try {
      const res = await api.sendOtp(resetIdentifier, resetMethod || 'email', 'reset');
      setGeneratedOtp(res.otpCode);
      setOtpSent(true);
      alert(`Verification code sent! [Fallback Code: ${res.otpCode}]`);
    } catch (err) {
      setResetError(err.message || 'Failed to dispatch verification code');
    } finally {
      setResetLoading(false);
    }
  };

  const handleVerifyOtp = (e) => {
    e.preventDefault();
    setResetError('');
    if (resetOtpInput === generatedOtp) {
      setOtpVerified(true);
    } else {
      setResetError('Incorrect verification code. Please try again.');
    }
  };

  const handleResetPasswordSubmit = async (e) => {
    e.preventDefault();
    setResetError('');
    if (newPassword !== confirmPassword) {
      setResetError('Passwords do not match');
      return;
    }
    setResetLoading(true);
    try {
      await api.resetPasswordPublic(resetIdentifier, resetMethod, newPassword);
      setResetSuccess(true);
    } catch (err) {
      setResetError(err.message || 'Password reset failed');
    } finally {
      setResetLoading(false);
    }
  };

  const resetForgotPasswordFlow = () => {
    setShowForgotPassword(false);
    setResetMethod(null);
    setResetIdentifier('');
    setResetOtpInput('');
    setGeneratedOtp('');
    setOtpSent(false);
    setOtpVerified(false);
    setNewPassword('');
    setConfirmPassword('');
    setResetError('');
    setResetSuccess(false);
  };

  const handleSendRegOtp = async () => {
    if (!regEmail || !regPhone) {
      alert('Please enter your email address and phone number first.');
      return;
    }
    setRegOtpLoading(true);
    setRegOtpError('');
    try {
      const res = await api.sendOtp(regEmail, 'email', 'register');
      setRegOtpCode(res.otpCode);
      setRegOtpSent(true);
      alert(`Verification OTP code sent to ${regEmail}! [Fallback Code: ${res.otpCode}]`);
    } catch (err) {
      setRegOtpError(err.message || 'Failed to dispatch verification OTP.');
    } finally {
      setRegOtpLoading(false);
    }
  };

  const handleVerifyRegOtp = (e) => {
    e.preventDefault();
    setRegOtpError('');
    if (regOtpInput === regOtpCode && regOtpCode !== '') {
      setRegOtpVerified(true);
      setRegStep(3);
    } else {
      setRegOtpError('Incorrect verification OTP code. Please try again.');
    }
  };

  const handleRegCheckout = async (e) => {
    e.preventDefault();
    setRegPayProcessing(true);
    
    const logs = [
      'Establishing secure payment tunnel...',
      'Verifying account assets & fraud parameters...',
      'Settling subscription merchant account...',
      'Confirming tokenized gateway response...'
    ];

    for (let i = 0; i < logs.length; i++) {
      await new Promise(r => setTimeout(r, 600));
    }

    try {
      const companyDetails = JSON.stringify({
        address: regLocation,
        gst: 'Pending',
        phone: regPhone,
        whatsappNumber: regWhatsapp,
        shopPhoto: regShopPhoto,
        shopLicense: regShopLicense,
        ownerAadhaar: regOwnerAadhaar
      });

      const res = await api.registerShop({
        shopName: regShopName,
        ownerName: regOwnerName,
        email: regEmail,
        phone: regPhone,
        password: regPassword,
        plan: regPlan,
        whatsappNumber: regWhatsapp,
        location: regLocation,
        companyDetails
      });

      setRegPayProcessing(false);
      setRegPaySuccess(true);
      setRegSuccessMessage(res.message || 'Registration submitted. Awaiting Super Admin approval.');
    } catch (err) {
      setRegPayProcessing(false);
      setRegError(err.message || 'Self-registration failed.');
    }
  };

  const executeFreeRegistration = async () => {
    setRegLoading(true);
    setRegError('');
    try {
      const companyDetails = JSON.stringify({
        address: regLocation,
        gst: 'Pending',
        phone: regPhone,
        whatsappNumber: regWhatsapp,
        shopPhoto: regShopPhoto,
        shopLicense: regShopLicense,
        ownerAadhaar: regOwnerAadhaar
      });

      const res = await api.registerShop({
        shopName: regShopName,
        ownerName: regOwnerName,
        email: regEmail,
        phone: regPhone,
        password: regPassword,
        plan: 'TRIAL',
        whatsappNumber: regWhatsapp,
        location: regLocation,
        companyDetails
      });
      setRegSuccessMessage(res.message || 'Registration submitted. Awaiting Super Admin approval.');
    } catch (err) {
      setRegError(err.message || 'Self-registration failed.');
    } finally {
      setRegLoading(false);
    }
  };

  const resetRegisterShopFlow = () => {
    setShowRegisterShop(false);
    setRegShopName('');
    setRegOwnerName('');
    setRegEmail('');
    setRegPhone('');
    setRegWhatsapp('');
    setSameAsPhone(false);
    setRegLocation('');
    setRegPassword('');
    setRegPlan('TRIAL');
    setRegError('');
    setRegSuccessMessage('');
    setRegOtpSent(false);
    setRegOtpVerified(false);
    setRegOtpCode('');
    setRegOtpInput('');
    setRegOtpError('');
    setRegOtpLoading(false);
    setRegShowPayment(false);
    setRegCardNumber('');
    setRegCardExpiry('');
    setRegCardCvv('');
    setRegCardHolder('');
    setRegUpiId('');
    setRegPayProcessing(false);
    setRegPaySuccess(false);
    setRegStep(1);
  };

  if (loading) {
    return (
      <div className="flex h-screen items-center justify-center bg-[#080511]">
        <div className="flex flex-col items-center gap-4">
          <RefreshCw className="h-10 w-10 animate-spin text-primary-500" />
          <p className="text-gray-400 font-medium">Bootstrapping KEE Safe-Workspace...</p>
        </div>
      </div>
    );
  }

  return (
    <>
      {/* Background Mesh Gradients & Glow Effects */}
      <div className="fixed inset-0 z-[-10] overflow-hidden pointer-events-none">
        <div className="mesh-gradient-bg"></div>
        <div className="glow-sphere glow-purple"></div>
        <div className="glow-sphere glow-blue"></div>
      </div>

      {/* Mode Indicator & Switcher Panel - Hides tenant list after login as requested */}
      <div className="bg-[#140e2b] border-b border-primary-900/40 px-4 py-2 flex flex-wrap items-center justify-between gap-4 text-xs z-50 relative">
        <div className="flex items-center gap-2">
          <span className="flex h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <span className="font-semibold tracking-wide text-primary-300 uppercase">KEE MVP Platform Environment</span>
        </div>
        <div className="flex items-center gap-4">
          <div className="flex items-center gap-2">
            <span className="text-gray-400">Database Engine:</span>
            <button 
              onClick={() => toggleMode(true)}
              className={`px-2 py-1 rounded transition ${isDemoMode ? 'bg-primary-600 text-white font-semibold' : 'bg-white/5 text-gray-400 hover:bg-white/10'}`}
            >
              Simulated Demo (LocalStorage)
            </button>
            <button 
              onClick={() => toggleMode(false)}
              className={`px-2 py-1 rounded transition ${!isDemoMode ? 'bg-primary-600 text-white font-semibold' : 'bg-white/5 text-gray-400 hover:bg-white/10'}`}
            >
              Production API (NestJS backend)
            </button>
          </div>


        </div>
      </div>

      {!isAuthenticated ? (
        <div className="min-h-[calc(100vh-40px)] flex items-center justify-center px-4">
          <div className="glass-panel w-full max-w-md p-8 rounded-2xl shadow-2xl relative overflow-hidden animate-fade-in">
            <div className="absolute top-0 right-0 w-24 h-24 bg-primary-500/10 rounded-full blur-2xl"></div>
            <div className="flex flex-col items-center mb-8">
              <div className="bg-primary-500/15 p-3 rounded-xl mb-3 border border-primary-500/30">
                <Key className="h-8 w-8 text-primary-400" />
              </div>
              <h1 className="text-2xl font-extrabold tracking-tight bg-gradient-to-r from-white to-primary-300 bg-clip-text text-transparent">
                KEE PLATFORM
              </h1>
              <p className="text-gray-400 text-sm mt-1">Multi-Tenant Duplicate Key Operations</p>
            </div>

            {authError && (
              <div className="bg-red-950/50 border border-red-500/50 p-3 rounded-lg mb-6 flex gap-2 text-xs text-red-200">
                <AlertTriangle className="h-4 w-4 shrink-0" />
                <span>{authError}</span>
              </div>
            )}

            <form onSubmit={handleLoginSubmit} className="space-y-4">
              <div>
                <label className="block text-xs font-semibold text-gray-300 uppercase tracking-wider mb-2">Email Address</label>
                <input 
                  type="email" required value={authEmail} onChange={(e) => setAuthEmail(e.target.value)}
                  placeholder="admin@kee.com or shop@kee.com" className="w-full glass-input px-4 py-3 rounded-xl text-sm text-white"
                />
              </div>
              <div>
                <div className="flex justify-between items-center mb-2">
                  <label className="block text-xs font-semibold text-gray-300 uppercase tracking-wider">Password</label>
                  <button 
                    type="button" 
                    onClick={() => setShowForgotPassword(true)}
                    className="text-[10px] text-primary-400 hover:text-primary-300 transition hover:underline font-bold uppercase tracking-wider"
                  >
                    Forgot Password?
                  </button>
                </div>
                <div className="relative">
                  <input 
                    type={showAuthPassword ? "text" : "password"} required value={authPassword} onChange={(e) => setAuthPassword(e.target.value)}
                    placeholder="••••••••" className="w-full glass-input pl-4 pr-10 py-3 rounded-xl text-sm text-white"
                  />
                  <button 
                    type="button" 
                    onClick={() => setShowAuthPassword(!showAuthPassword)}
                    className="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white"
                  >
                    {showAuthPassword ? <EyeOff className="h-4 w-4" /> : <Eye className="h-4 w-4" />}
                  </button>
                </div>
              </div>
              <button 
                type="submit" disabled={authLoading}
                className="w-full glass-button-primary text-white py-3 rounded-xl font-semibold text-sm mt-6 flex items-center justify-center gap-2"
              >
                {authLoading ? <RefreshCw className="h-4 w-4 animate-spin" /> : <span>Log In to Workspace</span>}
              </button>
            </form>

            <div className="mt-4 text-center">
              <span className="text-xs text-gray-400">Want to register your shop? </span>
              <button 
                type="button" 
                onClick={() => setShowRegisterShop(true)}
                className="text-xs text-primary-400 hover:text-primary-300 font-bold hover:underline"
              >
                Create Shop Account
              </button>
            </div>

            <div className="mt-8 text-center border-t border-white/5 pt-6 text-[11px] text-gray-500">
              <p>Demo accounts seeded automatically:</p>
              <div className="mt-2 grid grid-cols-2 gap-2 text-left bg-white/2 p-2 rounded-lg border border-white/5">
                <div>
                  <span className="font-semibold text-primary-400 block">Super Admin:</span>
                  <span>admin@kee.com / adminpassword</span>
                </div>
                <div>
                  <span className="font-semibold text-emerald-400 block">Shop Admin:</span>
                  <span>shop@kee.com / shoppassword</span>
                </div>
              </div>
            </div>
          </div>

          {/* Forgot Password Overlay Modal */}
          {showForgotPassword && (
            <div className="fixed inset-0 z-[60] bg-black/80 backdrop-blur-sm flex justify-center p-4">
              <div className="glass-panel w-full max-w-md p-8 rounded-3xl shadow-2xl border border-white/10 my-auto animate-fade-in bg-[#100c25] overflow-hidden flex flex-col relative">
                <button 
                  onClick={resetForgotPasswordFlow}
                  className="absolute top-4 right-4 text-gray-400 hover:text-white transition"
                >
                  <X className="h-5 w-5" />
                </button>

                <div className="flex flex-col items-center mb-6">
                  <div className="bg-primary-500/15 p-2.5 rounded-xl mb-2 border border-primary-500/30">
                    <Lock className="h-6 w-6 text-primary-400" />
                  </div>
                  <h2 className="text-lg font-extrabold text-white tracking-tight">Reset Workspace Password</h2>
                  <p className="text-gray-400 text-xs mt-0.5">Secure recovery portal</p>
                </div>

                {resetError && (
                  <div className="bg-red-950/50 border border-red-500/50 p-2.5 rounded-lg flex gap-2 text-xs text-red-200 mb-4">
                    <AlertTriangle className="h-4 w-4 shrink-0" />
                    <span>{resetError}</span>
                  </div>
                )}

                {resetSuccess ? (
                  <div className="space-y-4 text-center py-4">
                    <div className="w-12 h-12 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-full flex items-center justify-center mx-auto mb-2">
                      <Check className="h-6 w-6" />
                    </div>
                    <p className="text-xs text-emerald-400 font-bold">Password Reset Successfully!</p>
                    <p className="text-[11px] text-gray-400">You can now login with your new credentials.</p>
                    <button 
                      onClick={resetForgotPasswordFlow}
                      className="w-full glass-button-primary text-white py-2.5 rounded-xl text-xs font-semibold"
                    >
                      Return to Login
                    </button>
                  </div>
                ) : resetMethod === null ? (
                  <div className="space-y-4">
                    <p className="text-xs text-gray-400 leading-relaxed text-center">
                      Select your verification method to recover your multi-tenant workspace credentials.
                    </p>
                    <div className="grid grid-cols-2 gap-3 pt-2">
                      <button 
                        onClick={() => setResetMethod('email')}
                        className="glass-panel p-5 rounded-xl text-center hover:border-primary-500/40 transition flex flex-col items-center gap-2.5 group bg-white/2 border border-white/5"
                      >
                        <Mail className="h-6 w-6 text-primary-400 group-hover:scale-110 transition duration-300" />
                        <span className="text-[10px] text-gray-300 font-bold uppercase">Via Email OTP</span>
                      </button>
                      <button 
                        onClick={() => setResetMethod('phone')}
                        className="glass-panel p-5 rounded-xl text-center hover:border-primary-500/40 transition flex flex-col items-center gap-2.5 group bg-white/2 border border-white/5"
                      >
                        <Phone className="h-6 w-6 text-pink-400 group-hover:scale-110 transition duration-300" />
                        <span className="text-[10px] text-gray-300 font-bold uppercase">Via Phone OTP</span>
                      </button>
                    </div>
                    <button 
                      onClick={resetForgotPasswordFlow}
                      className="w-full bg-white/5 hover:bg-white/10 text-gray-300 py-2.5 rounded-xl text-xs font-semibold border border-white/10 transition mt-2"
                    >
                      Cancel
                    </button>
                  </div>
                ) : !otpSent ? (
                  <form onSubmit={handleSendOtp} className="space-y-4">
                    <p className="text-xs text-gray-400 text-center">
                      Enter the registered {resetMethod} associated with your workspace to request a reset passcode.
                    </p>
                    <div>
                      <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2">
                        {resetMethod === 'email' ? 'Registered Email' : 'Registered Phone Number'}
                      </label>
                      <input 
                        type={resetMethod === 'email' ? 'email' : 'text'} 
                        required 
                        value={resetIdentifier} 
                        onChange={(e) => setResetIdentifier(e.target.value)}
                        placeholder={resetMethod === 'email' ? 'e.g. shop@kee.com' : 'e.g. +91 99999 99999'}
                        className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                      />
                    </div>
                    <div className="flex gap-2 pt-2">
                      <button 
                        type="button" 
                        onClick={() => { setResetMethod(null); setResetIdentifier(''); }}
                        className="w-1/3 py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 text-gray-300 rounded-xl text-xs font-semibold transition"
                      >
                        Back
                      </button>
                      <button 
                        type="submit" 
                        disabled={resetLoading}
                        className="w-2/3 glass-button-primary text-white py-2.5 rounded-xl text-xs font-semibold flex items-center justify-center gap-1.5"
                      >
                        {resetLoading ? <RefreshCw className="h-4 w-4 animate-spin" /> : 'Send OTP Code'}
                      </button>
                    </div>
                  </form>
                ) : !otpVerified ? (
                  <form onSubmit={handleVerifyOtp} className="space-y-4">
                    <p className="text-xs text-gray-400 leading-relaxed text-center">
                      A 4-digit code has been dispatched to <span className="text-primary-300 font-semibold">{resetIdentifier}</span>. Check developer logs or display code below.
                    </p>
                    <div className="bg-emerald-500/10 border border-emerald-500/20 p-2 rounded-xl text-[10px] text-center text-emerald-400 my-2">
                      <span className="font-semibold block uppercase text-[8px] text-gray-500 mb-0.5">Verification code</span>
                      <span className="font-extrabold text-sm tracking-widest">{generatedOtp}</span>
                    </div>
                    <div>
                      <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2">Enter OTP</label>
                      <input 
                        type="text" 
                        required 
                        maxLength={4}
                        value={resetOtpInput} 
                        onChange={(e) => setResetOtpInput(e.target.value.replace(/\D/g, ''))}
                        placeholder="e.g. 1234"
                        className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white text-center font-bold tracking-widest"
                      />
                    </div>
                    <div className="flex gap-2 pt-2">
                      <button 
                        type="button" 
                        onClick={() => setOtpSent(false)}
                        className="w-1/3 py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 text-gray-300 rounded-xl text-xs font-semibold transition"
                      >
                        Back
                      </button>
                      <button 
                        type="submit" 
                        className="w-2/3 glass-button-primary text-white py-2.5 rounded-xl text-xs font-semibold"
                      >
                        Verify OTP
                      </button>
                    </div>
                  </form>
                ) : (
                  <form onSubmit={handleResetPasswordSubmit} className="space-y-4">
                    <p className="text-xs text-gray-400 text-center">
                      OTP Verified. Please configure a new password below.
                    </p>
                    <div>
                      <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2">New Password</label>
                      <input 
                        type="password" 
                        required 
                        value={newPassword} 
                        onChange={(e) => setNewPassword(e.target.value)}
                        placeholder="Min 6 characters"
                        className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                      />
                    </div>
                    <div>
                      <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2">Confirm Password</label>
                      <input 
                        type="password" 
                        required 
                        value={confirmPassword} 
                        onChange={(e) => setConfirmPassword(e.target.value)}
                        placeholder="Retype password"
                        className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                      />
                    </div>
                    <button 
                      type="submit" 
                      disabled={resetLoading}
                      className="w-full glass-button-primary text-white py-2.5 rounded-xl text-xs font-bold flex items-center justify-center gap-1.5 mt-2"
                    >
                      {resetLoading ? <RefreshCw className="h-4 w-4 animate-spin" /> : 'Update Password'}
                    </button>
                  </form>
                )}
              </div>
            </div>
          )}

          {showRegisterShop && (

    <div className="fixed inset-0 z-50 overflow-y-auto bg-black/75 backdrop-blur-sm flex justify-center p-4 md:p-10">
      <div className="glass-panel w-full max-w-md rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4 bg-[#100c25]">
        <div className="flex items-center justify-between border-b border-white/5 pb-3">
          <h2 className="text-base font-bold text-white uppercase tracking-wider">Register Your Key Shop</h2>
          <button 
            onClick={() => {
              resetRegisterShopFlow();
              setRegStep(1);
            }} 
            className="text-gray-400 hover:text-white"
          >
            <X className="h-5 w-5" />
          </button>
        </div>

        {regSuccessMessage ? (
          <div className="space-y-4 py-4 text-center">
            <div className="mx-auto bg-emerald-500/20 text-emerald-400 p-3 rounded-full w-12 h-12 flex items-center justify-center border border-emerald-500/30">
              <Check className="h-6 w-6" />
            </div>
            <h3 className="text-sm font-bold text-white uppercase tracking-wider">Registration Submitted</h3>
            <p className="text-xs text-gray-300 px-4 leading-relaxed">
              {regSuccessMessage}
            </p>
            <button 
              onClick={() => {
                resetRegisterShopFlow();
                setRegStep(1);
              }}
              className="px-6 py-2 bg-white/5 hover:bg-white/10 border border-white/10 text-gray-300 rounded-xl text-xs font-semibold mt-2"
            >
              Return to Login
            </button>
          </div>
        ) : (
          <div className="space-y-4">
            {/* Step Progress indicators */}
            <div className="flex items-center justify-between text-[10px] text-gray-400 border-b border-white/5 pb-2">
              <span className={regStep === 1 ? "text-primary-300 font-bold" : ""}>1. Business Info</span>
              <ChevronRight className="h-3 w-3" />
              <span className={regStep === 2 ? "text-primary-300 font-bold" : ""}>2. Verification</span>
              <ChevronRight className="h-3 w-3" />
              <span className={regStep === 3 ? "text-primary-300 font-bold" : ""}>3. Subscription</span>
              {regPlan !== 'TRIAL' && (
                <>
                  <ChevronRight className="h-3 w-3" />
                  <span className={regStep === 4 ? "text-primary-300 font-bold" : ""}>4. Payment</span>
                </>
              )}
            </div>

            {regError && (
              <div className="bg-red-950/40 border border-red-500/30 p-2.5 rounded-lg text-[11px] text-red-200 flex gap-2">
                <AlertTriangle className="h-4 w-4 shrink-0 text-red-400" />
                <span>{regError}</span>
              </div>
            )}

            {/* STEP 1: Info */}
            {regStep === 1 && (
              <div className="space-y-3.5">
                <div>
                  <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-1">Shop Name / Business Name</label>
                  <input 
                    type="text" required value={regShopName} onChange={(e) => setRegShopName(e.target.value)}
                    placeholder="e.g. Metro Duplicate Keys"
                    className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                  />
                </div>

                <div>
                  <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-1">Owner Name</label>
                  <input 
                    type="text" required value={regOwnerName} onChange={(e) => setRegOwnerName(e.target.value)}
                    placeholder="e.g. Rajesh Kumar"
                    className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                  />
                </div>

                <div className="grid grid-cols-2 gap-3">
                  <div>
                    <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-1">Email Address</label>
                    <input 
                      type="email" required value={regEmail} onChange={(e) => setRegEmail(e.target.value)}
                      placeholder="shop@example.com"
                      className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                    />
                  </div>
                  <div>
                    <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-1">Phone Number</label>
                    <input 
                      type="tel" required value={regPhone} onChange={(e) => setRegPhone(e.target.value)}
                      placeholder="+91..."
                      className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                    />
                  </div>
                </div>

                <div className="grid grid-cols-2 gap-3">
                  <div>
                    <div className="flex justify-between items-center mb-1">
                      <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider">WhatsApp Number</label>
                      <label className="flex items-center gap-1 cursor-pointer text-[9px] text-primary-400 font-bold select-none">
                        <input 
                          type="checkbox" checked={sameAsPhone} 
                          onChange={(e) => {
                            setSameAsPhone(e.target.checked);
                            if (e.target.checked) setRegWhatsapp(regPhone);
                          }} 
                          className="rounded border-white/10 bg-white/5 text-primary-500 h-3 w-3" 
                        />
                        <span>Same as Phone</span>
                      </label>
                    </div>
                    <input 
                      type="tel" required value={regWhatsapp} onChange={(e) => setRegWhatsapp(e.target.value)}
                      disabled={sameAsPhone} placeholder="WhatsApp No."
                      className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white disabled:opacity-50"
                    />
                  </div>

                  <div>
                    <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-1">Shop Location Details</label>
                    <input 
                      type="text" required value={regLocation} onChange={(e) => setRegLocation(e.target.value)}
                      placeholder="City, State / Landmark"
                      className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                    />
                  </div>
                </div>

                <div className="flex justify-end pt-3 border-t border-white/5">
                  <button 
                    type="button" 
                    onClick={() => {
                      if (!regShopName || !regOwnerName || !regEmail || !regPhone || !regWhatsapp || !regLocation) {
                        alert('Please fill out all registration fields.');
                        return;
                      }
                      const indianPhoneRegex = /^[6-9]\d{9}$/;
                      if (!indianPhoneRegex.test(regPhone)) {
                        alert('Phone number must be a valid 10-digit Indian mobile number (starting with 6-9).');
                        return;
                      }
                      if (!indianPhoneRegex.test(regWhatsapp)) {
                        alert('WhatsApp number must be a valid 10-digit Indian mobile number (starting with 6-9).');
                        return;
                      }
                      setRegStep(2);
                    }}
                    className="glass-button-primary px-6 py-2 rounded-xl text-xs font-bold text-white"
                  >
                    Continue to OTP Verification
                  </button>
                </div>
              </div>
            )}

            {/* STEP 2: OTP Verification */}
            {regStep === 2 && (
              <div className="space-y-4">
                <p className="text-xs text-gray-400 leading-relaxed text-center">
                  We need to verify your credentials. A secure verification OTP code will be sent to <strong className="text-primary-300">{regEmail}</strong>.
                </p>

                {!regOtpSent ? (
                  <div className="flex justify-center py-4">
                    <button 
                      type="button" onClick={handleSendRegOtp} disabled={regOtpLoading}
                      className="glass-button-primary px-6 py-2.5 rounded-xl text-xs font-bold text-white flex items-center gap-1.5"
                    >
                      {regOtpLoading ? <RefreshCw className="h-4 w-4 animate-spin" /> : <Mail className="h-4 w-4" />}
                      <span>Send Verification OTP Code</span>
                    </button>
                  </div>
                ) : (
                  <form onSubmit={handleVerifyRegOtp} className="space-y-4">
                    {regOtpError && <div className="text-xs text-red-400 font-semibold text-center">{regOtpError}</div>}
                    <div className="bg-white/2 border border-white/5 p-3 rounded-xl text-center space-y-1">
                      <span className="font-semibold block uppercase text-[8px] text-gray-500 mb-0.5">Mock OTP Code</span>
                      <span className="font-extrabold text-sm tracking-widest text-primary-300 font-mono">{regOtpCode}</span>
                    </div>

                    <div>
                      <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2 text-center">Enter Verification OTP</label>
                      <input 
                        type="text" required maxLength={4} value={regOtpInput} onChange={(e) => setRegOtpInput(e.target.value.replace(/\D/g, ''))}
                        placeholder="e.g. 1234" className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white text-center font-bold tracking-widest"
                      />
                    </div>

                    <div className="flex gap-2">
                      <button 
                        type="button" onClick={() => setRegOtpSent(false)}
                        className="w-1/3 py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 text-gray-300 rounded-xl text-xs font-semibold"
                      >
                        Resend OTP
                      </button>
                      <button type="submit" className="w-2/3 glass-button-primary text-white py-2.5 rounded-xl text-xs font-bold">
                        Verify OTP Code
                      </button>
                    </div>
                  </form>
                )}
                
                <div className="pt-2 border-t border-white/5">
                  <button type="button" onClick={() => setRegStep(1)} className="text-xs text-gray-400 hover:text-white">
                    &larr; Back to Shop Info
                  </button>
                </div>
              </div>
            )}

            {/* STEP 3: Plan & Password */}
            {regStep === 3 && (
              <div className="space-y-4">
                <div>
                  <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-1">Create Account Password</label>
                  <div className="relative">
                    <input 
                      type={showRegPassword ? "text" : "password"} required minLength={6} value={regPassword} onChange={(e) => setRegPassword(e.target.value)}
                      placeholder="Min 6 characters" className="w-full glass-input pl-3 pr-10 py-2.5 rounded-xl text-xs text-white"
                    />
                    <button 
                      type="button" 
                      onClick={() => setShowRegPassword(!showRegPassword)}
                      className="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white"
                    >
                      {showRegPassword ? <EyeOff className="h-4 w-4" /> : <Eye className="h-4 w-4" />}
                    </button>
                  </div>
                </div>

                <div>
                  <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-1.5">Choose Subscription Plan</label>
                  <div className="grid grid-cols-3 gap-2">
                    <button 
                      type="button" 
                      onClick={() => setRegPlan('TRIAL')}
                      className={`p-2.5 border rounded-xl flex flex-col items-center justify-center transition text-center ${regPlan === 'TRIAL' ? 'border-primary-500 bg-primary-600/10 text-white' : 'border-white/10 bg-white/2 text-gray-400 hover:bg-white/5'}`}
                    >
                      <span className="text-[10px] font-bold">Free Trial</span>
                      <span className="text-[8px] text-gray-400 mt-0.5 font-bold">7 Days</span>
                    </button>
                    <button 
                      type="button" 
                      onClick={() => setRegPlan('MONTHLY')}
                      className={`p-2.5 border rounded-xl flex flex-col items-center justify-center transition text-center ${regPlan === 'MONTHLY' ? 'border-primary-500 bg-primary-600/10 text-white' : 'border-white/10 bg-white/2 text-gray-400 hover:bg-white/5'}`}
                    >
                      <span className="text-[10px] font-bold">Monthly</span>
                      <span className="text-[8px] text-emerald-400 mt-0.5 font-bold">Rs. 49</span>
                    </button>
                    <button 
                      type="button" 
                      onClick={() => setRegPlan('YEARLY')}
                      className={`p-2.5 border rounded-xl flex flex-col items-center justify-center transition text-center ${regPlan === 'YEARLY' ? 'border-primary-500 bg-primary-600/10 text-white' : 'border-white/10 bg-white/2 text-gray-400 hover:bg-white/5'}`}
                    >
                      <span className="text-[10px] font-bold">Yearly</span>
                      <span className="text-[8px] text-emerald-400 mt-0.5 font-bold">Rs. 499</span>
                    </button>
                  </div>
                </div>

                <div className="space-y-3.5 border-t border-white/5 pt-4">
                  <h4 className="text-[10px] font-bold text-primary-300 uppercase tracking-wider">Upload Shop Documents</h4>
                  
                  <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
                    <div>
                      <label className="block text-[9px] text-gray-400 font-semibold mb-1 uppercase tracking-wider">Shop Photo</label>
                      <div className="relative">
                        <input 
                          type="file" accept="image/*" required
                          onChange={(e) => {
                            const file = e.target.files[0];
                            if (file) {
                              const r = new FileReader();
                              r.onloadend = () => compressBase64Image(r.result, setRegShopPhoto);
                              r.readAsDataURL(file);
                            }
                          }}
                          className="w-full text-xs text-gray-400 file:mr-2 file:py-1.5 file:px-2.5 file:rounded-lg file:border-0 file:text-[10px] file:font-semibold file:bg-primary-600 file:text-white hover:file:bg-primary-500 cursor-pointer"
                        />
                      </div>
                    </div>

                    <div>
                      <label className="block text-[9px] text-gray-400 font-semibold mb-1 uppercase tracking-wider">Shop License</label>
                      <div className="relative">
                        <input 
                          type="file" accept="image/*,application/pdf" required
                          onChange={(e) => {
                            const file = e.target.files[0];
                            if (file) {
                              const r = new FileReader();
                              r.onloadend = () => compressBase64Image(r.result, setRegShopLicense);
                              r.readAsDataURL(file);
                            }
                          }}
                          className="w-full text-xs text-gray-400 file:mr-2 file:py-1.5 file:px-2.5 file:rounded-lg file:border-0 file:text-[10px] file:font-semibold file:bg-primary-600 file:text-white hover:file:bg-primary-500 cursor-pointer"
                        />
                      </div>
                    </div>

                    <div>
                      <label className="block text-[9px] text-gray-400 font-semibold mb-1 uppercase tracking-wider">Owner Aadhaar</label>
                      <div className="relative">
                        <input 
                          type="file" accept="image/*,application/pdf" required
                          onChange={(e) => {
                            const file = e.target.files[0];
                            if (file) {
                              const r = new FileReader();
                              r.onloadend = () => compressBase64Image(r.result, setRegOwnerAadhaar);
                              r.readAsDataURL(file);
                            }
                          }}
                          className="w-full text-xs text-gray-400 file:mr-2 file:py-1.5 file:px-2.5 file:rounded-lg file:border-0 file:text-[10px] file:font-semibold file:bg-primary-600 file:text-white hover:file:bg-primary-500 cursor-pointer"
                        />
                      </div>
                    </div>
                  </div>
                </div>

                <div className="flex justify-between items-center pt-3 border-t border-white/5">
                  <button type="button" onClick={() => setRegStep(2)} className="text-xs text-gray-400 hover:text-white">
                    &larr; Back to Verification
                  </button>
                  {regPlan === 'TRIAL' ? (
                    <button 
                      type="button" 
                      onClick={() => {
                        if (!regPassword || regPassword.length < 6) {
                          alert('Password must be at least 6 characters.');
                          return;
                        }
                        if (!regOwnerAadhaar) {
                          alert('Owner Aadhaar document is mandatory to register.');
                          return;
                        }
                        executeFreeRegistration();
                      }} 
                      disabled={regLoading}
                      className="glass-button-primary px-6 py-2 rounded-xl text-xs font-bold text-white flex items-center gap-1.5"
                    >
                      {regLoading ? <RefreshCw className="h-4 w-4 animate-spin" /> : <span>Complete Registration</span>}
                    </button>
                  ) : (
                    <button 
                      type="button" 
                      onClick={() => {
                        if (!regPassword || regPassword.length < 6) {
                          alert('Password must be at least 6 characters.');
                          return;
                        }
                        if (!regOwnerAadhaar) {
                          alert('Owner Aadhaar document is mandatory to register.');
                          return;
                        }
                        setRegStep(4);
                      }}
                      className="glass-button-primary px-6 py-2 rounded-xl text-xs font-bold text-white"
                    >
                      Proceed to Checkout
                    </button>
                  )}
                </div>
              </div>
            )}

            {/* STEP 4: Payment Checkout */}
            {regStep === 4 && (
              <form onSubmit={handleRegCheckout} className="space-y-4 animate-fade-in relative overflow-hidden">
                {regPayProcessing && (
                  <div className="absolute inset-0 bg-[#100c25]/90 flex flex-col items-center justify-center p-6 space-y-4 z-20">
                    <div className="relative w-12 h-12 flex items-center justify-center">
                      <span className="absolute inset-0 border-4 border-primary-500/20 rounded-full"></span>
                      <span className="absolute inset-0 border-4 border-t-primary-500 rounded-full animate-spin"></span>
                    </div>
                    <h3 className="font-extrabold text-xs uppercase tracking-wider text-white">Settling Payment...</h3>
                  </div>
                )}

                <div className="bg-white/2 p-3 rounded-xl border border-white/5 flex justify-between items-center text-xs text-white">
                  <span>Payable amount:</span>
                  <span className="font-extrabold text-emerald-400 text-sm">
                    Rs. {regPlan === 'MONTHLY' ? '49.00' : '499.00'}
                  </span>
                </div>

                <div className="space-y-3">
                  <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider">Choose Payment Channel</label>
                  <div className="grid grid-cols-2 gap-2">
                    <button
                      type="button" onClick={() => setRegPayMethod('card')}
                      className={`p-2.5 rounded-xl border flex flex-col items-center gap-1.5 transition ${regPayMethod === 'card' ? 'border-primary-500 bg-primary-600/10 text-white font-bold' : 'border-white/5 bg-white/2 text-gray-400 hover:bg-white/5'}`}
                    >
                      <CreditCard className="h-4.5 w-4.5 text-primary-400" />
                      <span className="text-[8px] uppercase tracking-wider">Credit Card</span>
                    </button>
                    <button
                      type="button" onClick={() => setRegPayMethod('upi')}
                      className={`p-2.5 rounded-xl border flex flex-col items-center gap-1.5 transition ${regPayMethod === 'upi' ? 'border-primary-500 bg-primary-600/10 text-white font-bold' : 'border-white/5 bg-white/2 text-gray-400 hover:bg-white/5'}`}
                    >
                      <QrCode className="h-4.5 w-4.5 text-primary-400" />
                      <span className="text-[8px] uppercase tracking-wider">UPI / QR Scan</span>
                    </button>
                  </div>
                </div>

                {regPayMethod === 'card' ? (
                  <div className="space-y-3 animate-fade-in text-[10px]">
                    <div>
                      <label className="block font-semibold text-gray-500 uppercase tracking-wider mb-1">Card Number</label>
                      <input 
                        type="text" required maxLength={16} placeholder="4111 2222 3333 4444" value={regCardNumber} onChange={(e) => setRegCardNumber(e.target.value.replace(/\D/g, ''))}
                        className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white font-mono" 
                      />
                    </div>
                    <div>
                      <label className="block font-semibold text-gray-500 uppercase tracking-wider mb-1">Cardholder Name</label>
                      <input 
                        type="text" required placeholder="RAJESH KUMAR" value={regCardHolder} onChange={(e) => setRegCardHolder(e.target.value.toUpperCase())}
                        className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white" 
                      />
                    </div>
                    <div className="grid grid-cols-2 gap-3">
                      <div>
                        <label className="block font-semibold text-gray-500 uppercase tracking-wider mb-1">Expiry Date</label>
                        <input 
                          type="text" required maxLength={5} placeholder="MM/YY" value={regCardExpiry} onChange={(e) => setRegCardExpiry(e.target.value)}
                          className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white text-center" 
                        />
                      </div>
                      <div>
                        <label className="block font-semibold text-gray-500 uppercase tracking-wider mb-1">CVV</label>
                        <input 
                          type="password" required maxLength={3} placeholder="***" value={regCardCvv} onChange={(e) => setRegCardCvv(e.target.value.replace(/\D/g, ''))}
                          className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white text-center font-mono" 
                        />
                      </div>
                    </div>
                  </div>
                ) : (
                  <div className="bg-[#140e29] border border-white/5 p-4 rounded-xl flex flex-col items-center justify-center py-6 space-y-3 animate-fade-in text-center">
                    <QrCode className="h-12 w-12 text-primary-400" />
                    <p className="text-[10px] text-gray-400 font-medium">Scan QR code using GooglePay, PhonePe, or Paytm</p>
                    <span className="font-bold text-xs text-white font-mono">UPI: keeplace.register@icici</span>
                  </div>
                )}

                <div className="flex gap-2 pt-3 border-t border-white/5">
                  <button type="button" onClick={() => setRegStep(3)} className="w-1/3 py-2.5 border border-white/10 rounded-xl text-xs text-gray-300 font-semibold hover:bg-white/5">
                    Back
                  </button>
                  <button type="submit" className="w-2/3 glass-button-primary text-white py-2.5 rounded-xl text-xs font-bold shadow-lg">
                    Pay & Settle Setup
                  </button>
                </div>
              </form>
            )}
          </div>
        )}
      </div>
    </div>
  )}
        </div>
      ) : (
        <div className="min-h-[calc(100vh-40px)] flex flex-col md:flex-row">
          {/* SIDEBAR NAVIGATION */}
          <aside className="w-full md:w-64 bg-[#100b21]/70 backdrop-blur-lg border-r border-white/5 flex flex-col shrink-0 p-4">
            <div className="flex items-center gap-3 mb-6 px-2">
              <div className="bg-primary-500/20 p-2 rounded-lg border border-primary-500/30">
                <Key className="h-5 w-5 text-primary-400" />
              </div>
              <div>
                <span className="font-bold text-sm tracking-wide block uppercase">{t('welcome')}</span>
                <span className="text-[10px] text-gray-400 uppercase tracking-widest">
                  {user.role === 'SUPER_ADMIN' ? t('superAdmin') : t('shopTerminal')}
                </span>
              </div>
            </div>

            {/* Language Selector Dropdown */}
            <div className="flex flex-col gap-1.5 px-2 mb-6 border-b border-white/5 pb-4">
              <label className="text-[9px] uppercase tracking-wider text-gray-500 font-extrabold block">Language / भाषा / மொழி</label>
              <select 
                value={lang} 
                onChange={(e) => {
                  setLang(e.target.value);
                  localStorage.setItem('kee_lang', e.target.value);
                }}
                className="w-full bg-[#1b1530] border border-white/10 text-xs px-2.5 py-1.5 rounded-lg text-gray-300 focus:outline-none font-semibold cursor-pointer"
              >
                <option value="en">English</option>
                <option value="hi">Hindi (हिन्दी)</option>
                <option value="ta">Tamil (தமிழ்)</option>
                <option value="te">Telugu (తెలుగు)</option>
                <option value="kn">Kannada (ಕನ್ನಡ)</option>
                <option value="ml">Malayalam (മലയാളം)</option>
              </select>
            </div>

            <nav className="flex-1 space-y-1.5">
              <button 
                onClick={() => setActiveTab('dashboard')}
                className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'dashboard' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
              >
                <Sliders className="h-4 w-4" />
                <span>{t('dashboard')}</span>
              </button>

              {user.role === 'SUPER_ADMIN' ? (
                <>
                  <button 
                    onClick={() => setActiveTab('shops')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'shops' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <Layers className="h-4 w-4" />
                    <span>{t('shops')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('super-customers')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'super-customers' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <Users className="h-4 w-4" />
                    <span>{t('customers')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('keys')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'keys' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <Database className="h-4 w-4" />
                    <span>{t('keys')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('inventory')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'inventory' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <ShoppingBag className="h-4 w-4" />
                    <span>{t('inventory')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('pricing-offers')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'pricing-offers' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <Settings className="h-4 w-4" />
                    <span>{t('pricing')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('revenue')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'revenue' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <DollarSign className="h-4 w-4" />
                    <span>{t('revenue')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('support-config')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'support-config' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <Phone className="h-4 w-4" />
                    <span>Support Config</span>
                  </button>
                </>
              ) : (
                <>
                  <button 
                    onClick={() => setActiveTab('search-keys')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'search-keys' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <Search className="h-4 w-4" />
                    <span>{t('searchKeys')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('register')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'register' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <Plus className="h-4 w-4" />
                    <span>{t('register')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('history')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'history' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <Users className="h-4 w-4" />
                    <span>{t('history')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('store')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'store' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <ShoppingCart className="h-4 w-4" />
                    <span>{t('store')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('reports')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'reports' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <BarChart3 className="h-4 w-4" />
                    <span>{t('reports')}</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('customer-care')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'customer-care' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <Phone className="h-4 w-4" />
                    <span>Customer Care</span>
                  </button>
                  <button 
                    onClick={() => setActiveTab('settings')}
                    className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition ${activeTab === 'settings' ? 'bg-primary-600/35 text-white border-l-4 border-primary-500' : 'text-gray-400 hover:text-white hover:bg-white/5'}`}
                  >
                    <Settings className="h-4 w-4" />
                    <span>{t('settings')}</span>
                  </button>
                </>
              )}
            </nav>

            <div className="border-t border-white/5 pt-4 mt-auto">
              <div className="flex flex-col gap-1 mb-3 px-2">
                <span className="text-xs font-semibold text-gray-200 block truncate">{user.name}</span>
                <span className="text-[10px] text-gray-500 block truncate">{user.email}</span>
              </div>
              <button 
                onClick={logout}
                className="w-full flex items-center gap-3 px-3 py-2 rounded-xl text-sm font-medium text-red-400 hover:bg-red-500/10 transition"
              >
                <LogOut className="h-4 w-4" />
                <span>Log Out</span>
              </button>
            </div>
          </aside>

          {/* MAIN CONTENT DISPLAY */}
          <main className="flex-1 p-6 overflow-y-auto space-y-6">
            
            {/* Top Workspace Header Bar */}
            <header className="flex justify-between items-center bg-[#140e2b]/40 backdrop-blur-md p-4 rounded-2xl border border-white/5 shadow-lg mb-6 relative z-50">
              <div className="flex items-center gap-3">
                <span className="h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
                <h2 className="text-xs font-bold text-white uppercase tracking-wider">
                  {user.role === 'SUPER_ADMIN' ? 'Headquarters Command Center' : `${user.name} Terminal`}
                </h2>
              </div>
              
              <div className="flex items-center gap-4 relative">
                {/* Notification Bell */}
                <button 
                  onClick={() => setShowNotifDropdown(!showNotifDropdown)}
                  className="relative p-2 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 text-gray-300 hover:text-white transition duration-200"
                >
                  <Bell className="h-4.5 w-4.5" />
                  {unreadCount > 0 && (
                    <span className="absolute -top-1 -right-1 bg-red-500 text-white font-extrabold text-[9px] w-4.5 h-4.5 rounded-full flex items-center justify-center border border-black animate-pulse">
                      {unreadCount}
                    </span>
                  )}
                </button>

                {/* Notifications dropdown popup overlay */}
                {showNotifDropdown && (
                  <div className="absolute right-0 top-11 w-80 bg-[#120c24] border border-white/10 rounded-2xl shadow-2xl p-4 z-[9999] space-y-3 animate-fade-in text-left">
                    <div className="flex justify-between items-center border-b border-white/5 pb-2">
                      <h3 className="text-xs font-bold text-white uppercase tracking-wider">Notifications</h3>
                      {unreadCount > 0 && (
                        <button 
                          onClick={async () => {
                            try {
                              for (const n of notifications) {
                                if (!n.isRead) {
                                  if (user.role === 'SUPER_ADMIN') {
                                    await api.markSuperNotificationRead(n.id);
                                  } else {
                                    await api.markNotificationRead(n.id);
                                  }
                                }
                              }
                              fetchNotifications();
                            } catch (e) {
                              console.error(e);
                            }
                          }}
                          className="text-[9px] font-bold text-primary-400 hover:text-primary-300 uppercase hover:underline"
                        >
                          Mark all read
                        </button>
                      )}
                    </div>
                    <div className="max-h-60 overflow-y-auto space-y-2 pr-1">
                      {notifications.length === 0 ? (
                        <div className="text-center text-xs text-gray-500 py-6">No notifications found</div>
                      ) : (
                        notifications.map(n => (
                          <div 
                            key={n.id} 
                            onClick={async () => {
                              try {
                                if (user.role === 'SUPER_ADMIN') {
                                  await api.markSuperNotificationRead(n.id);
                                } else {
                                  await api.markNotificationRead(n.id);
                                }
                                fetchNotifications();
                                if (n.type === 'SHOP_REGISTRATION' && user.role === 'SUPER_ADMIN') {
                                  setActiveTab('shops');
                                }
                                setShowNotifDropdown(false);
                              } catch (e) {
                                console.error(e);
                              }
                            }}
                            className={`p-2.5 rounded-xl border text-[11px] cursor-pointer transition ${!n.isRead ? 'bg-primary-950/20 border-primary-500/20 hover:bg-primary-950/30' : 'bg-white/2 border-white/5 hover:bg-white/5'}`}
                          >
                            <div className="flex justify-between items-start mb-1 font-semibold text-white">
                              <span>{n.title}</span>
                              <span className="text-[8px] text-gray-500 font-mono font-normal">
                                {new Date(n.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                              </span>
                            </div>
                            <p className="text-gray-400 text-[10px] leading-relaxed">{n.message}</p>
                          </div>
                        ))
                      )}
                    </div>
                  </div>
                )}
              </div>
            </header>

            {activeTab === 'dashboard' && <DashboardView t={t} setActiveTab={setActiveTab} setAutoOpenShopModal={setAutoOpenShopModal} />}
            {activeTab === 'shops' && <ShopsManagementView t={t} api={api} initiallyOpenAddModal={autoOpenShopModal} onCloseInitiallyOpen={() => setAutoOpenShopModal(false)} />}
            {activeTab === 'super-customers' && <SuperCustomersView t={t} api={api} />}
            {activeTab === 'keys' && <KeysCatalogView t={t} api={api} />}
            {activeTab === 'inventory' && <StoreInventoryView t={t} api={api} />}
            {activeTab === 'pricing-offers' && <PricingOffersView t={t} api={api} />}
            {activeTab === 'revenue' && <RevenueManagementView t={t} api={api} />}
            {activeTab === 'search-keys' && <KeysSearchView t={t} api={api} />}
            {activeTab === 'register' && <CustomerRegistrationWizard t={t} api={api} />}
            {activeTab === 'history' && <CustomerHistoryView t={t} api={api} />}
            {activeTab === 'store' && <PlatformStoreView t={t} api={api} />}
            {activeTab === 'reports' && <ReportsPortalView t={t} api={api} />}
            {activeTab === 'customer-care' && <CustomerCareView t={t} api={api} />}
            {activeTab === 'support-config' && <SupportConfigView t={t} api={api} />}
            {activeTab === 'settings' && <ShopSettingsView t={t} api={api} />}
          </main>
        </div>
      )}
    </>
  );
}

// ============================================================================
// COMPONENT 1: DASHBOARD VIEW WITH INTERACTIVE CARD DETAILS
// ============================================================================
function DashboardView({ t, setActiveTab, setAutoOpenShopModal }) {
  const { user, api } = useAuth();
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [activeDetail, setActiveDetail] = useState(null); // Interactive details drawer
  const [activePopupAd, setActivePopupAd] = useState(null);
  const [discountedProducts, setDiscountedProducts] = useState([]);

  useEffect(() => {
    if (user.role === 'SHOP_ADMIN') {
      fetchOfferProducts();
    }
  }, [user]);

  const fetchOfferProducts = async () => {
    try {
      const res = await api.getProducts();
      setDiscountedProducts(res.filter(p => p.discountPercentage > 0 && p.status === 'ACTIVE'));
    } catch (e) {
      console.error(e);
    }
  };

  useEffect(() => {
    if (activePopupAd) {
      const timer = setTimeout(() => {
        sessionStorage.setItem(`dismissed_ad_${activePopupAd.id}`, 'true');
        setActivePopupAd(null);
      }, 10000);
      return () => clearTimeout(timer);
    }
  }, [activePopupAd]);

  useEffect(() => {
    fetchDashboardData();
    if (user.role === 'SHOP_ADMIN') {
      fetchPopupAds();
    }
  }, [user]);

  const fetchPopupAds = async () => {
    try {
      const ads = await api.getAdvertisements();
      const popups = ads.filter(ad => ad.type === 'POPUP');
      if (popups.length > 0) {
        const sorted = popups.sort((a, b) => b.priority - a.priority);
        const dismissed = sessionStorage.getItem(`dismissed_ad_${sorted[0].id}`);
        if (!dismissed) {
          setActivePopupAd(sorted[0]);
        }
      }
    } catch (e) {
      console.error('Failed to fetch advertisements for popup', e);
    }
  };

  const fetchDashboardData = async () => {
    setLoading(true);
    try {
      const res = await api.getDashboard();
      setData(res);
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  if (loading) {
    return (
      <div className="flex h-64 items-center justify-center">
        <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
      </div>
    );
  }

  const toggleDetail = (card) => {
    setActiveDetail(activeDetail === card ? null : card);
  };

  if (user.role === 'SUPER_ADMIN') {
    return (
      <div className="space-y-6 animate-fade-in">
        <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h1 className="text-2xl font-extrabold tracking-tight">{t('superAdmin')} Portal</h1>
            <p className="text-sm text-gray-400 mt-1">Platform overview. Click on cards to view detailed splits.</p>
          </div>
          <div className="flex gap-2 self-end">
            <button 
              onClick={() => {
                setAutoOpenShopModal(true);
                setActiveTab('shops');
              }}
              className="glass-button-primary text-white text-xs font-semibold px-4 py-2 rounded-xl flex items-center gap-2"
            >
              <Plus className="h-4 w-4" />
              <span>{t('provisionNewShop')}</span>
            </button>
            <button onClick={fetchDashboardData} className="glass-panel p-2 rounded-lg text-gray-400 hover:text-white transition">
              <RefreshCw className="h-4 w-4" />
            </button>
          </div>
        </div>

        {/* Stats Grid with Expandable Interactions */}
        <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div 
            onClick={() => toggleDetail('shops')}
            className={`glass-panel p-5 rounded-2xl cursor-pointer hover:border-primary-500/40 transition duration-300 ${activeDetail === 'shops' ? 'ring-1 ring-primary-500' : ''}`}
          >
            <div className="flex items-center justify-between text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">
              <span>{t('shopsRegistered')}</span>
              <Layers className="h-4 w-4 text-purple-400" />
            </div>
            <div className="text-3xl font-extrabold">{data.shops.total}</div>
            <p className="text-[10px] text-gray-400 mt-1 hover:underline">Click to view active splits</p>
          </div>

          <div 
            onClick={() => toggleDetail('customers')}
            className={`glass-panel p-5 rounded-2xl cursor-pointer hover:border-primary-500/40 transition duration-300 ${activeDetail === 'customers' ? 'ring-1 ring-primary-500' : ''}`}
          >
            <div className="flex items-center justify-between text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">
              <span>{t('complianceRegistry')}</span>
              <Users className="h-4 w-4 text-emerald-400" />
            </div>
            <div className="text-3xl font-extrabold">{data.stats.customers}</div>
            <p className="text-[10px] text-gray-400 mt-1 hover:underline">Click to see file type split</p>
          </div>

          <div 
            onClick={() => toggleDetail('storage')}
            className={`glass-panel p-5 rounded-2xl cursor-pointer hover:border-primary-500/40 transition duration-300 ${activeDetail === 'storage' ? 'ring-1 ring-primary-500' : ''}`}
          >
            <div className="flex items-center justify-between text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">
              <span>{t('hostStorage')}</span>
              <Database className="h-4 w-4 text-blue-400" />
            </div>
            <div className="text-3xl font-extrabold">{(data.stats.storageUsed / (1024 * 1024)).toFixed(2)} MB</div>
            <p className="text-[10px] text-gray-400 mt-1 hover:underline">Click to view tenant storage</p>
          </div>

          <div 
            onClick={() => toggleDetail('revenue')}
            className={`glass-panel p-5 rounded-2xl cursor-pointer hover:border-primary-500/40 transition duration-300 ${activeDetail === 'revenue' ? 'ring-1 ring-primary-500' : ''}`}
          >
            <div className="flex items-center justify-between text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">
              <span>{t('annualRevenue')}</span>
              <DollarSign className="h-4 w-4 text-pink-400" />
            </div>
            <div className="text-3xl font-extrabold">
              Rs. {(data.revenue.reduce((acc, r) => acc + r.amount, 0) + (data.subscriptionRevenue || 0)).toFixed(2)}
            </div>
            <p className="text-[10px] text-gray-400 mt-1 hover:underline">Click to see monthly split</p>
          </div>
        </div>

        {/* Expandable Interactions Section */}
        {activeDetail && (
          <div className="glass-panel p-5 rounded-2xl bg-primary-950/15 border border-primary-500/30 animate-fade-in space-y-3">
            <div className="flex items-center justify-between border-b border-white/5 pb-2">
              <h3 className="text-xs font-bold text-primary-300 uppercase tracking-widest flex items-center gap-1.5">
                <Info className="h-3.5 w-3.5" />
                <span>Interactive Summary: {activeDetail}</span>
              </h3>
              <button onClick={() => setActiveDetail(null)} className="text-gray-400 hover:text-white">
                <X className="h-4 w-4" />
              </button>
            </div>

            {activeDetail === 'shops' && (
              <div className="text-xs grid grid-cols-2 md:grid-cols-4 gap-4">
                <div className="bg-white/2 p-3 rounded-xl border border-white/5">
                  <span className="text-gray-400 block mb-1">Active Tiers</span>
                  <span className="font-extrabold text-emerald-400 text-lg">{data.shops.active} Shops</span>
                </div>
                <div className="bg-white/2 p-3 rounded-xl border border-white/5">
                  <span className="text-gray-400 block mb-1">Suspended Tiers</span>
                  <span className="font-extrabold text-red-400 text-lg">{data.shops.inactive} Shops</span>
                </div>
              </div>
            )}

            {activeDetail === 'customers' && (
              <div className="text-xs text-gray-300">
                <p>Compliance entries are indexed and secured using AES-256 application-level encryption.</p>
                <p className="mt-1">Average transaction rate: <span className="font-semibold text-white">{(data.stats.customers / 30).toFixed(1)} / day</span></p>
              </div>
            )}

            {activeDetail === 'storage' && (
              <div className="text-xs text-gray-300 space-y-1">
                <p>Disk Pool Size: <span className="font-bold text-white">100 GB</span></p>
                <p>Total Used: <span className="font-bold text-primary-300">{(data.stats.storageUsed / (1024 * 1024)).toFixed(2)} MB</span></p>
                <div className="w-full bg-white/5 h-2 rounded-full overflow-hidden mt-2">
                  <div className="bg-primary-500 h-full" style={{ width: '0.8%' }}></div>
                </div>
              </div>
            )}

            {activeDetail === 'revenue' && (
              <div className="text-xs space-y-2">
                <div className="bg-[#1b1530]/50 border border-white/5 p-3 rounded-xl flex items-center justify-between font-bold text-white mb-2">
                  <span className="text-gray-400">Total Subscription Collections:</span>
                  <span className="text-emerald-400">Rs. {data.subscriptionRevenue || 0}</span>
                </div>
                <p className="text-gray-400 font-bold uppercase tracking-wider text-[9px] mb-1">Manual Revenue Records Split:</p>
                <div className="grid grid-cols-2 md:grid-cols-4 gap-2">
                  {data.revenue.map(r => (
                    <div key={r.id} className="bg-white/2 p-2 rounded-lg border border-white/5 flex justify-between">
                      <span>M{r.month}/{r.year}</span>
                      <span className="font-bold text-emerald-400">Rs. {r.amount}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {/* Dashboard Grid */}
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div className="glass-panel p-6 rounded-2xl flex flex-col">
            <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3 mb-4 flex items-center justify-between">
              <span>Subscriptions Expiring Soon</span>
              <AlertTriangle className="h-4 w-4 text-amber-500 animate-pulse" />
            </h2>
            {data.expiringSubscriptions.length === 0 ? (
              <div className="flex-1 flex items-center justify-center text-xs text-gray-500 py-10">
                No active subscriptions expiring in the next 10 days.
              </div>
            ) : (
              <div className="space-y-3">
                {data.expiringSubscriptions.map(s => (
                  <div key={s.id} className="bg-white/2 border border-white/5 p-3 rounded-xl flex items-center justify-between text-xs">
                    <div>
                      <p className="font-bold text-gray-200">{s.shopName}</p>
                      <p className="text-[10px] text-gray-500 mt-0.5">Plan Tier: {s.plan}</p>
                    </div>
                    <div className="text-right">
                      <p className="text-amber-400 font-semibold">Ends: {new Date(s.endDate).toLocaleDateString()}</p>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>

          <div className="glass-panel p-6 rounded-2xl flex flex-col">
            <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3 mb-4">
              Platform-Wide Key Popularity
            </h2>
            {data.popularKeys.length === 0 ? (
              <div className="flex-1 flex items-center justify-center text-xs text-gray-500 py-10">
                No key blank transactions logged yet.
              </div>
            ) : (
              <div className="space-y-4 flex-1 justify-center flex flex-col">
                {data.popularKeys.map((k) => (
                  <div key={k.keyNumber} className="space-y-1">
                    <div className="flex justify-between text-xs font-semibold">
                      <span className="text-gray-300">{k.keyNumber}</span>
                      <span className="text-primary-400">{k.count} cuts</span>
                    </div>
                    <div className="w-full bg-white/5 h-2 rounded-full overflow-hidden">
                      <div 
                        className="bg-primary-500 h-full rounded-full" 
                        style={{ width: `${(k.count / data.popularKeys[0].count) * 100}%` }}
                      ></div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    );
  }

  // SHOP ADMIN DASHBOARD
  const sub = data.subscription;
  return (
    <div className="space-y-6 animate-fade-in">
      <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div className="flex items-center gap-3">
          {data.shop?.logoUrl ? (
            <img src={cleanGoogleImageUrl(data.shop.logoUrl)} alt="Shop Logo" className="w-10 h-10 rounded-xl object-cover border border-white/10" />
          ) : (
            <div className="p-2.5 bg-primary-500/10 border border-primary-500/25 rounded-xl text-primary-400">
              <Key className="h-5 w-5" />
            </div>
          )}
          <div>
            <h1 className="text-2xl font-extrabold tracking-tight">
              {data.shop ? data.shop.name : `${t('shopTerminal')} Workspace`}
            </h1>
            <p className="text-sm text-gray-400 mt-1">Logged in as {user.name} • {t('shopTerminal')}</p>
          </div>
        </div>
        <div className="flex gap-2 self-end">
          <button 
            onClick={() => setActiveTab('register')}
            className="glass-button-primary text-white text-xs font-semibold px-4 py-2.5 rounded-xl flex items-center gap-2"
          >
            <Plus className="h-4 w-4" />
            <span>Register Customer</span>
          </button>
          <button onClick={fetchDashboardData} className="glass-panel p-2.5 rounded-xl text-gray-400 hover:text-white transition">
            <RefreshCw className="h-4 w-4" />
          </button>
        </div>
      </div>

      {sub && sub.daysRemaining <= 7 && (
        <div className="bg-amber-950/40 border border-amber-500/40 p-4 rounded-2xl flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div className="flex items-start gap-3">
            <AlertTriangle className="h-5 w-5 text-amber-400 shrink-0 mt-0.5" />
            <div>
              <p className="font-semibold text-sm text-white">Subscription Renewal Required!</p>
              <p className="text-xs text-gray-400">
                Your shop subscription is set to expire in <span className="text-amber-300 font-bold">{sub.daysRemaining} days</span>. Please coordinate renewal with KEE Super Admin.
              </p>
            </div>
          </div>
          <div className="text-xs font-semibold bg-amber-600/20 text-amber-300 px-3 py-1.5 rounded-lg border border-amber-500/20 uppercase tracking-wider">
            {sub.plan} Plan
          </div>
        </div>
      )}

      {/* Shop KPI Cards */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div 
          onClick={() => toggleDetail('today')}
          className={`glass-panel p-5 rounded-2xl cursor-pointer hover:border-primary-500/40 transition duration-300 ${activeDetail === 'today' ? 'ring-1 ring-primary-500' : ''}`}
        >
          <div className="flex items-center justify-between text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">
            <span>Today's Registrations</span>
            <Check className="h-4 w-4 text-emerald-400" />
          </div>
          <div className="text-3xl font-extrabold">{data.todayCustomers}</div>
          <p className="text-[10px] text-gray-400 mt-1 hover:underline">Click to view timeline</p>
        </div>

        <div 
          onClick={() => toggleDetail('total')}
          className={`glass-panel p-5 rounded-2xl cursor-pointer hover:border-primary-500/40 transition duration-300 ${activeDetail === 'total' ? 'ring-1 ring-primary-500' : ''}`}
        >
          <div className="flex items-center justify-between text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">
            <span>Total Customers</span>
            <Users className="h-4 w-4 text-primary-400" />
          </div>
          <div className="text-3xl font-extrabold">{data.totalCustomers}</div>
          <p className="text-[10px] text-gray-400 mt-1 hover:underline">Click to view averages</p>
        </div>

        <div 
          onClick={() => toggleDetail('subscription')}
          className={`glass-panel p-5 rounded-2xl cursor-pointer hover:border-primary-500/40 transition duration-300 ${activeDetail === 'subscription' ? 'ring-1 ring-primary-500' : ''}`}
        >
          <div className="flex items-center justify-between text-gray-400 text-xs font-semibold uppercase tracking-wider mb-2">
            <span>Terminal Subscription</span>
            <Shield className="h-4 w-4 text-blue-400" />
          </div>
          <div className="text-2xl font-extrabold text-white">
            {sub ? sub.plan : 'No Active Plan'}
          </div>
          <p className="text-[10px] text-gray-400 mt-1.5 hover:underline">Click to view expiry date</p>
        </div>
      </div>

      {/* Expandable Details Box */}
      {activeDetail && (
        <div className="glass-panel p-5 rounded-2xl bg-primary-950/15 border border-primary-500/30 animate-fade-in space-y-2">
          <div className="flex items-center justify-between border-b border-white/5 pb-2">
            <h3 className="text-xs font-bold text-primary-300 uppercase tracking-widest flex items-center gap-1.5">
              <Info className="h-3.5 w-3.5" />
              <span>Workspace Info: {activeDetail}</span>
            </h3>
            <button onClick={() => setActiveDetail(null)} className="text-gray-400 hover:text-white">
              <X className="h-4 w-4" />
            </button>
          </div>

          {activeDetail === 'today' && (
            <p className="text-xs text-gray-300">Compliance entries submitted today: <span className="font-semibold text-white">{data.todayCustomers} records</span>.</p>
          )}
          {activeDetail === 'total' && (
            <p className="text-xs text-gray-300">Lifetime duplicate key compliance logs recorded at this terminal: <span className="font-semibold text-white">{data.totalCustomers} entries</span>.</p>
          )}
          {activeDetail === 'subscription' && sub && (
            <p className="text-xs text-gray-300">Subscription expires on <span className="font-semibold text-white">{new Date(sub.endDate).toLocaleDateString()}</span> ({sub.daysRemaining} days remaining).</p>
          )}
        </div>
      )}

      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div className="glass-panel p-6 rounded-2xl flex flex-col">
          <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3 mb-4">
            Recent Compliance Registrations
          </h2>
          {data.recentCustomers.length === 0 ? (
            <div className="flex-1 flex items-center justify-center text-xs text-gray-500 py-10">
              No customers logged yet. Click "Register Customer" in sidebar to start.
            </div>
          ) : (
            <div className="space-y-3">
              {data.recentCustomers.map(c => (
                <div key={c.id} className="bg-white/2 border border-white/5 p-3 rounded-xl flex items-center justify-between text-xs">
                  <div>
                    <p className="font-semibold text-gray-200">{c.name}</p>
                    <p className="text-[10px] text-gray-500 mt-0.5">{c.phone} • Key: {c.keyNumber}</p>
                  </div>
                  <div className="text-right">
                    <p className="text-gray-500 text-[10px]">{new Date(c.createdAt).toLocaleTimeString()}</p>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>

        <div className="glass-panel p-6 rounded-2xl flex flex-col">
          <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3 mb-4">
            Customer Registration Trend (Last 6 Months)
          </h2>
          {!data.monthlyStats || data.monthlyStats.length === 0 ? (
            <div className="flex-1 flex items-center justify-center text-xs text-gray-500 py-10">
              No registration history logged yet.
            </div>
          ) : (
            <div className="flex-1 flex flex-col justify-between space-y-4">
              <div className="h-40 w-full relative">
                {/* SVG Line Graph */}
                <svg className="w-full h-full" viewBox="0 0 500 160" preserveAspectRatio="none">
                  {/* Grid Lines */}
                  <line x1="0" y1="40" x2="500" y2="40" stroke="rgba(255,255,255,0.03)" strokeWidth="1" />
                  <line x1="0" y1="80" x2="500" y2="80" stroke="rgba(255,255,255,0.03)" strokeWidth="1" />
                  <line x1="0" y1="120" x2="500" y2="120" stroke="rgba(255,255,255,0.03)" strokeWidth="1" />
                  <line x1="0" y1="150" x2="500" y2="150" stroke="rgba(255,255,255,0.05)" strokeWidth="1.5" />

                  {/* Draw Line and Dots */}
                  {(() => {
                    const stats = data.monthlyStats;
                    const maxCount = Math.max(...stats.map(s => s.count), 5);
                    const points = stats.map((s, idx) => {
                      const x = (idx / (stats.length - 1)) * 500;
                      // Height scaling from 10 to 140 (160 is total height, keeping 10 margin top/bottom)
                      const y = 150 - (s.count / maxCount) * 110;
                      return { x, y, count: s.count };
                    });

                    const pathD = points.reduce((acc, p, idx) => {
                      return acc + (idx === 0 ? `M ${p.x} ${p.y}` : ` L ${p.x} ${p.y}`);
                    }, '');

                    const areaD = points.reduce((acc, p, idx) => {
                      return acc + (idx === 0 ? `M ${p.x} ${p.y}` : ` L ${p.x} ${p.y}`);
                    }, '') + ` L 500 150 L 0 150 Z`;

                    return (
                      <>
                        {/* Area under line */}
                        <path d={areaD} fill="url(#lineGradient)" opacity="0.15" />
                        
                        {/* Line path */}
                        <path d={pathD} fill="none" stroke="#8C24FF" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" />
                        
                        {/* Data Points */}
                        {points.map((p, idx) => (
                          <g key={idx} className="group cursor-pointer">
                            <circle cx={p.x} cy={p.y} r="4" fill="#8C24FF" stroke="#100c25" strokeWidth="2" className="transition hover:r-6" />
                            <text x={p.x} y={p.y - 10} textAnchor="middle" fill="#DCA2FF" fontSize="9" fontWeight="bold" className="opacity-0 group-hover:opacity-100 transition duration-200">
                              {p.count}
                            </text>
                          </g>
                        ))}

                        <defs>
                          <linearGradient id="lineGradient" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stopColor="#8C24FF" stopOpacity="0" />
                            <stop offset="100%" stopColor="#8C24FF" stopOpacity="0" />
                          </linearGradient>
                        </defs>
                      </>
                    );
                  })()}
                </svg>
              </div>

              {/* Month Labels */}
              <div className="flex justify-between text-[9px] text-gray-500 font-bold uppercase tracking-wider font-mono px-1">
                {data.monthlyStats.map(s => (
                  <span key={s.month}>{s.month.split(' ')[0]}</span>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>

      {/* Active Announcement Popup Modal */}
      {activePopupAd && createPortal(
        <div className="fixed inset-0 z-[60] overflow-y-auto bg-black/85 backdrop-blur-md flex justify-center p-4 md:p-10">
          <div className="glass-panel w-full max-w-md rounded-3xl shadow-2xl border border-white/10 my-auto animate-fade-in bg-[#100c25] overflow-hidden flex flex-col">
            <div className="relative">
              <img src={cleanGoogleImageUrl(activePopupAd.imageUrl)} alt={activePopupAd.title} className="w-full h-48 object-cover opacity-90" />
              <div className="absolute top-3 right-3">
                <button 
                  onClick={() => {
                    sessionStorage.setItem(`dismissed_ad_${activePopupAd.id}`, 'true');
                    setActivePopupAd(null);
                  }}
                  className="bg-black/50 hover:bg-black/80 text-white p-1.5 rounded-full transition"
                >
                  <X className="h-4 w-4" />
                </button>
              </div>
              <div className="absolute bottom-0 inset-x-0 bg-gradient-to-t from-[#100c25] to-transparent h-16"></div>
            </div>
            
            <div className="p-6 space-y-4">
              <span className="text-[9px] uppercase tracking-widest font-extrabold bg-primary-600/20 text-primary-300 px-2.5 py-1 border border-primary-500/25 rounded-md">
                Featured Announcement
              </span>
              <h3 className="text-base font-extrabold text-white leading-snug">{activePopupAd.title}</h3>
              <p className="text-xs text-gray-400 leading-relaxed">
                Special promotion from KEE Headquarters for duplicate key shop workspaces. Upgrade inventory stock or log compliance checks to qualify.
              </p>

              {discountedProducts.length > 0 && (
                <div className="space-y-2 border-t border-white/5 pt-3">
                  <span className="text-[9px] uppercase tracking-wider font-extrabold text-emerald-400 block">Active Offers</span>
                  <div className="flex gap-2 overflow-x-auto pb-1 max-h-32 scrollbar-thin">
                    {discountedProducts.map(p => (
                      <div 
                        key={p.id} 
                        onClick={() => {
                          sessionStorage.setItem(`dismissed_ad_${activePopupAd.id}`, 'true');
                          setActivePopupAd(null);
                          setActiveTab('store');
                        }}
                        className="bg-white/5 border border-white/10 rounded-xl p-2 flex items-center gap-3 shrink-0 w-52 cursor-pointer hover:bg-white/10 transition"
                      >
                        <img src={p.imageUrl} alt={p.name} className="w-8 h-8 rounded-lg object-cover border border-white/5 shrink-0" />
                        <div className="min-w-0 flex-1">
                          <p className="font-bold text-[10px] text-white truncate leading-none">{p.name}</p>
                          <div className="flex items-center gap-1.5 mt-1.5 leading-none">
                            <span className="text-[9px] text-gray-500 line-through leading-none">Rs. {p.price.toFixed(2)}</span>
                            <span className="text-[10px] text-emerald-400 font-extrabold leading-none">Rs. {(p.offerPrice || p.price).toFixed(2)}</span>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
              
              <div className="border-t border-white/5 pt-4 flex gap-3">
                <button 
                  onClick={() => {
                    sessionStorage.setItem(`dismissed_ad_${activePopupAd.id}`, 'true');
                    setActivePopupAd(null);
                  }}
                  className="w-1/2 py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-xs font-semibold text-gray-300 transition"
                >
                  Dismiss Offer
                </button>
                <button 
                  onClick={() => {
                    sessionStorage.setItem(`dismissed_ad_${activePopupAd.id}`, 'true');
                    setActivePopupAd(null);
                    setActiveTab('store');
                  }}
                  className="w-1/2 glass-button-primary text-white py-2.5 rounded-xl font-bold text-xs"
                >
                  View Details
                </button>
              </div>
            </div>
          </div>
        </div>,
        document.body
      )}
    </div>
  );
}

// ============================================================================
// COMPONENT 2: SHOPS MANAGEMENT WITH OPTIMIZED CENTERED FIXED DIALOG
// ============================================================================
function ShopsManagementView({ t, api, initiallyOpenAddModal, onCloseInitiallyOpen }) {
  const [shops, setShops] = useState([]);
  const [loading, setLoading] = useState(true);
  const [showAddModal, setShowAddModal] = useState(false);

  useEffect(() => {
    if (initiallyOpenAddModal) {
      setShowAddModal(true);
      if (onCloseInitiallyOpen) onCloseInitiallyOpen();
    }
  }, [initiallyOpenAddModal]);
  const [showSubModal, setShowSubModal] = useState(false);
  const [showEditModal, setShowEditModal] = useState(false); // Edit shop profile
  const [selectedShop, setSelectedShop] = useState(null);

  // Form States for Add Shop
  const [shopName, setShopName] = useState('');
  const [adminEmail, setAdminEmail] = useState('');
  const [adminName, setAdminName] = useState('');
  const [adminPassword, setAdminPassword] = useState('');
  const [subPlan, setSubPlan] = useState('TRIAL');
  const [subEndDate, setSubEndDate] = useState('');
  const [provisionPhone, setProvisionPhone] = useState('');
  const [provisionWhatsapp, setProvisionWhatsapp] = useState('');
  const [provisionLocation, setProvisionLocation] = useState('');
  const [provisionSameAsPhone, setProvisionSameAsPhone] = useState(false);
  const [provisionShopPhoto, setProvisionShopPhoto] = useState('');
  const [provisionShopLicense, setProvisionShopLicense] = useState('');
  const [provisionOwnerAadhaar, setProvisionOwnerAadhaar] = useState('');
  const [errorMsg, setErrorMsg] = useState('');

  // Form States for Edit Shop Details (Super Admin capability)
  const [editName, setEditName] = useState('');
  const [editThemeColor, setEditThemeColor] = useState('#8C24FF');
  const [editLogoUrl, setEditLogoUrl] = useState('');
  const [editAddress, setEditAddress] = useState('');
  const [editGst, setEditGst] = useState('');
  const [editPhone, setEditPhone] = useState('');
  const [editShopPhoto, setEditShopPhoto] = useState('');
  const [editShopLicense, setEditShopLicense] = useState('');
  const [editOwnerAadhaar, setEditOwnerAadhaar] = useState('');

  // Form States for Subscription management
  const [newPlan, setNewPlan] = useState('MONTHLY');
  const [newEndDate, setNewEndDate] = useState('');

  // Plan Prices configuration loaded from system settings
  const [planPrices, setPlanPrices] = useState({ TRIAL: 0, MONTHLY: 49, YEARLY: 499 });

  // Payment integration states for new shop provision
  const [showPaymentProvisionModal, setShowPaymentProvisionModal] = useState(false);
  const [provisionDto, setProvisionDto] = useState(null);
  const [paymentMethod, setPaymentMethod] = useState('card');
  const [paymentProcessing, setPaymentProcessing] = useState(false);
  const [paymentSuccess, setPaymentSuccess] = useState(false);
  const [processingLog, setProcessingLog] = useState('');
  const [cardNumber, setCardNumber] = useState('');
  const [cardHolder, setCardHolder] = useState('');
  const [cardExpiry, setCardExpiry] = useState('');
  const [cardCvv, setCardCvv] = useState('');

  const fetchPlanPrices = async () => {
    try {
      const res = await api.getPlanPrices();
      setPlanPrices(res);
    } catch (e) {
      console.error(e);
    }
  };

  useEffect(() => {
    fetchShops();
    fetchPlanPrices();
  }, []);

  // Automatic End Date Updater for Shop Creation Form
  useEffect(() => {
    const calculateEndDate = () => {
      const now = new Date();
      if (subPlan === 'TRIAL') {
        now.setDate(now.getDate() + 15);
      } else if (subPlan === 'MONTHLY') {
        now.setMonth(now.getMonth() + 1);
      } else if (subPlan === 'YEARLY') {
        now.setFullYear(now.getFullYear() + 1);
      }
      const yyyy = now.getFullYear();
      const mm = String(now.getMonth() + 1).padStart(2, '0');
      const dd = String(now.getDate()).padStart(2, '0');
      setSubEndDate(`${yyyy}-${mm}-${dd}`);
    };
    calculateEndDate();
  }, [subPlan]);

  // Automatic End Date Updater for Plan Updates Form
  useEffect(() => {
    const calculateNewEndDate = () => {
      const now = new Date();
      if (newPlan === 'TRIAL') {
        now.setDate(now.getDate() + 15);
      } else if (newPlan === 'MONTHLY') {
        now.setMonth(now.getMonth() + 1);
      } else if (newPlan === 'YEARLY') {
        now.setFullYear(now.getFullYear() + 1);
      }
      const yyyy = now.getFullYear();
      const mm = String(now.getMonth() + 1).padStart(2, '0');
      const dd = String(now.getDate()).padStart(2, '0');
      setNewEndDate(`${yyyy}-${mm}-${dd}`);
    };
    calculateNewEndDate();
  }, [newPlan]);

  const fetchShops = async () => {
    setLoading(true);
    try {
      const res = await api.getShops();
      setShops(res);
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  const executeShopCreation = async (dto) => {
    try {
      await api.createShop(dto);
      setShowAddModal(false);
      resetAddForm();
      fetchShops();
    } catch (err) {
      setErrorMsg(err.message || 'Failed to create key shop. Try again.');
      throw err;
    }
  };

  const handleCreateShopSubmit = async (e) => {
    e.preventDefault();
    setErrorMsg('');
    try {
      const indianPhoneRegex = /^[6-9]\d{9}$/;
      if (!indianPhoneRegex.test(provisionPhone)) {
        alert('Phone number must be a valid 10-digit Indian mobile number (starting with 6-9).');
        return;
      }
      if (provisionWhatsapp && !indianPhoneRegex.test(provisionWhatsapp)) {
        alert('WhatsApp number must be a valid 10-digit Indian mobile number (starting with 6-9).');
        return;
      }

      if (!provisionOwnerAadhaar) {
        alert('Owner Aadhaar document is mandatory to provision a shop workspace.');
        return;
      }

      const formattedEndDate = new Date(subEndDate).toISOString();
      const companyDetails = JSON.stringify({
        address: provisionLocation,
        gst: 'Pending',
        phone: provisionPhone,
        whatsappNumber: provisionWhatsapp,
        shopPhoto: provisionShopPhoto,
        shopLicense: provisionShopLicense,
        ownerAadhaar: provisionOwnerAadhaar
      });
      const dto = {
        name: shopName,
        adminEmail,
        adminName,
        adminPassword,
        plan: subPlan,
        endDate: formattedEndDate,
        companyDetails,
        themeColor: '#8C24FF'
      };

      const price = planPrices[subPlan] ?? 0;
      if (price > 0) {
        setProvisionDto(dto);
        setShowPaymentProvisionModal(true);
        setPaymentSuccess(false);
        setPaymentProcessing(false);
        setProcessingLog('');
      } else {
        await executeShopCreation(dto);
      }
    } catch (err) {
      setErrorMsg(err.message || 'Failed to initialize subscription checkout. Try again.');
    }
  };

  const executePaymentProvision = async (e) => {
    e.preventDefault();
    setPaymentProcessing(true);

    const logs = [
      'Establishing secure end-to-end sandbox tunnel...',
      'Verifying account balance & credit lines...',
      'Authorizing subscription escrow settlement transaction...',
      'Encrypting card details via AES-GCM...',
      'Fulfilling KEE API workspace provisioning...'
    ];

    for (let i = 0; i < logs.length; i++) {
      setProcessingLog(logs[i]);
      await new Promise(r => setTimeout(r, 600));
    }

    try {
      await executeShopCreation(provisionDto);
      setPaymentProcessing(false);
      setPaymentSuccess(true);
    } catch (err) {
      setPaymentProcessing(false);
      alert(`Payment failed: ${err.message}`);
    }
  };

  const resetAddForm = () => {
    setShopName('');
    setAdminEmail('');
    setAdminName('');
    setAdminPassword('');
    setSubPlan('TRIAL');
    setSubEndDate('');
    setProvisionPhone('');
    setProvisionWhatsapp('');
    setProvisionLocation('');
    setProvisionSameAsPhone(false);
    setProvisionShopPhoto('');
    setProvisionShopLicense('');
    setProvisionOwnerAadhaar('');
    setErrorMsg('');
  };

  const toggleShopStatus = async (shop) => {
    try {
      await api.suspendShop(shop.id, !shop.isActive);
      fetchShops();
    } catch (e) {
      alert(e.message);
    }
  };

  const handleUpdateSubscriptionSubmit = async (e) => {
    e.preventDefault();
    try {
      await api.updateSubscription(selectedShop.id, {
        plan: newPlan,
        status: 'ACTIVE',
        startDate: new Date().toISOString(),
        endDate: new Date(newEndDate).toISOString()
      });
      setShowSubModal(false);
      fetchShops();
    } catch (e) {
      alert(e.message);
    }
  };

  const handleEditShopClick = (shop) => {
    setSelectedShop(shop);
    setEditName(shop.name);
    setEditThemeColor(shop.themeColor);
    setEditLogoUrl(shop.logoUrl || '');
    
    if (shop.companyDetails) {
      try {
        const details = JSON.parse(shop.companyDetails);
        setEditAddress(details.address || '');
        setEditGst(details.gst || '');
        setEditPhone(details.phone || '');
        setEditShopPhoto(details.shopPhoto || '');
        setEditShopLicense(details.shopLicense || '');
        setEditOwnerAadhaar(details.ownerAadhaar || '');
      } catch (err) {
        setEditAddress('');
        setEditGst('');
        setEditPhone('');
        setEditShopPhoto('');
        setEditShopLicense('');
        setEditOwnerAadhaar('');
      }
    } else {
      setEditAddress('');
      setEditGst('');
      setEditPhone('');
      setEditShopPhoto('');
      setEditShopLicense('');
      setEditOwnerAadhaar('');
    }
    setShowEditModal(true);
  };

  const handleEditShopSubmit = async (e) => {
    e.preventDefault();
    try {
      const companyDetails = JSON.stringify({
        address: editAddress,
        phone: editPhone,
        shopPhoto: editShopPhoto,
        shopLicense: editShopLicense,
        ownerAadhaar: editOwnerAadhaar
      });

      await api.updateShop(selectedShop.id, {
        name: editName,
        logoUrl: editLogoUrl,
        themeColor: editThemeColor,
        companyDetails
      });
      setShowEditModal(false);
      fetchShops();
    } catch (err) {
      alert(err.message || 'Update failed');
    }
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-extrabold tracking-tight">{t('shops')}</h1>
          <p className="text-sm text-gray-400 mt-1">Manage and provision key shops on the platform.</p>
        </div>
        <button 
          onClick={() => setShowAddModal(true)}
          className="glass-button-primary text-white text-xs font-semibold px-4 py-2.5 rounded-xl flex items-center gap-2"
        >
          <Plus className="h-4 w-4" />
          <span>Provision New Shop</span>
        </button>
      </div>

      {loading ? (
        <div className="flex h-64 items-center justify-center">
          <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
        </div>
      ) : (
        <div className="glass-panel rounded-2xl overflow-hidden shadow-xl">
          <table className="w-full text-left text-xs border-collapse">
            <thead>
              <tr className="bg-white/5 text-gray-400 border-b border-white/5 uppercase font-bold tracking-wider">
                <th className="p-4">Shop Details</th>
                <th className="p-4">Admin Contact</th>
                <th className="p-4">Active Plan</th>
                <th className="p-4">Valid Until</th>
                <th className="p-4">Disk Storage</th>
                <th className="p-4 text-center">Approval Status</th>
                <th className="p-4 text-center">Status</th>
                <th className="p-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-white/5 font-medium">
              {shops.map(s => (
                <tr key={s.id} className="hover:bg-white/2 transition">
                  <td className="p-4">
                    <div className="font-bold text-sm text-white">{s.name}</div>
                    <div className="text-[10px] text-gray-500 mt-0.5">ID: {s.id}</div>
                  </td>
                  <td className="p-4">
                    <div className="text-gray-200">{s.adminName}</div>
                    <div className="text-gray-400">{s.adminEmail}</div>
                  </td>
                  <td className="p-4">
                    <span className={`px-2 py-0.5 rounded font-bold ${s.plan === 'YEARLY' ? 'bg-purple-500/10 text-purple-400 border border-purple-500/20' : s.plan === 'MONTHLY' ? 'bg-blue-500/10 text-blue-400 border border-blue-500/20' : 'bg-amber-500/10 text-amber-400 border border-amber-500/20'}`}>
                      {s.plan}
                    </span>
                  </td>
                  <td className="p-4 text-gray-300">
                    {s.endDate ? new Date(s.endDate).toLocaleDateString() : 'N/A'}
                  </td>
                  <td className="p-4 text-gray-400">
                    {(Number(s.storageUsed || 0) / (1024 * 1024)).toFixed(2)} MB
                  </td>
                  <td className="p-4 text-center">
                    <span className={`px-2.5 py-1 rounded-full font-bold text-[10px] uppercase tracking-wider ${s.isApproved ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-amber-500/10 text-amber-400 border border-amber-500/20'}`}>
                      {s.isApproved ? 'Approved' : 'Pending'}
                    </span>
                  </td>
                  <td className="p-4 text-center">
                    <button 
                      onClick={() => toggleShopStatus(s)}
                      disabled={!s.isApproved}
                      className={`px-3 py-1 rounded-full font-bold text-[10px] uppercase tracking-wider disabled:opacity-50 disabled:cursor-not-allowed ${s.isActive ? 'bg-emerald-500/15 text-emerald-400 border border-emerald-500/20 hover:bg-emerald-500/25' : 'bg-red-500/15 text-red-400 border border-red-500/20 hover:bg-red-500/25'}`}
                    >
                      {s.isActive ? 'Active' : 'Suspended'}
                    </button>
                  </td>
                  <td className="p-4 text-right space-x-2">
                    {s.isApproved ? (
                      <button 
                        onClick={async () => {
                          if (confirm('Are you sure you want to unapprove this shop workspace?')) {
                            try {
                              await api.unapproveShop(s.id);
                              alert('Shop account unapproved successfully!');
                              fetchShops();
                            } catch (err) {
                              alert(err.message);
                            }
                          }
                        }}
                        className="bg-amber-600/35 hover:bg-amber-600/50 text-amber-300 px-2 py-1 rounded transition text-[10px] font-bold"
                      >
                        Unapprove Shop
                      </button>
                    ) : (
                      <button 
                        onClick={async () => {
                          try {
                            await api.approveShop(s.id);
                            alert('Shop account approved successfully!');
                            fetchShops();
                          } catch (err) {
                            alert(err.message);
                          }
                        }}
                        className="bg-emerald-600/35 hover:bg-emerald-600/50 text-emerald-300 px-2 py-1 rounded transition text-[10px] font-bold"
                      >
                        Approve Shop
                      </button>
                    )}
                    <button 
                      onClick={() => handleEditShopClick(s)}
                      className="bg-white/5 hover:bg-white/10 text-gray-300 px-2 py-1 rounded transition text-[10px]"
                    >
                      Edit Workspace
                    </button>
                    <button 
                      onClick={() => {
                        setSelectedShop(s);
                        setNewPlan(s.plan || 'MONTHLY');
                        setShowSubModal(true);
                      }}
                      className="bg-white/5 hover:bg-white/10 text-gray-300 px-2 py-1 rounded transition text-[10px]"
                    >
                      Plan
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {showAddModal && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/70 backdrop-blur-sm flex justify-center p-4 md:p-10">
          <div className="glass-panel w-full max-w-lg rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4">
            {/* Modal Header */}
            <div className="flex items-center justify-between border-b border-white/5 pb-3">
              <h2 className="text-base font-bold text-white uppercase tracking-wider flex items-center gap-2">
                <Layers className="h-5 w-5 text-primary-400" />
                <span>Provision New Shop Workspace</span>
              </h2>
              <button onClick={() => setShowAddModal(false)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            {errorMsg && (
              <div className="bg-red-950/50 border border-red-500/50 p-3 rounded-lg flex gap-2 text-xs text-red-200">
                <AlertTriangle className="h-4 w-4 shrink-0" />
                <span>{errorMsg}</span>
              </div>
            )}

            <form onSubmit={handleCreateShopSubmit} className="space-y-4">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Shop Name</label>
                  <input 
                    type="text" required value={shopName} onChange={(e) => setShopName(e.target.value)}
                    placeholder="e.g. Apex Duplicate Keys" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Admin Full Name</label>
                  <input 
                    type="text" required value={adminName} onChange={(e) => setAdminName(e.target.value)}
                    placeholder="e.g. Ramesh Kumar" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Admin Email</label>
                  <input 
                    type="email" required value={adminEmail} onChange={(e) => setAdminEmail(e.target.value)}
                    placeholder="e.g. admin@apexkeys.com" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Initial Password</label>
                  <input 
                    type="password" required value={adminPassword} onChange={(e) => setAdminPassword(e.target.value)}
                    placeholder="e.g. apexpassword123" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Phone Number</label>
                  <input 
                    type="tel" required value={provisionPhone} onChange={(e) => setProvisionPhone(e.target.value)}
                    placeholder="e.g. +91 99999 99999" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
                <div>
                  <div className="flex justify-between items-center mb-1.5">
                    <label className="block text-xs font-semibold text-gray-400 uppercase">WhatsApp Number</label>
                    <label className="flex items-center gap-1 cursor-pointer text-[10px] text-primary-400 font-bold select-none">
                      <input 
                        type="checkbox" checked={provisionSameAsPhone} 
                        onChange={(e) => {
                          setProvisionSameAsPhone(e.target.checked);
                          if (e.target.checked) setProvisionWhatsapp(provisionPhone);
                        }} 
                        className="rounded border-white/10 bg-white/5 text-primary-500 h-3.5 w-3.5" 
                      />
                      <span>Same as Phone</span>
                    </label>
                  </div>
                  <input 
                    type="tel" required value={provisionWhatsapp} onChange={(e) => setProvisionWhatsapp(e.target.value)}
                    disabled={provisionSameAsPhone} placeholder="WhatsApp Number" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white disabled:opacity-50"
                  />
                </div>
              </div>

              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Shop Address / Location</label>
                <input 
                  type="text" required value={provisionLocation} onChange={(e) => setProvisionLocation(e.target.value)}
                  placeholder="e.g. Metro Station Road, Sector 5" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                />
              </div>

              <div className="border-t border-white/5 pt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Subscription Plan</label>
                  <select 
                    value={subPlan} onChange={(e) => setSubPlan(e.target.value)}
                    className="w-full bg-[#1b1530] border border-white/10 text-xs px-3 py-2 rounded-lg text-gray-300 focus:outline-none font-bold"
                  >
                    <option value="TRIAL">Trial Plan (15 days) • Rs. {planPrices.TRIAL}</option>
                    <option value="MONTHLY">Monthly Plan • Rs. {planPrices.MONTHLY}/mo</option>
                    <option value="YEARLY">Yearly Plan • Rs. {planPrices.YEARLY}/yr</option>
                  </select>
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">End Date (Validity)</label>
                  <input 
                    type="date" required value={subEndDate} disabled
                    className="w-full bg-[#1b1530]/50 border border-white/10 text-xs px-3 py-2 rounded-lg text-gray-400 focus:outline-none cursor-not-allowed"
                  />
                  <span className="text-[9px] text-gray-500 mt-1 block">Auto-calculated based on selected tier</span>
                </div>
              </div>

              <div className="border-t border-white/5 pt-4 space-y-3">
                <label className="block text-xs font-semibold text-primary-300 uppercase tracking-wider">Upload Shop Documents</label>
                <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
                  <div>
                    <label className="block text-[10px] text-gray-400 font-semibold mb-1 uppercase">Shop Photo</label>
                    <input 
                      type="file" accept="image/*" required
                      onChange={(e) => {
                        const file = e.target.files[0];
                        if (file) {
                          const r = new FileReader();
                          r.onloadend = () => compressBase64Image(r.result, setProvisionShopPhoto);
                          r.readAsDataURL(file);
                        }
                      }}
                      className="w-full text-xs text-gray-400 file:mr-2 file:py-1.5 file:px-2.5 file:rounded-lg file:border-0 file:text-[10px] file:font-semibold file:bg-primary-600 file:text-white hover:file:bg-primary-500 cursor-pointer"
                    />
                  </div>
                  <div>
                    <label className="block text-[10px] text-gray-400 font-semibold mb-1 uppercase">Shop License</label>
                    <input 
                      type="file" accept="image/*,application/pdf" required
                      onChange={(e) => {
                        const file = e.target.files[0];
                        if (file) {
                          const r = new FileReader();
                          r.onloadend = () => compressBase64Image(r.result, setProvisionShopLicense);
                          r.readAsDataURL(file);
                        }
                      }}
                      className="w-full text-xs text-gray-400 file:mr-2 file:py-1.5 file:px-2.5 file:rounded-lg file:border-0 file:text-[10px] file:font-semibold file:bg-primary-600 file:text-white hover:file:bg-primary-500 cursor-pointer"
                    />
                  </div>
                  <div>
                    <label className="block text-[10px] text-gray-400 font-semibold mb-1 uppercase">Owner Aadhaar</label>
                    <input 
                      type="file" accept="image/*,application/pdf" required
                      onChange={(e) => {
                        const file = e.target.files[0];
                        if (file) {
                          const r = new FileReader();
                          r.onloadend = () => compressBase64Image(r.result, setProvisionOwnerAadhaar);
                          r.readAsDataURL(file);
                        }
                      }}
                      className="w-full text-xs text-gray-400 file:mr-2 file:py-1.5 file:px-2.5 file:rounded-lg file:border-0 file:text-[10px] file:font-semibold file:bg-primary-600 file:text-white hover:file:bg-primary-500 cursor-pointer"
                    />
                  </div>
                </div>
              </div>

              {/* Fixed Footer with CTA buttons */}
              <div className="border-t border-white/5 pt-4 flex justify-end gap-3">
                <button 
                  type="button" onClick={() => setShowAddModal(false)}
                  className="px-4 py-2 border border-white/10 rounded-lg text-xs text-gray-300 hover:bg-white/5"
                >
                  Cancel
                </button>
                <button 
                  type="submit"
                  className="glass-button-primary px-4 py-2 rounded-lg text-xs text-white font-semibold"
                >
                  Provision Account
                </button>
              </div>
            </form>
          </div>
        </div>,
        document.body
      )}

      {showEditModal && selectedShop && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/70 backdrop-blur-sm flex justify-center p-4 md:p-10">
          <div className="glass-panel w-full max-w-lg rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4">
            <div className="flex items-center justify-between border-b border-white/5 pb-3">
              <h2 className="text-base font-bold text-white uppercase tracking-wider flex items-center gap-2">
                <Edit className="h-5 w-5 text-primary-400" />
                <span>Edit Shop Workspace Details</span>
              </h2>
              <button onClick={() => setShowEditModal(false)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            <form onSubmit={handleEditShopSubmit} className="space-y-4">
              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Workspace Name</label>
                <input 
                  type="text" required value={editName} onChange={(e) => setEditName(e.target.value)}
                  className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                />
              </div>

              <div className="grid grid-cols-1 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Phone Number</label>
                  <input 
                    type="tel" required value={editPhone} onChange={(e) => setEditPhone(e.target.value)}
                    className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
              </div>

              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Registered Address (Fixed)</label>
                <input 
                  type="text" readOnly value={editAddress}
                  className="w-full bg-white/20 text-gray-400 border border-white/10 px-3 py-2 rounded-lg text-xs cursor-not-allowed font-medium"
                />
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-white/5 pt-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Logo URL</label>
                  <input 
                    type="text" value={editLogoUrl} onChange={(e) => setEditLogoUrl(e.target.value)}
                    className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Theme Color</label>
                  <div className="flex gap-2 items-center">
                    <input 
                      type="color" value={editThemeColor} onChange={(e) => setEditThemeColor(e.target.value)}
                      className="bg-transparent border border-white/10 w-10 h-10 p-0.5 rounded cursor-pointer"
                    />
                    <span className="text-xs uppercase text-gray-300 font-bold">{editThemeColor}</span>
                  </div>
                </div>
              </div>

              <div className="border-t border-white/5 pt-4 space-y-3">
                <label className="block text-xs font-semibold text-primary-300 uppercase tracking-wider">Verification Documents Review</label>
                <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
                  {/* Shop Photo */}
                  <div className="bg-white/2 border border-white/5 p-2 rounded-xl flex flex-col justify-between space-y-2">
                    <div>
                      <span className="text-[9px] text-gray-400 block font-semibold uppercase">Shop Photo</span>
                      {editShopPhoto ? (
                        <div className="mt-1 h-12 w-full rounded overflow-hidden border border-white/10 bg-black">
                          <img src={editShopPhoto} className="w-full h-full object-cover" alt="Shop Photo Preview" />
                        </div>
                      ) : (
                        <span className="text-[9px] text-gray-500 italic block mt-1">Not Uploaded</span>
                      )}
                    </div>
                    {editShopPhoto && (
                      <a 
                        href={editShopPhoto} 
                        download="shop_photo.png" 
                        className="bg-primary-600 hover:bg-primary-500 text-white text-[8px] font-bold py-1 rounded transition text-center block w-full"
                      >
                        Download
                      </a>
                    )}
                  </div>

                  {/* Shop License */}
                  <div className="bg-white/2 border border-white/5 p-2 rounded-xl flex flex-col justify-between space-y-2">
                    <div>
                      <span className="text-[9px] text-gray-400 block font-semibold uppercase">Shop License</span>
                      {editShopLicense ? (
                        <div className="mt-1 h-12 w-full rounded overflow-hidden border border-white/10 bg-black flex items-center justify-center">
                          {editShopLicense.startsWith('data:application/pdf') ? (
                            <span className="text-[8px] text-red-400 font-bold font-mono">📄 PDF</span>
                          ) : (
                            <img src={editShopLicense} className="w-full h-full object-cover" alt="License Preview" />
                          )}
                        </div>
                      ) : (
                        <span className="text-[9px] text-gray-500 italic block mt-1">Not Uploaded</span>
                      )}
                    </div>
                    {editShopLicense && (
                      <a 
                        href={editShopLicense} 
                        download="shop_license.pdf" 
                        className="bg-primary-600 hover:bg-primary-500 text-white text-[8px] font-bold py-1 rounded transition text-center block w-full"
                      >
                        Download
                      </a>
                    )}
                  </div>

                  {/* Owner Aadhaar */}
                  <div className="bg-[#120e24]/60 border border-white/5 p-2 rounded-xl flex flex-col justify-between space-y-2">
                    <div>
                      <span className="text-[9px] text-gray-400 block font-semibold uppercase">Owner Aadhaar</span>
                      {editOwnerAadhaar ? (
                        <div className="mt-1 h-12 w-full rounded overflow-hidden border border-white/10 bg-black flex items-center justify-center">
                          {editOwnerAadhaar.startsWith('data:application/pdf') ? (
                            <span className="text-[8px] text-red-400 font-bold font-mono">📄 Aadhaar PDF</span>
                          ) : (
                            <img src={editOwnerAadhaar} className="w-full h-full object-cover" alt="Aadhaar Preview" />
                          )}
                        </div>
                      ) : (
                        <span className="text-[9px] text-gray-500 italic block mt-1">Not Uploaded</span>
                      )}
                    </div>
                    {editOwnerAadhaar && (
                      <a 
                        href={editOwnerAadhaar} 
                        download="owner_aadhaar.pdf" 
                        className="bg-primary-600 hover:bg-primary-500 text-white text-[8px] font-bold py-1 rounded transition text-center block w-full"
                      >
                        Download
                      </a>
                    )}
                  </div>
                </div>
              </div>

              <div className="border-t border-white/5 pt-4 flex justify-end gap-3">
                <button 
                  type="button" onClick={() => setShowEditModal(false)}
                  className="px-4 py-2 border border-white/10 rounded-lg text-xs text-gray-300 hover:bg-white/5"
                >
                  Cancel
                </button>
                <button 
                  type="submit"
                  className="glass-button-primary px-4 py-2 rounded-lg text-xs text-white font-semibold"
                >
                  Save Settings
                </button>
              </div>
            </form>
          </div>
        </div>,
        document.body
      )}

      {/* Subscription Update Modal */}
      {showSubModal && selectedShop && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/60 backdrop-blur-sm flex justify-center p-4 md:p-10">
          <div className="glass-panel w-full max-w-md rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4">
            <div className="flex items-center justify-between border-b border-white/5 pb-3">
              <h2 className="text-base font-bold text-white uppercase tracking-wider">Update Shop Subscription</h2>
              <button onClick={() => setShowSubModal(false)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            <div className="text-xs text-gray-400 bg-white/2 p-3 rounded-lg border border-white/5">
              Target shop: <span className="font-bold text-primary-400">{selectedShop.name}</span>
            </div>

             <form onSubmit={handleUpdateSubscriptionSubmit} className="space-y-4">
              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Plan Tier</label>
                <select 
                  value={newPlan} onChange={(e) => setNewPlan(e.target.value)}
                  className="w-full bg-[#1b1530] border border-white/10 text-xs px-3 py-2 rounded-lg text-gray-300 focus:outline-none font-bold"
                >
                  <option value="TRIAL">Trial Plan • Rs. {planPrices.TRIAL}</option>
                  <option value="MONTHLY">Monthly Plan • Rs. {planPrices.MONTHLY}/mo</option>
                  <option value="YEARLY">Yearly Plan • Rs. {planPrices.YEARLY}/yr</option>
                </select>
              </div>

              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">New End Date</label>
                <input 
                  type="date" required value={newEndDate} disabled
                  className="w-full bg-[#1b1530]/50 border border-white/10 text-xs px-3 py-2 rounded-lg text-gray-400 focus:outline-none cursor-not-allowed"
                />
                <span className="text-[9px] text-gray-500 mt-1 block">Auto-calculated based on selected tier</span>
              </div>

              <div className="border-t border-white/5 pt-4 flex justify-end gap-3">
                <button 
                  type="button" onClick={() => setShowSubModal(false)}
                  className="px-4 py-2 border border-white/10 rounded-lg text-xs text-gray-300 hover:bg-white/5"
                >
                  Cancel
                </button>
                <button 
                  type="submit"
                  className="glass-button-primary px-4 py-2 rounded-lg text-xs text-white font-semibold"
                >
                  Update Plan
                </button>
              </div>
            </form>
          </div>
        </div>,
        document.body
      )}

      {showPaymentProvisionModal && provisionDto && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/85 backdrop-blur-sm flex justify-center p-4 md:p-10 animate-fade-in">
          <div className="glass-panel w-full max-w-lg rounded-2xl shadow-2xl border border-white/10 my-auto bg-[#100c25] overflow-hidden flex flex-col">
            {/* Header */}
            <div className="flex items-center justify-between border-b border-white/5 p-5 bg-white/2">
              <div className="flex items-center gap-2">
                <ShieldCheck className="h-5 w-5 text-emerald-400" />
                <div>
                  <h2 className="text-sm font-bold text-white uppercase tracking-wider">Plan Subscription Escrow Pay</h2>
                  <p className="text-[10px] text-gray-400">Workspace Terminal Provisioning Payment</p>
                </div>
              </div>
              {!paymentProcessing && !paymentSuccess && (
                <button onClick={() => setShowPaymentProvisionModal(false)} className="text-gray-400 hover:text-white">
                  <X className="h-5 w-5" />
                </button>
              )}
            </div>

            {/* Success State */}
            {paymentSuccess ? (
              <div className="p-8 text-center flex flex-col items-center justify-center space-y-6">
                <div className="w-16 h-16 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-full flex items-center justify-center animate-bounce">
                  <Check className="h-8 w-8" />
                </div>
                <div className="space-y-2">
                  <h3 className="text-lg font-bold text-white">Payment Authorized!</h3>
                  <p className="text-xs text-gray-400 max-w-xs mx-auto">
                    The subscription payment has settled successfully. Workspace <strong>{provisionDto.name}</strong> is now fully provisioned and activated.
                  </p>
                </div>
                <button 
                  onClick={() => {
                    setShowPaymentProvisionModal(false);
                  }}
                  className="w-full glass-button-primary py-2.5 rounded-xl font-bold text-xs text-white"
                >
                  Close & Proceed
                </button>
              </div>
            ) : paymentProcessing ? (
              /* Processing State */
              <div className="p-10 text-center flex flex-col items-center justify-center space-y-6">
                <div className="w-12 h-12 border-4 border-t-primary-500 border-white/10 rounded-full animate-spin"></div>
                <div className="space-y-2">
                  <h3 className="text-sm font-bold text-white uppercase tracking-wider">Processing Transaction</h3>
                  <p className="text-xs text-gray-400">Finalizing workspace creation tunnels.</p>
                </div>
                <div className="w-full bg-white/2 p-3 rounded-lg border border-white/5 text-[10px] text-gray-400 font-mono text-center min-h-[40px] flex items-center justify-center">
                  <span className="text-primary-400">{processingLog}</span>
                </div>
              </div>
            ) : (
              /* Main Checkout Form */
              <form onSubmit={executePaymentProvision} className="p-6 space-y-5">
                {/* Invoice Summary */}
                <div className="flex justify-between items-center bg-white/2 border border-white/5 p-4 rounded-xl">
                  <div>
                    <span className="text-[10px] text-gray-400 uppercase block font-semibold">Workspace Provision Invoice</span>
                    <span className="text-xs text-gray-300">Plan: <span className="font-extrabold text-primary-300">{provisionDto.plan}</span></span>
                  </div>
                  <span className="text-xl font-extrabold text-emerald-400">Rs. {planPrices[provisionDto.plan]}</span>
                </div>

                {/* Tab Selector */}
                <div className="grid grid-cols-2 gap-2 bg-white/2 p-1 rounded-xl border border-white/5">
                  <button
                    type="button"
                    onClick={() => setPaymentMethod('card')}
                    className={`py-2 rounded-lg text-[10px] font-bold uppercase flex flex-col items-center gap-1.5 transition ${paymentMethod === 'card' ? 'bg-primary-600 text-white shadow' : 'text-gray-400 hover:text-white'}`}
                  >
                    <CreditCard className="h-4 w-4" />
                    <span>Credit Card</span>
                  </button>
                  <button
                    type="button"
                    onClick={() => setPaymentMethod('upi')}
                    className={`py-2 rounded-lg text-[10px] font-bold uppercase flex flex-col items-center gap-1.5 transition ${paymentMethod === 'upi' ? 'bg-primary-600 text-white shadow' : 'text-gray-400 hover:text-white'}`}
                  >
                    <QrCode className="h-4 w-4" />
                    <span>UPI QR Code</span>
                  </button>
                </div>

                {paymentMethod === 'card' ? (
                  <div className="space-y-4">
                    <div>
                      <label className="block text-[9px] font-semibold text-gray-400 uppercase mb-1.5">Cardholder Full Name</label>
                      <input 
                        type="text" required value={cardHolder} onChange={(e) => setCardHolder(e.target.value)}
                        placeholder="e.g. Ramesh Kumar" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                      />
                    </div>
                    <div>
                      <label className="block text-[9px] font-semibold text-gray-400 uppercase mb-1.5">Debit / Credit Card Number</label>
                      <div className="relative">
                        <input 
                          type="text" required value={cardNumber} 
                          onChange={(e) => {
                            let val = e.target.value.replace(/\D/g, '').substring(0, 16);
                            const parts = val.match(/.{1,4}/g) || [];
                            setCardNumber(parts.join(' '));
                          }}
                          placeholder="4111 2222 3333 4444" className="w-full glass-input pl-10 pr-3 py-2 rounded-lg text-xs text-white"
                        />
                        <CreditCard className="h-4 w-4 text-gray-500 absolute left-3 top-2.5" />
                      </div>
                    </div>
                    <div className="grid grid-cols-2 gap-4">
                      <div>
                        <label className="block text-[9px] font-semibold text-gray-400 uppercase mb-1.5">Expiry Date</label>
                        <input 
                          type="text" required value={cardExpiry} 
                          onChange={(e) => {
                            let val = e.target.value.replace(/\D/g, '');
                            if (val.length > 2) {
                              setCardExpiry(val.substring(0, 2) + '/' + val.substring(2, 4));
                            } else {
                              setCardExpiry(val);
                            }
                          }}
                          placeholder="MM/YY" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                        />
                      </div>
                      <div>
                        <label className="block text-[9px] font-semibold text-gray-400 uppercase mb-1.5">CVV Code</label>
                        <input 
                          type="password" required value={cardCvv} onChange={(e) => setCardCvv(e.target.value.substring(0, 3))}
                          placeholder="•••" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                        />
                      </div>
                    </div>
                  </div>
                ) : (
                  <div className="flex flex-col items-center text-center space-y-4 py-3">
                    <div className="bg-white p-3 rounded-2xl shadow-xl relative overflow-hidden flex items-center justify-center w-40 h-40">
                      <div className="absolute inset-0 bg-primary-600/5 animate-pulse"></div>
                      <img 
                        src={`https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://kee.platform/subscribe?amount=${planPrices[provisionDto.plan]}`}
                        alt="Pay QR code"
                        className="w-full h-full object-contain"
                      />
                    </div>
                    <div className="space-y-1">
                      <p className="text-xs text-gray-200 font-bold">Scan to Authorize Setup Invoice</p>
                      <p className="text-[10px] text-gray-400 max-w-[240px]">
                        Scan with GPay, PhonePe, Paytm, or BHIM. Subscription activates automatically post-detection.
                      </p>
                    </div>
                  </div>
                )}

                {/* Footer buttons */}
                <div className="border-t border-white/5 pt-4 space-y-3">
                  <div className="flex items-center gap-1.5 text-[10px] text-gray-400 justify-center">
                    <Lock className="h-3 w-3 text-emerald-400" />
                    <span>256-bit Secure Gateway Payment Portal</span>
                  </div>

                  <div className="flex gap-3 pt-1">
                    <button 
                      type="button"
                      onClick={() => setShowPaymentProvisionModal(false)}
                      className="w-1/2 py-2.5 border border-white/10 rounded-xl text-xs text-gray-300 hover:bg-white/5 transition"
                    >
                      Cancel Setup
                    </button>
                    <button 
                      type="submit"
                      className="w-1/2 glass-button-primary text-white py-2.5 rounded-xl font-bold text-xs"
                    >
                      Pay Rs. {planPrices[provisionDto.plan]} & Provision
                    </button>
                  </div>
                </div>
              </form>
            )}
          </div>
        </div>,
        document.body
      )}
    </div>
  );
}

// ============================================================================
// COMPONENT 3: SUPER CUSTOMER SUPERVISION VIEW (SUPER ADMIN ONLY)
// ============================================================================
function SuperCustomersView({ api }) {
  const [customers, setCustomers] = useState([]);
  const [loading, setLoading] = useState(false);
  const [search, setSearch] = useState('');
  const [selectedCust, setSelectedCust] = useState(null);
  const [viewCust, setViewCust] = useState(null);
  const [showEditDrawer, setShowEditDrawer] = useState(false);

  // Edit Customer states
  const [editName, setEditName] = useState('');
  const [editPhone, setEditPhone] = useState('');
  const [editAddress, setEditAddress] = useState('');
  const [editProofType, setEditProofType] = useState('');
  const [editProofNo, setEditProofNo] = useState('');
  const [editReason, setEditReason] = useState('');
  const [editKeyNo, setEditKeyNo] = useState('');

  useEffect(() => {
    fetchCustomers();
  }, [search]);

  const fetchCustomers = async () => {
    setLoading(true);
    try {
      const res = await api.getSuperCustomers(search);
      setCustomers(res);
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  const handleEditClick = (c) => {
    setSelectedCust(c);
    setEditName(c.name);
    setEditPhone(c.phone);
    setEditAddress(c.address);
    setEditProofType(c.idProofType);
    setEditProofNo(c.idProofNumber || '');
    setEditReason(c.reason);
    setEditKeyNo(c.keyNumber);
    setShowEditDrawer(true);
  };

  const handleUpdateSubmit = async (e) => {
    e.preventDefault();
    try {
      await api.updateSuperCustomer(selectedCust.id, {
        name: editName,
        phone: editPhone,
        address: editAddress,
        idProofType: editProofType,
        idProofNumber: editProofNo,
        reason: editReason,
        keyNumber: editKeyNo
      });
      setShowEditDrawer(false);
      setSelectedCust(null);
      fetchCustomers();
    } catch (err) {
      alert(err.message || 'Update failed');
    }
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div>
        <h1 className="text-2xl font-extrabold tracking-tight">Compliance Supervised Customer Registry</h1>
        <p className="text-sm text-gray-400 mt-1">Cross-tenant monitoring. View and modify compliance logs across all shops.</p>
      </div>

      <div className="glass-panel p-4 rounded-2xl flex items-center gap-3">
        <Search className="h-5 w-5 text-primary-400 shrink-0" />
        <input 
          type="text" value={search} onChange={(e) => setSearch(e.target.value)}
          placeholder="Search customers platform-wide by name, phone, or matching key number..."
          className="w-full bg-transparent border-none outline-none text-sm placeholder:text-gray-500 text-white"
        />
      </div>

      {loading ? (
        <div className="flex h-48 items-center justify-center">
          <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
        </div>
      ) : (
        <div className="glass-panel rounded-2xl overflow-hidden shadow-xl border border-white/5">
          <table className="w-full text-left text-xs border-collapse">
            <thead>
              <tr className="bg-white/5 text-gray-400 border-b border-white/5 uppercase font-bold tracking-wider">
                <th className="p-4">Tenant Workspace</th>
                <th className="p-4">Customer Name</th>
                <th className="p-4">Phone Number</th>
                <th className="p-4">Key Blank Code</th>
                <th className="p-4">Registry Timestamp</th>
                <th className="p-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-white/5 font-medium text-gray-200">
              {customers.map(c => (
                <tr key={c.id} className="hover:bg-white/2 transition">
                  <td className="p-4">
                    <span className="font-bold text-primary-400">{c.shop ? c.shop.name : 'Shop Workspace'}</span>
                  </td>
                  <td className="p-4 font-semibold text-white">{c.name}</td>
                  <td className="p-4">{c.phone}</td>
                  <td className="p-4">{c.keyNumber}</td>
                  <td className="p-4 text-gray-400">{new Date(c.createdAt).toLocaleDateString()} {new Date(c.createdAt).toLocaleTimeString()}</td>
                  <td className="p-4 text-right space-x-2">
                    <button 
                      onClick={() => setViewCust(c)}
                      className="bg-primary-600/20 hover:bg-primary-600/35 border border-primary-500/30 text-primary-300 px-2.5 py-1 rounded transition text-[10px] uppercase font-bold"
                    >
                      View details
                    </button>
                    <button 
                      onClick={() => handleEditClick(c)}
                      className="bg-white/5 hover:bg-white/10 text-gray-300 px-2.5 py-1 rounded transition text-[10px] uppercase font-bold"
                    >
                      Modify file
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {/* Edit Customer Profile drawer */}
      {showEditDrawer && selectedCust && createPortal(
        <div className="fixed inset-0 z-50 flex items-center justify-end bg-black/60 backdrop-blur-sm">
          <div className="glass-panel w-full max-w-md h-full p-6 shadow-2xl border-l border-white/10 flex flex-col animate-fade-in bg-[#100c25]">
            <div className="flex items-center justify-between border-b border-white/5 pb-4 mb-4">
              <h2 className="text-base font-bold text-white uppercase tracking-wider flex items-center gap-2">
                <Edit className="h-5 w-5 text-primary-400" />
                <span>Modify customer files</span>
              </h2>
              <button onClick={() => setShowEditDrawer(false)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            <form onSubmit={handleUpdateSubmit} className="flex-1 overflow-y-auto space-y-4 pr-1">
              <div>
                <label className="block text-[10px] font-bold text-gray-400 mb-1.5 uppercase">Full Customer Name</label>
                <input 
                  type="text" required value={editName} onChange={(e) => setEditName(e.target.value)}
                  className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white"
                />
              </div>

              <div>
                <label className="block text-[10px] font-bold text-gray-400 mb-1.5 uppercase">Phone Number</label>
                <input 
                  type="tel" required value={editPhone} onChange={(e) => setEditPhone(e.target.value)}
                  className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white"
                />
              </div>

              <div>
                <label className="block text-[10px] font-bold text-gray-400 mb-1.5 uppercase">Registered Address</label>
                <input 
                  type="text" required value={editAddress} onChange={(e) => setEditAddress(e.target.value)}
                  className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white"
                />
              </div>

              <div className="grid grid-cols-2 gap-4">
                <div>
                  <label className="block text-[10px] font-bold text-gray-400 mb-1.5 uppercase">ID Type</label>
                  <input 
                    type="text" required value={editProofType} onChange={(e) => setEditProofType(e.target.value)}
                    className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white"
                  />
                </div>
                <div>
                  <label className="block text-[10px] font-bold text-gray-400 mb-1.5 uppercase">ID Proof Number</label>
                  <input 
                    type="text" required value={editProofNo} onChange={(e) => setEditProofNo(e.target.value)}
                    className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white"
                  />
                </div>
              </div>

              <div>
                <label className="block text-[10px] font-bold text-gray-400 mb-1.5 uppercase">Reason for duplicate key</label>
                <input 
                  type="text" required value={editReason} onChange={(e) => setEditReason(e.target.value)}
                  className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white"
                />
              </div>

              <div>
                <label className="block text-[10px] font-bold text-gray-400 mb-1.5 uppercase">Cut Key Code</label>
                <input 
                  type="text" required value={editKeyNo} onChange={(e) => setEditKeyNo(e.target.value)}
                  className="w-full glass-input px-3 py-2 rounded-xl text-xs text-white"
                />
              </div>

              <div className="border-t border-white/5 pt-4 flex gap-3">
                <button 
                  type="button" onClick={() => setShowEditDrawer(false)}
                  className="w-1/2 px-4 py-2.5 border border-white/10 rounded-xl text-xs text-gray-300 hover:bg-white/5"
                >
                  Cancel
                </button>
                <button 
                  type="submit"
                  className="w-1/2 glass-button-primary text-white py-2.5 rounded-xl font-semibold text-xs"
                >
                  Save file edits
                </button>
              </div>
            </form>
          </div>
        </div>,
        document.body
      )}

      {viewCust && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/60 backdrop-blur-sm flex justify-center p-4 md:p-10">
          <div className="glass-panel w-full max-w-lg rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4 bg-[#100c25]">
            <div className="flex items-center justify-between border-b border-white/5 pb-3">
              <h2 className="text-base font-bold text-white uppercase tracking-wider flex items-center gap-2">
                <FileText className="h-5 w-5 text-primary-400" />
                <span>Compliance File: {viewCust.name}</span>
              </h2>
              <button onClick={() => setViewCust(null)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            <div className="grid grid-cols-2 gap-4 text-xs font-semibold text-gray-300">
              <div>
                <span className="text-[10px] text-gray-500 block">Phone Contact</span>
                <span className="text-white">{viewCust.phone}</span>
              </div>
              <div>
                <span className="text-[10px] text-gray-500 block">Registry Date</span>
                <span className="text-white">{new Date(viewCust.createdAt).toLocaleString()}</span>
              </div>
              <div>
                <span className="text-[10px] text-gray-500 block">Address</span>
                <span className="text-white block truncate">{viewCust.address}</span>
              </div>
              <div>
                <span className="text-[10px] text-gray-500 block">Key Blank Code</span>
                <span className="text-white">{viewCust.keyNumber}</span>
              </div>
            </div>

            <div className="grid grid-cols-2 gap-4 border-t border-white/5 pt-4 text-xs font-semibold text-gray-300">
              <div>
                <span className="text-[10px] text-gray-500 block">ID Verification</span>
                <span className="text-white">{viewCust.idProofType}</span>
              </div>
              <div>
                <span className="text-[10px] text-gray-500 block">ID Number (Decrypted)</span>
                <span className="text-primary-300">{viewCust.idProofNumber}</span>
              </div>
            </div>

            <div className="bg-[#140f29] border border-white/5 p-3 rounded-xl space-y-2 mt-2 text-xs text-white">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-2">
                  <MapPin className="h-5 w-5 text-emerald-400 shrink-0" />
                  <div>
                    <p className="font-bold text-gray-200">GPS Coordinates</p>
                    <p className="text-[10px] text-gray-500 mt-0.5">Lat: {viewCust.latitude} • Long: {viewCust.longitude}</p>
                  </div>
                </div>
                <a href={viewCust.mapsLink} target="_blank" rel="noopener noreferrer" className="text-[10px] text-primary-400 font-bold hover:underline flex items-center gap-1">
                  <span>Google Maps</span><ExternalLink className="h-3 w-3" />
                </a>
              </div>
              {viewCust.capturedAddress && (
                <div className="text-[10px] text-gray-400 border-t border-white/5 pt-1.5 pl-7">
                  <span className="block font-semibold text-[8px] text-gray-500 uppercase">Captured Address</span>
                  <span>{viewCust.capturedAddress}</span>
                </div>
              )}
            </div>

            <div className="grid grid-cols-2 gap-4 border-t border-white/5 pt-4">
              <div>
                <span className="text-[10px] text-gray-500 uppercase block mb-1">Webcam Photo</span>
                {viewCust.photoUrl ? (
                  <div className="w-full h-32 rounded-lg bg-white/2 overflow-hidden border border-white/5">
                    <img src={viewCust.photoUrl} alt="Customer snapshot" className="w-full h-full object-cover" />
                  </div>
                ) : (
                  <div className="w-full h-32 rounded-lg border border-dashed border-white/10 flex items-center justify-center text-xs text-gray-500">No snapshot</div>
                )}
              </div>
              <div>
                <span className="text-[10px] text-gray-500 uppercase block mb-1">Customer Signature</span>
                {viewCust.signatureUrl ? (
                  <div className="w-full h-32 rounded-lg bg-white/5 border border-white/5 p-3 flex items-center justify-center">
                    <img src={viewCust.signatureUrl} alt="Signature drawing" className="max-h-full max-w-full object-contain" />
                  </div>
                ) : (
                  <div className="w-full h-32 rounded-lg border border-dashed border-white/10 flex items-center justify-center text-xs text-gray-500">No signature</div>
                )}
              </div>
            </div>

            {viewCust.documents && viewCust.documents.length > 0 && (
              <div className="border-t border-white/5 pt-4 space-y-2">
                <span className="text-[10px] text-gray-500 uppercase block font-semibold">Attached ID Copies</span>
                {viewCust.documents.map(d => (
                  <div key={d.id} className="bg-white/2 border border-white/5 p-2 rounded-xl flex items-center justify-between text-xs text-white">
                    <span>{d.documentType} ({d.fileKey})</span>
                    <a href={d.fileUrl} target="_blank" rel="noopener noreferrer" className="text-[10px] font-bold text-primary-400 hover:underline">Download</a>
                  </div>
                ))}
              </div>
            )}

            <div className="border-t border-white/5 pt-4 flex justify-end">
              <button onClick={() => setViewCust(null)} className="px-4 py-2 border border-white/10 rounded-lg text-xs text-gray-300 hover:bg-white/5">Close File</button>
            </div>
          </div>
        </div>,
        document.body
      )}
    </div>
  );
}

// ============================================================================
// COMPONENT 4: MASTER KEY DATABASE CRUD (SUPER ADMIN ONLY)
// ============================================================================
function KeysCatalogView({ api }) {
  const [keys, setKeys] = useState([]);
  const [loading, setLoading] = useState(true);
  const [showAddModal, setShowAddModal] = useState(false);
  const [editKey, setEditKey] = useState(null);
  const [searchQuery, setSearchQuery] = useState('');

  // Form states
  const [keyNumber, setKeyNumber] = useState('');
  const [brand, setBrand] = useState('');
  const [category, setCategory] = useState('');
  const [blankNumber, setBlankNumber] = useState('');
  const [frontImageUrl, setFrontImageUrl] = useState('');
  const [backImageUrl, setBackImageUrl] = useState('');
  const [description, setDescription] = useState('');
  const [notes, setNotes] = useState('');
  const [status, setStatus] = useState('ACTIVE');
  const [errorMsg, setErrorMsg] = useState('');

  useEffect(() => {
    fetchKeys();
  }, []);

  const fetchKeys = async () => {
    setLoading(true);
    try {
      const res = await api.getMasterKeys();
      setKeys(res);
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    setErrorMsg('');
    try {
      const dto = {
        keyNumber, brand, category, blankNumber,
        frontImageUrl, backImageUrl, description, notes, status
      };

      if (editKey) {
        await api.updateMasterKey(editKey.id, dto);
      } else {
        await api.createMasterKey(dto);
      }
      setShowAddModal(false);
      resetForm();
      fetchKeys();
    } catch (err) {
      setErrorMsg(err.message || 'Operation failed');
    }
  };

  const handleEditClick = (k) => {
    setEditKey(k);
    setKeyNumber(k.keyNumber);
    setBrand(k.brand);
    setCategory(k.category);
    setBlankNumber(k.blankNumber);
    setFrontImageUrl(k.frontImageUrl || '');
    setBackImageUrl(k.backImageUrl || '');
    setDescription(k.description || '');
    setNotes(k.notes || '');
    setStatus(k.status);
    setShowAddModal(true);
  };

  const handleDelete = async (id) => {
    if (!confirm('Are you sure you want to remove this key blank from the central catalogue?')) return;
    try {
      await api.deleteMasterKey(id);
      fetchKeys();
    } catch (e) {
      alert(e.message);
    }
  };

  const resetForm = () => {
    setEditKey(null);
    setKeyNumber('');
    setBrand('');
    setCategory('');
    setBlankNumber('');
    setFrontImageUrl('');
    setBackImageUrl('');
    setDescription('');
    setNotes('');
    setStatus('ACTIVE');
    setErrorMsg('');
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-extrabold tracking-tight">Master Key Catalogue</h1>
          <p className="text-sm text-gray-400 mt-1">Provision key blanks available to shop terminals.</p>
        </div>
        <button 
          onClick={() => { resetForm(); setShowAddModal(true); }}
          className="glass-button-primary text-white text-xs font-semibold px-4 py-2.5 rounded-xl flex items-center gap-2"
        >
          <Plus className="h-4 w-4" />
          <span>Add Key Blank</span>
        </button>
      </div>

      {/* Central catalog lookup search input */}
      <div className="glass-panel p-4 rounded-2xl flex items-center gap-3">
        <Search className="h-5 w-5 text-primary-400 shrink-0" />
        <input 
          type="text" value={searchQuery} onChange={(e) => setSearchQuery(e.target.value)}
          placeholder="Search catalogue by code, category, brand name, specs reference..."
          className="w-full bg-transparent border-none outline-none text-sm placeholder:text-gray-500 text-white"
        />
        {searchQuery && (
          <button onClick={() => setSearchQuery('')} className="text-gray-400 hover:text-white">
            <X className="h-4 w-4" />
          </button>
        )}
      </div>

      {loading ? (
        <div className="flex h-64 items-center justify-center">
          <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
        </div>
      ) : (() => {
        const filteredKeys = keys.filter(k => 
          (k.keyNumber || '').toLowerCase().includes(searchQuery.toLowerCase()) ||
          (k.brand || '').toLowerCase().includes(searchQuery.toLowerCase()) ||
          (k.category || '').toLowerCase().includes(searchQuery.toLowerCase()) ||
          (k.blankNumber || '').toLowerCase().includes(searchQuery.toLowerCase()) ||
          (k.description || '').toLowerCase().includes(searchQuery.toLowerCase())
        );

        return (
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
            {filteredKeys.map(k => (
              <div key={k.id} className="glass-panel p-5 rounded-2xl flex flex-col justify-between space-y-4">
              <div className="space-y-2">
                <div className="flex items-center justify-between">
                  <span className="text-xs font-bold bg-primary-600/10 text-primary-300 border border-primary-500/20 px-2 py-0.5 rounded uppercase">
                    {k.category}
                  </span>
                  <span className={`text-[10px] font-bold px-2 py-0.5 rounded-full ${k.status === 'ACTIVE' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-red-500/10 text-red-400'}`}>
                    {k.status}
                  </span>
                </div>
                <div className="flex gap-4">
                  {k.frontImageUrl && (
                    <img 
                      src={k.frontImageUrl} 
                      alt="Key blank profile"
                      className="w-16 h-16 object-cover rounded-lg border border-white/5 shadow"
                    />
                  )}
                  <div>
                    <h3 className="text-base font-bold text-white">{k.keyNumber}</h3>
                    <p className="text-xs text-gray-400">{k.brand} • Blank: {k.blankNumber}</p>
                  </div>
                </div>
                {k.description && <p className="text-xs text-gray-400 mt-2 italic">"{k.description}"</p>}
              </div>

              <div className="flex justify-end gap-2 border-t border-white/5 pt-3">
                <button 
                  onClick={() => handleEditClick(k)}
                  className="bg-white/5 hover:bg-white/10 text-gray-300 px-2.5 py-1.5 rounded-lg text-xs font-medium transition flex items-center gap-1.5"
                >
                  <Edit className="h-3.5 w-3.5" />
                  <span>Modify</span>
                </button>
                <button 
                  onClick={() => handleDelete(k.id)}
                  className="bg-red-950/20 hover:bg-red-500/15 text-red-400 px-2.5 py-1.5 rounded-lg text-xs font-medium transition flex items-center gap-1.5"
                >
                  <Trash className="h-3.5 w-3.5" />
                  <span>Delete</span>
                </button>
              </div>
            </div>
            ))}
          </div>
        );
      })()}

      {/* Add / Edit Key Modal */}
      {showAddModal && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/70 backdrop-blur-sm flex justify-center p-4 md:p-10">
          <div className="glass-panel w-full max-w-lg rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4">
            <div className="flex items-center justify-between border-b border-white/5 pb-3">
              <h2 className="text-base font-bold text-white uppercase tracking-wider flex items-center gap-2">
                <Key className="h-5 w-5 text-primary-400" />
                <span>{editKey ? 'Modify Key Blank' : 'Add New Key Blank'}</span>
              </h2>
              <button onClick={() => setShowAddModal(false)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            {errorMsg && (
              <div className="bg-red-950/50 border border-red-500/50 p-3 rounded-lg flex gap-2 text-xs text-red-200">
                <AlertTriangle className="h-4 w-4 shrink-0" />
                <span>{errorMsg}</span>
              </div>
            )}

            <form onSubmit={handleSubmit} className="space-y-4">
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Key Code</label>
                  <input 
                    type="text" required value={keyNumber} onChange={(e) => setKeyNumber(e.target.value)}
                    placeholder="e.g. CY-102" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Brand Manufacturer</label>
                  <input 
                    type="text" required value={brand} onChange={(e) => setBrand(e.target.value)}
                    placeholder="e.g. Godrej" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Blank Number Reference</label>
                  <input 
                    type="text" required value={blankNumber} onChange={(e) => setBlankNumber(e.target.value)}
                    placeholder="e.g. GD-901" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Category Type</label>
                  <input 
                    type="text" required value={category} onChange={(e) => setCategory(e.target.value)}
                    placeholder="e.g. Padlock" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Front Image URL</label>
                  <input 
                    type="text" value={frontImageUrl} onChange={(e) => setFrontImageUrl(e.target.value)}
                    placeholder="https://images..." className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Back Image URL</label>
                  <input 
                    type="text" value={backImageUrl} onChange={(e) => setBackImageUrl(e.target.value)}
                    placeholder="https://images..." className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
              </div>

              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Product Description</label>
                <textarea 
                  rows={2} value={description} onChange={(e) => setDescription(e.target.value)}
                  placeholder="Grooves details..." className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                />
              </div>

              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Internal Setup Notes</label>
                <textarea 
                  rows={2} value={notes} onChange={(e) => setNotes(e.target.value)}
                  placeholder="Cutter machine setup guidance..." className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                />
              </div>

              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Catalog Status</label>
                <select 
                  value={status} onChange={(e) => setStatus(e.target.value)}
                  className="w-full bg-[#1b1530] border border-white/10 text-xs px-3 py-2 rounded-lg text-gray-300 focus:outline-none"
                >
                  <option value="ACTIVE">Active (Searchable by shops)</option>
                  <option value="INACTIVE">Inactive (Hidden)</option>
                </select>
              </div>

              <div className="border-t border-white/5 pt-4 flex justify-end gap-3">
                <button 
                  type="button" onClick={() => setShowAddModal(false)}
                  className="px-4 py-2 border border-white/10 rounded-lg text-xs text-gray-300 hover:bg-white/5"
                >
                  Cancel
                </button>
                <button 
                  type="submit"
                  className="glass-button-primary px-4 py-2 rounded-lg text-xs text-white font-semibold"
                >
                  {editKey ? 'Save Changes' : 'Publish Key'}
                </button>
              </div>
            </form>
          </div>
        </div>,
        document.body
      )}
    </div>
  );
}

// ============================================================================
// COMPONENT 5: STORE INVENTORY & DISPATCH fulfillment (SUPER ADMIN ONLY)
// ============================================================================
function StoreInventoryView({ t, api }) {
  const [products, setProducts] = useState([]);
  const [orders, setOrders] = useState([]);
  const [loading, setLoading] = useState(true);
  const [subTab, setSubTab] = useState('inventory'); // inventory | orders
  const [showAddModal, setShowAddModal] = useState(false);
  const [editProduct, setEditProduct] = useState(null);

  // Form states
  const [name, setName] = useState('');
  const [description, setDescription] = useState('');
  const [price, setPrice] = useState('');
  const [category, setCategory] = useState('Key Blanks');
  const [stock, setStock] = useState('');
  const [imageUrl, setImageUrl] = useState('');
  const [discountPercentage, setDiscountPercentage] = useState(0);

  useEffect(() => {
    fetchInventoryData();
  }, [subTab]);

  const fetchInventoryData = async () => {
    setLoading(true);
    try {
      if (subTab === 'inventory') {
        const res = await api.getProducts();
        setProducts(res);
      } else {
        const res = await api.getSuperOrders();
        setOrders(res);
      }
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  const handleProductSubmit = async (e) => {
    e.preventDefault();
    try {
      const dto = { 
        name, 
        description, 
        price: Number(price), 
        discountPercentage: Number(discountPercentage),
        category, 
        stock: Number(stock), 
        imageUrl 
      };
      if (editProduct) {
        await api.updateProduct(editProduct.id, dto);
      } else {
        await api.createProduct(dto);
      }
      setShowAddModal(false);
      resetProductForm();
      fetchInventoryData();
    } catch (err) {
      alert(err.message || 'Operation failed');
    }
  };

  const resetProductForm = () => {
    setEditProduct(null);
    setName('');
    setDescription('');
    setPrice('');
    setCategory('Key Blanks');
    setStock('');
    setImageUrl('');
    setDiscountPercentage(0);
  };

  const handleEditProductClick = (p) => {
    setEditProduct(p);
    setName(p.name);
    setDescription(p.description || '');
    setPrice(p.price);
    setCategory(p.category);
    setStock(p.stock);
    setImageUrl(p.imageUrl || '');
    setDiscountPercentage(p.discountPercentage || 0);
    setShowAddModal(true);
  };

  const handleDeleteProduct = async (id) => {
    if (!confirm('Are you sure you want to delete this product?')) return;
    try {
      await api.deleteProduct(id);
      fetchInventoryData();
    } catch (e) {
      alert(e.message);
    }
  };

  const updateOrderStatus = async (id, status) => {
    try {
      await api.updateOrderStatus(id, status);
      fetchInventoryData();
    } catch (e) {
      alert(e.message);
    }
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 className="text-2xl font-extrabold tracking-tight">{t('inventory')}</h1>
          <p className="text-sm text-gray-400 mt-1">Sell key blank supplies, milling accessories, and cutters to key shops.</p>
        </div>
        <div className="flex gap-2">
          <button 
            onClick={() => setSubTab('inventory')}
            className={`px-4 py-2 text-xs font-semibold rounded-xl border transition ${subTab === 'inventory' ? 'bg-primary-600 text-white border-primary-500 shadow-md' : 'bg-white/5 border-white/5 text-gray-400 hover:text-white'}`}
          >
            {t('inventoryStock')}
          </button>
          <button 
            onClick={() => setSubTab('orders')}
            className={`px-4 py-2 text-xs font-semibold rounded-xl border transition ${subTab === 'orders' ? 'bg-primary-600 text-white border-primary-500 shadow-md' : 'bg-white/5 border-white/5 text-gray-400 hover:text-white'}`}
          >
            {t('incomingOrders')}
          </button>
        </div>
      </div>

      {subTab === 'inventory' ? (
        <div className="space-y-4">
          <div className="flex justify-end">
            <button 
              onClick={() => { resetProductForm(); setShowAddModal(true); }}
              className="glass-button-primary text-white text-xs font-semibold px-4 py-2.5 rounded-xl flex items-center gap-2"
            >
              <Plus className="h-4 w-4" />
              <span>Add Store Product</span>
            </button>
          </div>

          {loading ? (
            <div className="flex h-48 items-center justify-center">
              <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
            </div>
          ) : (
            <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
              {products.map(p => (
                <div key={p.id} className="glass-panel rounded-2xl overflow-hidden flex flex-col justify-between border border-white/5">
                  <img src={p.imageUrl} alt={p.name} className="w-full h-32 object-cover opacity-85" />
                  <div className="p-4 flex-1 flex flex-col justify-between space-y-3">
                    <div>
                      <span className="text-[9px] uppercase tracking-wider bg-primary-600/20 text-primary-300 px-2 py-0.5 border border-primary-500/20 rounded font-bold">
                        {p.category}
                      </span>
                      <h3 className="font-bold text-sm text-white mt-1.5 leading-snug">{p.name}</h3>
                      <p className="text-[11px] text-gray-400 line-clamp-2 mt-1 italic">"{p.description}"</p>
                    </div>

                    <div className="flex justify-between items-center text-xs font-bold border-t border-white/5 pt-3">
                      <div>
                        {p.discountPercentage > 0 ? (
                          <div className="flex flex-col">
                            <span className="text-gray-500 text-[10px] line-through leading-none">Rs. {p.price.toFixed(2)}</span>
                            <div className="flex items-center gap-1 mt-0.5">
                              <span className="text-emerald-400 text-sm">Rs. {(p.offerPrice || p.price).toFixed(2)}</span>
                              <span className="bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-1 py-0.5 rounded text-[8px] font-bold leading-none">{p.discountPercentage}% OFF</span>
                            </div>
                          </div>
                        ) : (
                          <span className="text-emerald-400 text-sm">Rs. {p.price.toFixed(2)}</span>
                        )}
                      </div>
                      <span className={`${p.stock < 5 ? 'text-red-400' : 'text-gray-400'}`}>Stock: {p.stock}</span>
                    </div>

                    <div className="flex gap-2 pt-2">
                      <button 
                        onClick={() => handleEditProductClick(p)}
                        className="w-1/2 bg-white/5 hover:bg-white/10 text-gray-300 py-1.5 rounded-lg text-[10px] font-bold transition flex items-center justify-center gap-1"
                      >
                        <Edit className="h-3 w-3" />
                        <span>Edit</span>
                      </button>
                      <button 
                        onClick={() => handleDeleteProduct(p.id)}
                        className="w-1/2 bg-red-950/20 hover:bg-red-500/15 text-red-400 py-1.5 rounded-lg text-[10px] font-bold transition flex items-center justify-center gap-1"
                      >
                        <Trash className="h-3 w-3" />
                        <span>Delete</span>
                      </button>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      ) : (
        /* Super Admin Orders fulfillment tracker log */
        <div className="space-y-4">
          {loading ? (
            <div className="flex h-48 items-center justify-center">
              <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
            </div>
          ) : orders.length === 0 ? (
            <div className="glass-panel p-8 text-center text-xs text-gray-500 rounded-2xl">
              No platform supply orders placed yet.
            </div>
          ) : (
            <div className="space-y-4">
              {/* Sales Revenue KPI Summary */}
              <div className="glass-panel p-5 rounded-2xl border border-white/5 flex items-center justify-between bg-primary-600/5">
                <div className="flex items-center gap-3">
                  <div className="p-3 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-xl">
                    <DollarSign className="h-6 w-6" />
                  </div>
                  <div>
                    <h3 className="text-xs font-bold text-gray-400 uppercase tracking-wider">Gross Platform Store Revenue</h3>
                    <p className="text-[11px] text-gray-500 mt-0.5">Total accumulated payouts from wholesale supplies, machinery, and key blanks.</p>
                  </div>
                </div>
                <div className="text-right">
                  <span className="text-2xl font-extrabold text-emerald-400">
                    Rs. {orders.reduce((acc, o) => acc + o.totalAmount, 0).toFixed(2)}
                  </span>
                </div>
              </div>

              {orders.map(o => (
                <div key={o.id} className="glass-panel p-5 rounded-2xl border border-white/5 flex flex-col md:flex-row md:items-center justify-between gap-6">
                  <div className="space-y-2 flex-1">
                    <div className="flex items-center gap-3">
                      <span className="font-extrabold text-sm text-white">Order {o.id.split('-').pop()}</span>
                      <span className="text-xs text-primary-400 font-bold">{o.shop ? o.shop.name : 'Unknown Shop'}</span>
                      <span className={`px-2 py-0.5 rounded font-bold text-[9px] uppercase tracking-wider ${o.status === 'DELIVERED' ? 'bg-emerald-500/10 text-emerald-400' : o.status === 'DISPATCHED' ? 'bg-blue-500/10 text-blue-400' : 'bg-amber-500/10 text-amber-400 animate-pulse'}`}>
                        {o.status}
                      </span>
                    </div>

                    <div className="text-[11px] text-gray-400 bg-white/2 p-3 rounded-xl border border-white/5">
                      <span className="font-semibold block text-[10px] text-gray-500 uppercase mb-1">Purchased Accessories:</span>
                      {o.items.map(item => (
                        <div key={item.id} className="flex justify-between py-0.5">
                          <span>{item.product ? item.product.name : 'Supply Blank'} x{item.quantity}</span>
                          <span className="text-gray-300">Rs. {(item.price * item.quantity).toFixed(2)}</span>
                        </div>
                      ))}
                    </div>
                  </div>

                  <div className="flex flex-col items-end gap-3">
                    <div className="text-right">
                      <span className="text-[10px] text-gray-500 block uppercase">Total Invoice</span>
                      <span className="font-extrabold text-emerald-400 text-lg">Rs. {o.totalAmount.toFixed(2)}</span>
                    </div>

                    <div className="flex gap-2">
                      {o.status === 'PENDING' && (
                        <button 
                          onClick={() => updateOrderStatus(o.id, 'DISPATCHED')}
                          className="bg-blue-600 hover:bg-blue-500 text-white font-bold text-[10px] uppercase px-3 py-1.5 rounded-lg flex items-center gap-1.5 transition"
                        >
                          <Truck className="h-3.5 w-3.5" />
                          <span>Dispatch Supplies</span>
                        </button>
                      )}
                      {o.status === 'DISPATCHED' && (
                        <button 
                          onClick={() => updateOrderStatus(o.id, 'DELIVERED')}
                          className="bg-emerald-600 hover:bg-emerald-500 text-white font-bold text-[10px] uppercase px-3 py-1.5 rounded-lg flex items-center gap-1.5 transition"
                        >
                          <CheckCircle2 className="h-3.5 w-3.5" />
                          <span>Complete Order</span>
                        </button>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {/* Add / Edit Product Modal */}
      {showAddModal && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/70 backdrop-blur-sm flex justify-center p-4 md:p-10">
          <div className="glass-panel w-full max-w-lg rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4">
            <div className="flex items-center justify-between border-b border-white/5 pb-3">
              <h2 className="text-base font-bold text-white uppercase tracking-wider flex items-center gap-2">
                <ShoppingBag className="h-5 w-5 text-primary-400" />
                <span>{editProduct ? 'Modify Product Stock' : 'Add Wholesale Product'}</span>
              </h2>
              <button onClick={() => setShowAddModal(false)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            <form onSubmit={handleProductSubmit} className="space-y-4">
              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Product / Supply Title</label>
                <input 
                  type="text" required value={name} onChange={(e) => setName(e.target.value)}
                  placeholder="e.g. Godrej Blank Keys Box of 100" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                />
              </div>

              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Visual Creative URL</label>
                <input 
                  type="text" required value={imageUrl} onChange={(e) => setImageUrl(e.target.value)}
                  placeholder="https://images.unsplash.com..." className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                />
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Price (Original USD)</label>
                  <input 
                    type="number" step="0.01" required value={price} onChange={(e) => setPrice(e.target.value)}
                    placeholder="45.00" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Discount Offer (%)</label>
                  <div className="flex gap-2">
                    <input 
                      type="number" min="0" max="100" value={discountPercentage} onChange={(e) => setDiscountPercentage(e.target.value)}
                      placeholder="e.g. 20" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                    />
                    <div className="bg-emerald-500/10 border border-emerald-500/20 px-3 py-2 rounded-lg text-[10px] text-emerald-400 font-bold shrink-0 flex flex-col justify-center text-center">
                      <span className="text-[7px] text-gray-500 uppercase block font-semibold leading-none mb-0.5">Offer Price</span>
                      <span className="leading-none">Rs. {(price * (1 - (Number(discountPercentage) || 0) / 100)).toFixed(2)}</span>
                    </div>
                  </div>
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Wholesale stock</label>
                  <input 
                    type="number" required value={stock} onChange={(e) => setStock(e.target.value)}
                    placeholder="50" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Store Category</label>
                  <select 
                    value={category} onChange={(e) => setCategory(e.target.value)}
                    className="w-full bg-[#1b1530] border border-white/10 text-xs px-3 py-2 rounded-lg text-gray-300 focus:outline-none"
                  >
                    <option value="Key Blanks">Key Blanks</option>
                    <option value="Machines">Machines</option>
                    <option value="Accessories">Accessories</option>
                  </select>
                </div>
              </div>

              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Catalog description</label>
                <textarea 
                  rows={2} value={description} onChange={(e) => setDescription(e.target.value)}
                  placeholder="Specs, metal structure, etc." className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                />
              </div>

              <div className="border-t border-white/5 pt-4 flex justify-end gap-3">
                <button 
                  type="button" onClick={() => setShowAddModal(false)}
                  className="px-4 py-2 border border-white/10 rounded-lg text-xs text-gray-300 hover:bg-white/5"
                >
                  Cancel
                </button>
                <button 
                  type="submit"
                  className="glass-button-primary px-4 py-2 rounded-lg text-xs text-white font-semibold"
                >
                  Save Product
                </button>
              </div>
            </form>
          </div>
        </div>,
        document.body
      )}
    </div>
  );
}

// ============================================================================
// COMPONENT 6: ADVERTISEMENTS CRUD (SUPER ADMIN ONLY)
// ============================================================================
function AdsManagementView({ api }) {
  const [ads, setAds] = useState([]);
  const [shops, setShops] = useState([]);
  const [loading, setLoading] = useState(true);
  const [showAddModal, setShowAddModal] = useState(false);

  // Form states
  const [title, setTitle] = useState('');
  const [imageUrl, setImageUrl] = useState('');
  const [type, setType] = useState('BANNER');
  const [startDate, setStartDate] = useState('');
  const [endDate, setEndDate] = useState('');
  const [priority, setPriority] = useState(0);
  const [targetAll, setTargetAll] = useState(true);
  const [targetShops, setTargetShops] = useState([]);
  const [errorMsg, setErrorMsg] = useState('');

  useEffect(() => {
    fetchAds();
    fetchShops();
  }, []);

  const fetchAds = async () => {
    setLoading(true);
    try {
      const res = await api.getAdvertisements();
      setAds(res);
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  const fetchShops = async () => {
    try {
      const res = await api.getShops();
      setShops(res);
    } catch (e) {
      console.error(e);
    }
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    setErrorMsg('');
    try {
      await api.createAdvertisement({
        title, imageUrl, type,
        startDate: new Date(startDate).toISOString(),
        endDate: new Date(endDate).toISOString(),
        priority: Number(priority),
        targetAll,
        targetShops
      });
      setShowAddModal(false);
      resetForm();
      fetchAds();
    } catch (err) {
      setErrorMsg(err.message || 'Failed to schedule campaign');
    }
  };

  const resetForm = () => {
    setTitle('');
    setImageUrl('');
    setType('BANNER');
    setStartDate('');
    setEndDate('');
    setPriority(0);
    setTargetAll(true);
    setTargetShops([]);
    setErrorMsg('');
  };

  const handleDelete = async (id) => {
    if (!confirm('Are you sure you want to terminate this advertisement campaign?')) return;
    try {
      await api.deleteAdvertisement(id);
      fetchAds();
    } catch (e) {
      alert(e.message);
    }
  };

  const handleShopSelectChange = (shopId) => {
    if (targetShops.includes(shopId)) {
      setTargetShops(targetShops.filter(id => id !== shopId));
    } else {
      setTargetShops([...targetShops, shopId]);
    }
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-extrabold tracking-tight">Advertisement Campaigns</h1>
          <p className="text-sm text-gray-400 mt-1">Publish banners and popups targeted to shop dashboard screens.</p>
        </div>
        <button 
          onClick={() => { resetForm(); setShowAddModal(true); }}
          className="glass-button-primary text-white text-xs font-semibold px-4 py-2.5 rounded-xl flex items-center gap-2"
        >
          <Plus className="h-4 w-4" />
          <span>New Ad Campaign</span>
        </button>
      </div>

      {loading ? (
        <div className="flex h-64 items-center justify-center">
          <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
        </div>
      ) : (
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
          {ads.map(ad => (
            <div key={ad.id} className="glass-panel rounded-2xl overflow-hidden shadow-xl border border-white/5 flex flex-col justify-between">
              <div>
                <img src={cleanGoogleImageUrl(ad.imageUrl)} alt={ad.title} className="w-full h-40 object-cover border-b border-white/5 opacity-85" />
                <div className="p-5 space-y-3">
                  <div className="flex items-center justify-between">
                    <span className="text-[10px] font-bold uppercase tracking-wider bg-primary-600/20 text-primary-300 border border-primary-500/20 px-2 py-0.5 rounded">
                      {ad.type}
                    </span>
                    <span className="text-[10px] text-gray-400 font-bold uppercase">Priority: {ad.priority}</span>
                  </div>
                  <h3 className="text-sm font-bold text-white leading-relaxed">{ad.title}</h3>
                  <div className="text-[11px] text-gray-400 grid grid-cols-2 gap-2 bg-white/2 p-2.5 rounded-xl border border-white/5">
                    <div>
                      <span className="text-gray-500 block">Start Date</span>
                      <span>{new Date(ad.startDate).toLocaleDateString()}</span>
                    </div>
                    <div>
                      <span className="text-gray-500 block">End Date</span>
                      <span>{new Date(ad.endDate).toLocaleDateString()}</span>
                    </div>
                  </div>
                  <div className="text-[11px] text-gray-400 mt-1">
                    <span className="font-semibold text-gray-300">Audience: </span>
                    {ad.targetAll ? 'All Key Shops' : `${ad.targetShops.length} targeted shops`}
                  </div>
                </div>
              </div>

              <div className="p-5 pt-0 flex justify-end">
                <button 
                  onClick={() => handleDelete(ad.id)}
                  className="bg-red-950/20 hover:bg-red-500/15 text-red-400 px-3 py-1.5 rounded-lg text-xs font-semibold transition flex items-center gap-1.5"
                >
                  <Trash className="h-3.5 w-3.5" />
                  <span>Cancel Campaign</span>
                </button>
              </div>
            </div>
          ))}
        </div>
      )}

      {/* Campaign Add Modal */}
      {showAddModal && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/70 backdrop-blur-sm flex justify-center p-4 md:p-10">
          <div className="glass-panel w-full max-w-lg rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4">
            <div className="flex items-center justify-between border-b border-white/5 pb-3">
              <h2 className="text-base font-bold text-white uppercase tracking-wider flex items-center gap-2">
                <Radio className="h-5 w-5 text-primary-400" />
                <span>New Visual Ad Campaign</span>
              </h2>
              <button onClick={() => setShowAddModal(false)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            {errorMsg && (
              <div className="bg-red-950/50 border border-red-500/50 p-3 rounded-lg flex gap-2 text-xs text-red-200">
                <AlertTriangle className="h-4 w-4 shrink-0" />
                <span>{errorMsg}</span>
              </div>
            )}

            <form onSubmit={handleSubmit} className="space-y-4">
              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Ad title / Announcement</label>
                <input 
                  type="text" required value={title} onChange={(e) => setTitle(e.target.value)}
                  placeholder="e.g. 20% Off Godrej key duplicates this Friday" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                />
              </div>

              <div>
                <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase font-bold tracking-wider">Banner Image Source</label>
                <div className="flex gap-2">
                  <input 
                    type="text" required value={imageUrl} 
                    onChange={(e) => setImageUrl(cleanGoogleImageUrl(e.target.value))}
                    placeholder="Paste Image URL (or Google Image Link)" 
                    className="flex-1 glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                  <label className="cursor-pointer bg-white/5 hover:bg-white/10 border border-white/10 px-3 py-2 rounded-xl text-xs font-bold text-gray-300 flex items-center justify-center gap-1.5 transition shrink-0">
                    <Upload className="h-3.5 w-3.5 text-primary-400" />
                    <span>Upload</span>
                    <input 
                      type="file" accept="image/*" className="hidden" 
                      onChange={(e) => {
                        const file = e.target.files[0];
                        if (file) {
                          const reader = new FileReader();
                          reader.onloadend = () => {
                            setImageUrl(reader.result);
                          };
                          reader.readAsDataURL(file);
                        }
                      }}
                    />
                  </label>
                </div>
                {imageUrl && (
                  <div className="mt-2 rounded-lg overflow-hidden border border-white/5 h-24 bg-[#120e29] flex items-center justify-center">
                    <img src={cleanGoogleImageUrl(imageUrl)} alt="Preview" className="max-h-full max-w-full object-contain" />
                  </div>
                )}
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Ad Format</label>
                  <select 
                    value={type} onChange={(e) => setType(e.target.value)}
                    className="w-full bg-[#1b1530] border border-white/10 text-xs px-3 py-2 rounded-lg text-gray-300 focus:outline-none"
                  >
                    <option value="BANNER">Main Banner Notice</option>
                    <option value="POPUP">Interactive Login Popup</option>
                    <option value="NOTICE">Dashboard Text Notice</option>
                  </select>
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Campaign Priority</label>
                  <input 
                    type="number" required value={priority} onChange={(e) => setPriority(e.target.value)}
                    placeholder="0" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                  />
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-white/5 pt-4">
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">Start Date</label>
                  <input 
                    type="date" required value={startDate} onChange={(e) => setStartDate(e.target.value)}
                    className="w-full bg-[#1b1530] border border-white/10 text-xs px-3 py-2 rounded-lg text-gray-300 focus:outline-none"
                  />
                </div>
                <div>
                  <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase">End Date</label>
                  <input 
                    type="date" required value={endDate} onChange={(e) => setEndDate(e.target.value)}
                    className="w-full bg-[#1b1530] border border-white/10 text-xs px-3 py-2 rounded-lg text-gray-300 focus:outline-none"
                  />
                </div>
              </div>

              <div className="border-t border-white/5 pt-4 space-y-2">
                <label className="block text-xs font-semibold text-gray-400 uppercase">Target Audience</label>
                <div className="flex gap-4 items-center">
                  <label className="flex items-center gap-2 text-xs cursor-pointer text-gray-300">
                    <input 
                      type="radio" name="target" checked={targetAll} onChange={() => setTargetAll(true)}
                      className="accent-primary-500"
                    />
                    <span>Broadcast to all key shops</span>
                  </label>
                  <label className="flex items-center gap-2 text-xs cursor-pointer text-gray-300">
                    <input 
                      type="radio" name="target" checked={!targetAll} onChange={() => setTargetAll(false)}
                      className="accent-primary-500"
                    />
                    <span>Target specific shops</span>
                  </label>
                </div>

                {!targetAll && (
                  <div className="bg-[#100b21] p-3 rounded-lg border border-white/5 max-h-32 overflow-y-auto space-y-1">
                    {shops.map(s => (
                      <label key={s.id} className="flex items-center gap-2 text-xs text-gray-300 cursor-pointer hover:bg-white/2 p-1 rounded">
                        <input 
                          type="checkbox" checked={targetShops.includes(s.id)} onChange={() => handleShopSelectChange(s.id)}
                          className="accent-primary-500 rounded border-white/10"
                        />
                        <span>{s.name}</span>
                      </label>
                    ))}
                  </div>
                )}
              </div>

              <div className="border-t border-white/5 pt-4 flex justify-end gap-3">
                <button 
                  type="button" onClick={() => setShowAddModal(false)}
                  className="px-4 py-2 border border-white/10 rounded-lg text-xs text-gray-300 hover:bg-white/5"
                >
                  Cancel
                </button>
                <button 
                  type="submit"
                  className="glass-button-primary px-4 py-2 rounded-lg text-xs text-white font-semibold"
                >
                  Schedule Campaign
                </button>
              </div>
            </form>
          </div>
        </div>,
        document.body
      )}
    </div>
  );
}

// ============================================================================
// COMPONENT 6B: PRICING & PROMOTIONAL OFFERS MANAGEMENT (SUPER ADMIN ONLY)
// ============================================================================
function PricingOffersView({ api }) {
  const [activeSubTab, setActiveSubTab] = useState('pricing'); // pricing | offers
  
  // Pricing states
  const [trialPrice, setTrialPrice] = useState(0);
  const [monthlyPrice, setMonthlyPrice] = useState(49);
  const [yearlyPrice, setYearlyPrice] = useState(499);
  const [pricingLoading, setPricingLoading] = useState(true);

  useEffect(() => {
    fetchPrices();
  }, []);

  const fetchPrices = async () => {
    setPricingLoading(true);
    try {
      const res = await api.getPlanPrices();
      setTrialPrice(res.TRIAL ?? 0);
      setMonthlyPrice(res.MONTHLY ?? 49);
      setYearlyPrice(res.YEARLY ?? 499);
    } catch (e) {
      console.error(e);
    } finally {
      setPricingLoading(false);
    }
  };

  const handleUpdatePrices = async (e) => {
    e.preventDefault();
    try {
      await api.updatePlanPrices({
        TRIAL: Number(trialPrice),
        MONTHLY: Number(monthlyPrice),
        YEARLY: Number(yearlyPrice)
      });
      alert('Subscription plan prices updated successfully!');
    } catch (err) {
      alert(`Update failed: ${err.message}`);
    }
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 className="text-2xl font-extrabold tracking-tight">Pricing & Promotional Offers</h1>
          <p className="text-sm text-gray-400 mt-1">Configure franchise subscription rates and edit dashboard banner campaigns.</p>
        </div>
        <div className="flex gap-2 self-end">
          <button 
            onClick={() => setActiveSubTab('pricing')}
            className={`px-4 py-2 text-xs font-semibold rounded-xl border transition ${activeSubTab === 'pricing' ? 'bg-primary-600 text-white border-primary-500 shadow-md' : 'bg-white/5 border-white/5 text-gray-400 hover:text-white'}`}
          >
            Subscription Rates
          </button>
          <button 
            onClick={() => setActiveSubTab('offers')}
            className={`px-4 py-2 text-xs font-semibold rounded-xl border transition ${activeSubTab === 'offers' ? 'bg-primary-600 text-white border-primary-500 shadow-md' : 'bg-white/5 border-white/5 text-gray-400 hover:text-white'}`}
          >
            Offers & Banner Ads
          </button>
        </div>
      </div>

      {activeSubTab === 'pricing' ? (
        <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-6 max-w-xl mx-auto">
          <div>
            <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3">Subscription Plan Pricing</h2>
            <p className="text-xs text-gray-500 mt-1">Set rates for the key shops. These prices will automatically update the checkout gateway screen during provisioning.</p>
          </div>

          {pricingLoading ? (
            <div className="flex h-32 items-center justify-center">
              <RefreshCw className="h-6 w-6 animate-spin text-primary-400" />
            </div>
          ) : (
            <form onSubmit={handleUpdatePrices} className="space-y-5">
              <div className="space-y-4">
                <div>
                  <label className="block text-[10px] font-bold text-gray-400 mb-1.5 uppercase">Free Trial Plan (Rs.)</label>
                  <input 
                    type="number" required value={trialPrice} onChange={(e) => setTrialPrice(e.target.value)}
                    className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                  />
                  <p className="text-[9px] text-gray-500 mt-1">Initial evaluation period. Suggested: 0.</p>
                </div>

                <div>
                  <label className="block text-[10px] font-bold text-gray-400 mb-1.5 uppercase">Monthly Recurring Plan (Rs.)</label>
                  <input 
                    type="number" required value={monthlyPrice} onChange={(e) => setMonthlyPrice(e.target.value)}
                    className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                  />
                  <p className="text-[9px] text-gray-500 mt-1">Monthly recurring rental bill for platform service.</p>
                </div>

                <div>
                  <label className="block text-[10px] font-bold text-gray-400 mb-1.5 uppercase">Yearly Plan Discounted Rate (Rs.)</label>
                  <input 
                    type="number" required value={yearlyPrice} onChange={(e) => setYearlyPrice(e.target.value)}
                    className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                  />
                  <p className="text-[9px] text-gray-500 mt-1">Discounted upfront annual rate for shops.</p>
                </div>
              </div>

              <div className="flex justify-end border-t border-white/5 pt-4">
                <button 
                  type="submit"
                  className="glass-button-primary px-5 py-2.5 rounded-xl text-xs font-semibold text-white flex items-center gap-1.5"
                >
                  <Check className="h-4 w-4" />
                  <span>Update Subscription Rates</span>
                </button>
              </div>
            </form>
          )}
        </div>
      ) : (
        <AdsManagementView api={api} />
      )}
    </div>
  );
}

// ============================================================================
// COMPONENT 7: REVENUE MANAGEMENT (SUPER ADMIN ONLY)
// ============================================================================
function RevenueManagementView({ api }) {
  const [records, setRecords] = useState([]);
  const [loading, setLoading] = useState(true);

  // Form states
  const [month, setMonth] = useState(new Date().getMonth() + 1);
  const [year, setYear] = useState(new Date().getFullYear());
  const [amount, setAmount] = useState('');
  const [notes, setNotes] = useState('');

  useEffect(() => {
    fetchRevenue();
  }, []);

  const fetchRevenue = async () => {
    setLoading(true);
    try {
      const res = await api.getRevenue();
      setRecords(res);
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    try {
      await api.logRevenue(month, year, amount, notes);
      setAmount('');
      setNotes('');
      fetchRevenue();
    } catch (e) {
      alert(e.message);
    }
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div>
        <h1 className="text-2xl font-extrabold tracking-tight">Monthly Revenue Logs</h1>
        <p className="text-sm text-gray-400 mt-1">Record subscription collections manually for SaaS performance tracking.</p>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div className="glass-panel p-6 rounded-2xl h-fit border border-white/5 space-y-4">
          <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3">
            Add Revenue Record
          </h2>

          <form onSubmit={handleSubmit} className="space-y-4">
            <div className="grid grid-cols-2 gap-4">
              <div>
                <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Month</label>
                <select 
                  value={month} onChange={(e) => setMonth(Number(e.target.value))}
                  className="w-full bg-[#1b1530] border border-white/10 text-xs px-3 py-2 rounded-lg text-gray-300 focus:outline-none"
                >
                  {Array.from({ length: 12 }, (_, i) => (
                    <option key={i+1} value={i+1}>
                      {new Date(2000, i).toLocaleString('default', { month: 'long' })}
                    </option>
                  ))}
                </select>
              </div>
              <div>
                <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Year</label>
                <input 
                  type="number" required value={year} onChange={(e) => setYear(Number(e.target.value))}
                  className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
                />
              </div>
            </div>

            <div>
              <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Amount Collected (USD)</label>
              <input 
                type="number" step="0.01" required value={amount} onChange={(e) => setAmount(e.target.value)}
                placeholder="2450.00" className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
              />
            </div>

            <div>
              <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Notes / Remarks</label>
              <textarea 
                rows={3} value={notes} onChange={(e) => setNotes(e.target.value)}
                placeholder="..." className="w-full glass-input px-3 py-2 rounded-lg text-xs text-white"
              />
            </div>

            <button 
              type="submit"
              className="w-full glass-button-primary text-white py-2.5 rounded-xl font-semibold text-xs flex items-center justify-center gap-2"
            >
              <Check className="h-4 w-4" />
              <span>Log Revenue Payout</span>
            </button>
          </form>
        </div>

        <div className="glass-panel p-6 rounded-2xl md:col-span-2 flex flex-col">
          <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3 mb-4">
            Platform Revenue History
          </h2>

          {loading ? (
            <div className="flex h-32 items-center justify-center">
              <RefreshCw className="h-6 w-6 animate-spin text-primary-400" />
            </div>
          ) : records.length === 0 ? (
            <div className="flex-1 flex items-center justify-center text-xs text-gray-500 py-10">
              No revenue logs recorded yet.
            </div>
          ) : (
            <div className="space-y-3 flex-1 overflow-y-auto max-h-[400px]">
              {records.map(r => (
                <div key={r.id} className="bg-white/2 border border-white/5 p-4 rounded-xl flex items-center justify-between text-xs">
                  <div className="space-y-1">
                    <p className="font-bold text-gray-200 text-sm">
                      {new Date(2000, r.month-1).toLocaleString('default', { month: 'long' })} {r.year}
                    </p>
                    {r.notes && <p className="text-gray-400 text-[10px]">Notes: {r.notes}</p>}
                  </div>
                  <div className="text-right">
                    <p className="text-emerald-400 font-extrabold text-base">Rs. {r.amount.toFixed(2)}</p>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

// ============================================================================
// COMPONENT 8: BLANK KEY SEARCH (SHOP ADMIN ONLY)
// ============================================================================
function KeysSearchView({ api }) {
  const { user } = useAuth();
  const [results, setResults] = useState([]);
  const [loading, setLoading] = useState(false);
  const [query, setQuery] = useState('');
  const [selectedResult, setSelectedResult] = useState(null);

  useEffect(() => {
    performSearch();
  }, [query]);

  const performSearch = async () => {
    setLoading(true);
    try {
      const allMasterKeys = await api.getMasterKeys();
      
      let matchedKeys = allMasterKeys;
      if (query) {
        const q = query.toLowerCase();
        matchedKeys = allMasterKeys.filter(k => 
          (k.keyNumber && k.keyNumber.toLowerCase().includes(q)) ||
          (k.brand && k.brand.toLowerCase().includes(q)) ||
          (k.category && k.category.toLowerCase().includes(q))
        );
      }

      const matchingCustomers = await api.getGlobalCustomersForSearch(query);

      const items = [];

      // 1. Add matching customer registrations linked to key specs
      matchingCustomers.forEach(c => {
        const spec = allMasterKeys.find(k => k.keyNumber.toLowerCase() === c.keyNumber.toLowerCase());
        items.push({
          id: `cust-${c.id}`,
          keySpec: spec || {
            id: `spec-${c.id}`,
            keyNumber: c.keyNumber,
            brand: 'Manual Vehicle Key',
            category: 'Vehicle Keys',
            blankNumber: c.keyNumber,
            frontImageUrl: null,
            backImageUrl: null
          },
          customer: c
        });
      });

      // 2. Add matching general keys that aren't already included
      matchedKeys.forEach(k => {
        if (!items.some(item => item.keySpec.keyNumber.toLowerCase() === k.keyNumber.toLowerCase())) {
          items.push({
            id: `key-${k.id}`,
            keySpec: k,
            customer: null
          });
        }
      });

      setResults(items);
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div>
        <h1 className="text-2xl font-extrabold tracking-tight">Master Key Catalog Search</h1>
        <p className="text-sm text-gray-400 mt-1">Lookup blank specifications, brand numbers, and customer registry records.</p>
      </div>

      <div className="glass-panel p-4 rounded-2xl flex items-center gap-3">
        <Search className="h-5 w-5 text-primary-400 shrink-0" />
        <input 
          type="text" value={query} onChange={(e) => setQuery(e.target.value)}
          placeholder="Search by key code, vehicle number, customer location, category..."
          className="w-full bg-transparent border-none outline-none text-sm placeholder:text-gray-500 text-white"
        />
        {query && (
          <button onClick={() => setQuery('')} className="text-gray-400 hover:text-white">
            <X className="h-4 w-4" />
          </button>
        )}
      </div>

      {loading ? (
        <div className="flex h-48 items-center justify-center">
          <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
        </div>
      ) : (
        <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
          {results.map(r => (
            <div 
              key={r.id} onClick={() => setSelectedResult(r)}
              className="glass-panel p-5 rounded-2xl glass-panel-hover cursor-pointer flex flex-col justify-between"
            >
              <div className="space-y-3">
                <div className="flex items-center justify-between">
                  <span className="text-[10px] font-bold bg-primary-600/10 text-primary-300 border border-primary-500/20 px-2 py-0.5 rounded uppercase">
                    {r.keySpec.category}
                  </span>
                  <span className="text-[10px] text-gray-500 font-bold uppercase">{r.keySpec.brand}</span>
                </div>
                <div className="flex gap-4">
                  {r.keySpec.frontImageUrl ? (
                    <img src={r.keySpec.frontImageUrl} alt="Front preview" className="w-16 h-16 object-cover rounded-lg border border-white/5" />
                  ) : (
                    <div className="w-16 h-16 rounded-lg bg-white/2 border border-white/10 flex items-center justify-center text-xs text-gray-500">
                      No Preview
                    </div>
                  )}
                  <div>
                    <h3 className="text-base font-bold text-white">{r.keySpec.keyNumber}</h3>
                    <p className="text-xs text-gray-400">Blank: {r.keySpec.blankNumber}</p>
                    {r.customer && (
                      <div className="mt-2 space-y-1">
                        <span className="inline-block text-[9px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/25 px-1.5 py-0.5 rounded font-bold uppercase">
                          Registered Customer Key
                        </span>
                        <div className="text-[10px] text-gray-300 bg-white/5 border border-white/5 p-2 rounded-xl mt-1 space-y-0.5">
                          <p><span className="text-gray-500">Customer:</span> <strong className="text-white">{r.customer.name}</strong></p>
                          <p><span className="text-gray-500">Vehicle No:</span> <strong className="text-emerald-400">{r.customer.vehicleNumber || 'N/A'}</strong></p>
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              </div>
              <div className="text-[10px] text-primary-400 font-bold border-t border-white/5 pt-3 mt-4 flex items-center justify-between">
                <span>View Full Details</span>
                <ExternalLink className="h-3 w-3" />
              </div>
            </div>
          ))}
        </div>
      )}

      {/* Details View Modal */}
      {selectedResult && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/60 backdrop-blur-sm flex justify-center p-4 md:p-10">
          <div className="glass-panel w-full max-w-lg rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4 bg-[#100c25]">
            <div className="flex items-center justify-between border-b border-white/5 pb-3">
              <h2 className="text-base font-bold text-white uppercase tracking-wider">Key Details: {selectedResult.keySpec.keyNumber}</h2>
              <button onClick={() => setSelectedResult(null)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            <div className="grid grid-cols-2 gap-4 text-xs font-semibold">
              <div>
                <span className="text-[10px] text-gray-500 uppercase block">Brand Manufacturer</span>
                <span className="text-white">{selectedResult.keySpec.brand}</span>
              </div>
              <div>
                <span className="text-[10px] text-gray-500 uppercase block">Lock Category</span>
                <span className="text-white">{selectedResult.keySpec.category}</span>
              </div>
              <div>
                <span className="text-[10px] text-gray-500 uppercase block">Blank Number Reference</span>
                <span className="text-white">{selectedResult.keySpec.blankNumber}</span>
              </div>
            </div>

            {selectedResult.keySpec.frontImageUrl && (
              <div className="grid grid-cols-2 gap-4 border-t border-white/5 pt-4">
                <div>
                  <span className="text-[10px] text-gray-500 uppercase block mb-1">Front Profile</span>
                  <img src={selectedResult.keySpec.frontImageUrl} alt="Front profile" className="w-full h-32 object-cover rounded-lg border border-white/5" />
                </div>
                <div>
                  <span className="text-[10px] text-gray-500 uppercase block mb-1">Back Profile</span>
                  {selectedResult.keySpec.backImageUrl ? (
                    <img src={selectedResult.keySpec.backImageUrl} alt="Back profile" className="w-full h-32 object-cover rounded-lg border border-white/5" />
                  ) : (
                    <div className="bg-white/2 h-32 rounded-lg border border-dashed border-white/10 flex items-center justify-center text-xs text-gray-500">
                      No Back profile Image
                    </div>
                  )}
                </div>
              </div>
            )}

            {selectedResult.keySpec.description && (
              <div className="border-t border-white/5 pt-4">
                <span className="text-[10px] text-gray-500 uppercase block">Description</span>
                <p className="text-xs text-gray-300 mt-1">"{selectedResult.keySpec.description}"</p>
              </div>
            )}

            {/* ASSOCIATED CUSTOMER REGISTRY SECTION */}
            {selectedResult.customer && (
              <div className="border-t border-primary-500/20 pt-4 space-y-3">
                <h3 className="text-xs font-bold uppercase tracking-wider text-emerald-400">Associated Customer Compliance Record</h3>
                
                {(user?.role === 'SUPER_ADMIN' || selectedResult.customer.shopId === user?.shopId) ? (
                  <>
                    <div className="grid grid-cols-2 gap-4 bg-white/2 border border-white/5 p-3 rounded-xl text-xs font-medium text-gray-300">
                      <div>
                        <span className="text-[9px] text-gray-500 block uppercase font-semibold">Customer Name</span>
                        <span className="text-white font-bold">{selectedResult.customer.name}</span>
                      </div>
                      <div>
                        <span className="text-[9px] text-gray-500 block uppercase font-semibold">Phone Number</span>
                        <span className="text-white font-bold">{selectedResult.customer.phone}</span>
                      </div>
                      <div>
                        <span className="text-[9px] text-gray-500 block uppercase font-semibold">Vehicle Number</span>
                        <span className="text-white font-bold">{selectedResult.customer.vehicleNumber || 'N/A'}</span>
                      </div>
                      <div>
                        <span className="text-[9px] text-gray-500 block uppercase font-semibold">Registry Date</span>
                        <span className="text-white">{new Date(selectedResult.customer.createdAt).toLocaleDateString()}</span>
                      </div>
                    </div>

                    <div className="bg-[#140f29] border border-white/5 p-3 rounded-xl space-y-2 text-xs text-white">
                      <div className="flex items-center justify-between">
                        <div className="flex items-center gap-2">
                          <MapPin className="h-5 w-5 text-emerald-400 shrink-0" />
                          <div>
                            <p className="font-bold text-gray-200">GPS Coordinates</p>
                            <p className="text-[10px] text-gray-500 mt-0.5">Lat: {selectedResult.customer.latitude} • Long: {selectedResult.customer.longitude}</p>
                          </div>
                        </div>
                        <a href={selectedResult.customer.mapsLink} target="_blank" rel="noopener noreferrer" className="text-[10px] text-primary-400 font-bold hover:underline flex items-center gap-1">
                          <span>Google Maps</span><ExternalLink className="h-3 w-3" />
                        </a>
                      </div>
                      {selectedResult.customer.capturedAddress && (
                        <div className="text-[10px] text-gray-400 border-t border-white/5 pt-1.5 pl-7">
                          <span className="block font-semibold text-[8px] text-gray-500 uppercase">Captured Address</span>
                          <span>{selectedResult.customer.capturedAddress}</span>
                        </div>
                      )}
                    </div>

                    <div className="grid grid-cols-2 gap-4">
                      <div>
                        <span className="text-[9px] text-gray-500 uppercase block mb-1 font-semibold">Webcam Snapshot</span>
                        {selectedResult.customer.photoUrl ? (
                          <div className="w-full h-24 rounded-lg bg-white/2 overflow-hidden border border-white/5">
                            <img src={selectedResult.customer.photoUrl} alt="Customer" className="w-full h-full object-cover" />
                          </div>
                        ) : (
                          <div className="w-full h-24 rounded-lg border border-dashed border-white/10 flex items-center justify-center text-xs text-gray-500">No snapshot</div>
                        )}
                      </div>
                      <div>
                        <span className="text-[9px] text-gray-500 uppercase block mb-1 font-semibold">Customer Signature</span>
                        {selectedResult.customer.signatureUrl ? (
                          <div className="w-full h-24 rounded-lg bg-white/5 border border-white/5 p-2 flex items-center justify-center">
                            <img src={selectedResult.customer.signatureUrl} alt="Signature" className="max-h-full max-w-full object-contain" />
                          </div>
                        ) : (
                          <div className="w-full h-24 rounded-lg border border-dashed border-white/10 flex items-center justify-center text-xs text-gray-500">No signature</div>
                        )}
                      </div>
                    </div>
                  </>
                ) : (
                  <div className="space-y-3 bg-[#1e173e]/55 border border-white/10 p-4 rounded-2xl text-xs">
                    <p className="text-[10px] text-primary-400 uppercase tracking-widest font-bold">Registry Location Overview (Other Workspace)</p>
                    
                    <div className="grid grid-cols-2 gap-3.5 mt-2 text-gray-300 font-medium">
                      <div>
                        <span className="text-[9px] text-gray-500 block uppercase font-semibold">Customer Name</span>
                        <span className="text-white font-bold">{selectedResult.customer.name}</span>
                      </div>
                      <div>
                        <span className="text-[9px] text-gray-500 block uppercase font-semibold">Customer Mobile</span>
                        <span className="text-emerald-400 font-mono font-bold">{selectedResult.customer.phone}</span>
                      </div>
                      <div>
                        <span className="text-[9px] text-gray-500 block uppercase font-semibold">Registered Shop</span>
                        <span className="text-white font-bold">{selectedResult.customer.shop?.name || 'KEE Workspace Shop'}</span>
                      </div>
                      <div>
                        <span className="text-[9px] text-gray-500 block uppercase font-semibold">Shop Mobile</span>
                        <span className="text-emerald-400 font-mono font-bold">
                          {(() => {
                            let shopMobile = 'N/A';
                            if (selectedResult.customer.shop) {
                              try {
                                const details = typeof selectedResult.customer.shop.companyDetails === 'string'
                                  ? JSON.parse(selectedResult.customer.shop.companyDetails)
                                  : selectedResult.customer.shop.companyDetails;
                                shopMobile = details?.phone || selectedResult.customer.shop.phone || 'N/A';
                              } catch(e) {
                                shopMobile = selectedResult.customer.shop.phone || 'N/A';
                              }
                            }
                            return shopMobile;
                          })()}
                        </span>
                      </div>
                    </div>
                    <span className="text-[9px] text-gray-500 block italic mt-1 bg-black/20 p-2 rounded-lg border border-white/5">
                      ⚠️ Sensitive coordinates, webcam images, and proof signatures are hidden since this key registration was created in another duplicate key shop.
                    </span>
                  </div>
                )}
              </div>
            )}

            <div className="border-t border-white/5 pt-4 flex justify-end">
              <button onClick={() => setSelectedResult(null)} className="px-4 py-2 border border-white/10 rounded-lg text-xs text-gray-300 hover:bg-white/5">
                Close details
              </button>
            </div>
          </div>
        </div>,
        document.body
      )}
    </div>
  );
}

function CustomerRegistrationWizard({ t, api }) {
  const [step, setStep] = useState(1);
  const [keysList, setKeysList] = useState([]);
  
  // Form fields
  const [name, setName] = useState('');
  const [phone, setPhone] = useState('');
  const [address, setAddress] = useState('N/A');
  const [idProofType, setIdProofType] = useState('Aadhaar Card');
  const [idProofNumber, setIdProofNumber] = useState('N/A');
  const [reason, setReason] = useState('N/A');
  const [keyNumber, setKeyNumber] = useState('');
  const [vehicleNumber, setVehicleNumber] = useState('');
  const [addressLine, setAddressLine] = useState('');
  const [stateVal, setStateVal] = useState('Tamil Nadu');
  const [district, setDistrict] = useState('Chennai');
  const [country, setCountry] = useState('India');
  const [masterKeyId, setMasterKeyId] = useState('');

  // Inline OTP states
  const [otpSent, setOtpSent] = useState(false);
  const [otpVerified, setOtpVerified] = useState(false);
  const [generatedCustomerOtp, setGeneratedCustomerOtp] = useState('');
  const [enteredOtp, setEnteredOtp] = useState('');
  const [otpError, setOtpError] = useState('');
  const [duplicateKeyWarning, setDuplicateKeyWarning] = useState(false);

  // Photos & Signatures (Webcam support)
  const [photoBase64, setPhotoBase64] = useState(null);
  const [signatureBase64, setSignatureBase64] = useState(null);
  const [isWebcamActive, setIsWebcamActive] = useState(false);
  const [webcamStream, setWebcamStream] = useState(null);
  const videoRef = useRef(null);

  // Document Uploads
  const [uploadedDocs, setUploadedDocs] = useState([]);
  const [uploadError, setUploadError] = useState('');

  // GPS Location Status
  const [latitude, setLatitude] = useState(null);
  const [longitude, setLongitude] = useState(null);
  const [gpsTimestamp, setGpsTimestamp] = useState(null);
  const [gpsError, setGpsError] = useState('');
  const [isCapturingGps, setIsCapturingGps] = useState(false);
  const [capturedAddress, setCapturedAddress] = useState('');
  const [isResolvingAddress, setIsResolvingAddress] = useState(false);
  const [isEditingAddress, setIsEditingAddress] = useState(false);

  // Canvas Ref for Signature
  const canvasRef = useRef(null);
  const isDrawing = useRef(false);

  useEffect(() => {
    const fetchKeys = async () => {
      try {
        const res = await api.getMasterKeys();
        setKeysList(res);
        if (res.length > 0) {
          setKeyNumber(res[0].keyNumber);
          setMasterKeyId(res[0].id);
        }
      } catch (e) {
        console.error(e);
      }
    };
    fetchKeys();
  }, []);

  useEffect(() => {
    if (addressLine || district || stateVal) {
      const finalAddress = `${addressLine}, ${district}, ${stateVal}, ${country}`;
      setAddress(finalAddress);
      setCapturedAddress(finalAddress);
    }
  }, [addressLine, district, stateVal, country]);

  const resolveAddress = async (lat, lng) => {
    setIsResolvingAddress(true);
    try {
      const res = await fetch(`https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${lat}&longitude=${lng}&localityLanguage=en`);
      if (res.ok) {
        const data = await res.json();
        const parts = [];
        if (data.locality) parts.push(data.locality);
        if (data.city) parts.push(data.city);
        if (data.principalSubdivision) parts.push(data.principalSubdivision);
        if (data.countryName) parts.push(data.countryName);
        if (parts.length > 0) {
          setCapturedAddress(parts.join(', '));
          setIsResolvingAddress(false);
          return;
        }
      }
    } catch (e) {
      console.warn('BigDataCloud address resolution failed:', e);
    }

    try {
      const res = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`, {
        headers: { 'Accept-Language': 'en' }
      });
      if (res.ok) {
        const data = await res.json();
        if (data.display_name) {
          setCapturedAddress(data.display_name);
          setIsResolvingAddress(false);
          return;
        }
      }
    } catch (e) {
      console.error('Nominatim address resolution failed:', e);
    }

    if (lat === 28.6139 && lng === 77.2090) {
      setCapturedAddress('Connaught Place, New Delhi, India');
    } else {
      setCapturedAddress(`Coordinates: ${lat}, ${lng}`);
    }
    setIsResolvingAddress(false);
  };

  const geocodeManualAddress = async (addrStr) => {
    setIsCapturingGps(true);
    setGpsError('');
    try {
      const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(addrStr)}&limit=1`);
      if (res.ok) {
        const data = await res.json();
        if (data && data.length > 0) {
          const lat = parseFloat(data[0].lat);
          const lng = parseFloat(data[0].lon);
          setLatitude(lat);
          setLongitude(lng);
          setIsCapturingGps(false);
          return;
        }
      }
    } catch (e) {
      console.warn('Geocoding manual address failed:', e);
    }

    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          setLatitude(pos.coords.latitude);
          setLongitude(pos.coords.longitude);
          setIsCapturingGps(false);
        },
        (err) => {
          setLatitude(28.6139);
          setLongitude(77.2090);
          setIsCapturingGps(false);
        }
      );
    } else {
      setLatitude(28.6139);
      setLongitude(77.2090);
      setIsCapturingGps(false);
    }
  };

  useEffect(() => {
    if (step === 5) {
      const finalAddress = `${addressLine}, ${district}, ${stateVal}, India`;
      setCapturedAddress(finalAddress);
      geocodeManualAddress(finalAddress);
    }
  }, [step]);

  const startWebcam = async () => {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } });
      setWebcamStream(stream);
      setIsWebcamActive(true);
      setTimeout(() => {
        if (videoRef.current) {
          videoRef.current.srcObject = stream;
        }
      }, 100);
    } catch (err) {
      alert('Camera access denied or unavailable. Please upload a photo instead.');
    }
  };

  const stopWebcam = () => {
    if (webcamStream) {
      webcamStream.getTracks().forEach(track => track.stop());
      setWebcamStream(null);
    }
    setIsWebcamActive(false);
  };

  const captureSnapshot = () => {
    if (!videoRef.current) return;
    const video = videoRef.current;
    const canvas = document.createElement('canvas');
    canvas.width = video.videoWidth || 640;
    canvas.height = video.videoHeight || 480;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
    const dataUrl = canvas.toDataURL('image/jpeg');
    setPhotoBase64(dataUrl);
    stopWebcam();
  };

  const handlePhotoUpload = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onloadend = () => {
      setPhotoBase64(reader.result);
      stopWebcam();
    };
    reader.readAsDataURL(file);
  };

  useEffect(() => {
    return () => {
      if (webcamStream) {
        webcamStream.getTracks().forEach(track => track.stop());
      }
    };
  }, [webcamStream]);

  useEffect(() => {
    if (step !== 2 && webcamStream) {
      webcamStream.getTracks().forEach(track => track.stop());
      setWebcamStream(null);
      setIsWebcamActive(false);
    }
  }, [step]);

  useEffect(() => {
    if (step === 3 && canvasRef.current) {
      const canvas = canvasRef.current;
      const ctx = canvas.getContext('2d');
      ctx.strokeStyle = '#8C24FF';
      ctx.lineWidth = 2.5;
      ctx.lineCap = 'round';
    }
  }, [step]);

  const startDrawing = (e) => {
    if (e.cancelable) e.preventDefault();
    if (!canvasRef.current) return;
    const canvas = canvasRef.current;
    const ctx = canvas.getContext('2d');
    const rect = canvas.getBoundingClientRect();
    isDrawing.current = true;
    const clientX = e.clientX || (e.touches && e.touches[0] && e.touches[0].clientX) || 0;
    const clientY = e.clientY || (e.touches && e.touches[0] && e.touches[0].clientY) || 0;
    const x = clientX - rect.left;
    const y = clientY - rect.top;
    ctx.beginPath();
    ctx.moveTo(x, y);
  };

  const draw = (e) => {
    if (e.cancelable) e.preventDefault();
    if (!isDrawing.current || !canvasRef.current) return;
    const canvas = canvasRef.current;
    const ctx = canvas.getContext('2d');
    const rect = canvas.getBoundingClientRect();
    const clientX = e.clientX || (e.touches && e.touches[0] && e.touches[0].clientX) || 0;
    const clientY = e.clientY || (e.touches && e.touches[0] && e.touches[0].clientY) || 0;
    const x = clientX - rect.left;
    const y = clientY - rect.top;
    ctx.lineTo(x, y);
    ctx.stroke();
  };

  const stopDrawing = () => { isDrawing.current = false; };
  const clearSignature = () => {
    if (!canvasRef.current) return;
    const canvas = canvasRef.current;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    setSignatureBase64(null);
  };

  const saveSignature = () => {
    if (!canvasRef.current) return;
    setSignatureBase64(canvasRef.current.toDataURL());
  };

  const handleFileChange = (e) => {
    setUploadError('');
    const file = e.target.files[0];
    if (!file) return;

    if (file.size > 5 * 1024 * 1024) {
      setUploadError('File size exceeds the 5MB limit');
      return;
    }

    const allowedTypes = ['image/jpeg', 'image/png', 'application/pdf'];
    if (!allowedTypes.includes(file.type)) {
      setUploadError('Only JPEG, PNG, and PDF document formats are accepted');
      return;
    }

    if (uploadedDocs.some(d => d.type === idProofType)) {
      setUploadError(`Document for ${idProofType} is already staged.`);
      return;
    }

    const newDocs = [...uploadedDocs, { type: idProofType, file }];
    setUploadedDocs(newDocs);

    const remaining = ['Aadhaar Card', 'Driving License', 'PAN Card', 'Voter ID'].filter(
      t => !newDocs.some(d => d.type === t)
    );
    if (remaining.length > 0) {
      setIdProofType(remaining[0]);
    }
  };

  const handleSendOtp = async () => {
    const phoneRegex = /^\+?[0-9\s-]{10,15}$/;
    if (!phone || !phoneRegex.test(phone)) {
      alert('Please enter a valid phone number (10 to 15 digits)');
      return;
    }
    if (!keyNumber) {
      alert('Please enter a key code first');
      return;
    }

    // Duplicate key validation check across current customer registry
    try {
      const allCusts = await api.getCustomers();
      const duplicate = allCusts.find(c => c.keyNumber.toLowerCase() === keyNumber.trim().toLowerCase());
      if (duplicate) {
        setDuplicateKeyWarning(true);
        return;
      }
    } catch (e) {
      console.warn('Duplicate key validation check skipped:', e);
    }

    setDuplicateKeyWarning(false);
    const mockOtp = Math.floor(1000 + Math.random() * 9000).toString();
    setGeneratedCustomerOtp(mockOtp);
    setOtpSent(true);
    setOtpError('');
  };

  const handleVerifyOtp = () => {
    if (enteredOtp === generatedCustomerOtp) {
      setOtpVerified(true);
      setOtpError('');
    } else {
      setOtpError('Invalid OTP code. Please enter the correct code.');
    }
  };

  const handleFinalSubmit = async () => {
    try {
      const finalLat = latitude || 28.6139;
      const finalLng = longitude || 77.2090;

      // Auto-register manual key code in catalog if not found
      let matchKey = keysList.find(k => k.keyNumber.toLowerCase() === keyNumber.toLowerCase());
      let finalMasterKeyId = masterKeyId || null;

      if (!matchKey && keyNumber) {
        try {
          const newKey = await api.createMasterKey({
            keyNumber,
            brand: 'Manual Input',
            category: 'Vehicle Keys',
            blankNumber: keyNumber,
            status: 'ACTIVE'
          });
          finalMasterKeyId = newKey.id;
        } catch (keyErr) {
          console.warn('Failed to auto-register manual key:', keyErr);
        }
      } else if (matchKey) {
        finalMasterKeyId = matchKey.id;
      }

      const customer = await api.createCustomer({
        name, phone, address, idProofType, idProofNumber, reason,
        keyNumber, vehicleNumber, masterKeyId: finalMasterKeyId, 
        latitude: finalLat, 
        longitude: finalLng,
        mapsLink: `https://www.google.com/maps?q=${finalLat},${finalLng}`,
        capturedAddress: capturedAddress || 'Connaught Place, New Delhi, India',
        photoBase64, signatureBase64
      });

      for (const doc of uploadedDocs) {
        await api.uploadDocument(customer.id, doc.type, doc.file);
      }

      alert('Customer compliance record logged successfully!');
      resetWizard();
    } catch (e) {
      alert(`Submission failed: ${e.message}`);
    }
  };

  const resetWizard = () => {
    setName('');
    setPhone('');
    setAddress('N/A');
    setIdProofType('Aadhaar Card');
    setIdProofNumber('N/A');
    setReason('N/A');
    setKeyNumber('');
    setVehicleNumber('');
    setAddressLine('');
    setDistrict('');
    setStateVal('');
    setCountry('India');
    setOtpSent(false);
    setOtpVerified(false);
    setEnteredOtp('');
    setGeneratedCustomerOtp('');
    setDuplicateKeyWarning(false);
    setPhotoBase64(null);
    setSignatureBase64(null);
    setUploadedDocs([]);
    setLatitude(null);
    setLongitude(null);
    setGpsTimestamp(null);
    setGpsError('');
    setCapturedAddress('');
    if (webcamStream) {
      webcamStream.getTracks().forEach(track => track.stop());
    }
    setWebcamStream(null);
    setIsWebcamActive(false);
    setStep(1);
  };

  return (
    <div className="max-w-2xl mx-auto space-y-6 animate-fade-in">
      <div>
        <h1 className="text-2xl font-extrabold tracking-tight">{t('register')}</h1>
        <p className="text-sm text-gray-400 mt-1">Multi-step compliance onboarding wizard.</p>
      </div>

      <div className="flex justify-between items-center bg-[#140f29] p-4 rounded-xl border border-white/5">
        {[
          { label: 'Details', icon: FileText },
          { label: 'Photo', icon: Camera },
          { label: 'Signature', icon: UserCheck },
          { label: 'Documents', icon: Layers },
          { label: 'Review', icon: MapPin }
        ].map((item, i) => {
          const Icon = item.icon;
          const isActive = step === i + 1;
          const isDone = step > i + 1;
          return (
            <div key={item.label} className="flex flex-col items-center gap-1.5 relative z-10 flex-1">
              <div className={`p-2.5 rounded-full border transition flex items-center justify-center ${isActive ? 'bg-primary-500 border-primary-400 text-white shadow-lg' : isDone ? 'bg-emerald-500/20 border-emerald-500/40 text-emerald-400' : 'bg-[#1b1530] border-white/10 text-gray-500'}`}>
                {isDone ? <Check className="h-4 w-4" /> : <Icon className="h-4 w-4" />}
              </div>
              <span className={`text-[10px] font-bold uppercase tracking-wider hidden md:block ${isActive ? 'text-primary-300' : 'text-gray-500'}`}>
                {item.label}
              </span>
            </div>
          );
        })}
      </div>

      {step === 1 && (
        <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-4">
          <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3">Step 1: Contact & Key Credentials</h2>
          
          {duplicateKeyWarning && (
            <div className="bg-red-955/20 border border-red-500/30 p-4 rounded-xl text-xs text-red-200 space-y-2 animate-fade-in">
              <div className="flex gap-2 font-bold text-red-400">
                <AlertTriangle className="h-4 w-4 shrink-0" />
                <span>Validation Failure: Duplicate Key Detected</span>
              </div>
              <p className="pl-6 text-[11px] leading-relaxed text-gray-300">
                This key code (<span className="font-bold text-white">{keyNumber}</span>) is already registered to an existing customer workspace record. Please verify and input a unique key code.
              </p>
            </div>
          )}

          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Full Customer Name</label>
              <input 
                type="text" required value={name} onChange={(e) => setName(e.target.value)} 
                placeholder="Rohan Malhotra" className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white" 
              />
            </div>
            <div>
              <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Vehicle Number</label>
              <input 
                type="text" required value={vehicleNumber} onChange={(e) => setVehicleNumber(e.target.value.toUpperCase())} 
                placeholder="e.g. TN09B1234" className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white" 
              />
            </div>
          </div>

          <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Key Code / Key Number (Manual Entry)</label>
              <input 
                type="text" required value={keyNumber} onChange={(e) => {
                  setKeyNumber(e.target.value);
                  setDuplicateKeyWarning(false);
                }} 
                placeholder="Enter Key Code (e.g. TN09B)" className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white" 
              />
            </div>
            <div>
              <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Phone Number</label>
              <div className="flex gap-2">
                <input 
                  type="tel" required value={phone} onChange={(e) => {
                    setPhone(e.target.value);
                    setOtpVerified(false);
                    setOtpSent(false);
                  }} 
                  placeholder="98765 00000" className="flex-1 glass-input px-3 py-2.5 rounded-xl text-xs text-white" 
                />
                {!otpVerified && (
                  <button 
                    type="button"
                    onClick={handleSendOtp}
                    disabled={!phone || !keyNumber}
                    className="glass-button-primary px-4 py-2.5 rounded-xl text-xs font-semibold text-white whitespace-nowrap disabled:opacity-40"
                  >
                    {otpSent ? 'Resend OTP' : 'Send OTP'}
                  </button>
                )}
              </div>
            </div>
          </div>

          <div className="border-t border-white/5 pt-4 space-y-4">
            <h3 className="text-xs font-bold text-primary-400 uppercase tracking-wider">Manual Address Details</h3>
            
            <div className="grid grid-cols-1 gap-4">
              <div>
                <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Address Line</label>
                <input 
                  type="text" required value={addressLine} 
                  onChange={(e) => setAddressLine(e.target.value)} 
                  placeholder="e.g. Flat 101, Park Avenue" 
                  className="w-full bg-white text-black px-3 py-2.5 rounded-xl text-xs font-semibold focus:outline-none" 
                />
              </div>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">State</label>
                <select 
                  value={stateVal} 
                  onChange={(e) => {
                    const selected = e.target.value;
                    setStateVal(selected);
                    const list = INDIAN_STATES_DISTRICTS[selected] || [];
                    setDistrict(list[0] || '');
                  }} 
                  className="w-full bg-white text-black px-3 py-2.5 rounded-xl text-xs font-semibold focus:outline-none" 
                >
                  {Object.keys(INDIAN_STATES_DISTRICTS).map(st => (
                    <option key={st} value={st}>{st}</option>
                  ))}
                </select>
              </div>
              <div>
                <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">District</label>
                <select 
                  value={district} 
                  onChange={(e) => setDistrict(e.target.value)} 
                  className="w-full bg-white text-black px-3 py-2.5 rounded-xl text-xs font-semibold focus:outline-none" 
                >
                  {(INDIAN_STATES_DISTRICTS[stateVal] || []).map(dt => (
                    <option key={dt} value={dt}>{dt}</option>
                  ))}
                </select>
              </div>
              <div>
                <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Country</label>
                <input 
                  type="text" readOnly value={country} 
                  className="w-full bg-white/20 text-gray-400 border border-white/10 px-3 py-2.5 rounded-xl text-xs cursor-not-allowed font-medium" 
                />
              </div>
            </div>
          </div>

          {otpSent && !otpVerified && (
            <div className="bg-white/2 border border-white/5 p-4 rounded-xl space-y-3 animate-fade-in">
              <div className="flex items-center justify-between text-xs text-gray-300">
                <span>Enter the 4-digit code dispatched to the customer's phone</span>
                <span className="text-[10px] font-mono bg-primary-600/20 text-primary-300 border border-primary-500/20 px-2 py-0.5 rounded font-bold">
                  Demo Code: {generatedCustomerOtp}
                </span>
              </div>
              <div className="flex gap-2 max-w-xs">
                <input 
                  type="text" 
                  maxLength={4}
                  value={enteredOtp} 
                  onChange={(e) => setEnteredOtp(e.target.value.replace(/\D/g, ''))}
                  placeholder="e.g. 1234"
                  className="w-1/2 glass-input px-3 py-2.5 rounded-xl text-xs text-white text-center font-bold tracking-widest"
                />
                <button 
                  type="button" 
                  onClick={handleVerifyOtp}
                  className="w-1/2 bg-[#8C24FF]/30 text-[#DCA2FF] hover:bg-[#8C24FF]/50 border border-[#8C24FF]/20 text-xs px-4 py-2.5 rounded-xl font-bold"
                >
                  Verify OTP
                </button>
              </div>
              {otpError && <p className="text-red-400 text-[10px] font-semibold">{otpError}</p>}
            </div>
          )}

          {otpVerified && (
            <div className="bg-emerald-950/20 border border-emerald-500/20 p-3 rounded-xl flex items-center gap-2 text-xs text-emerald-300 animate-fade-in">
              <Check className="h-4 w-4 text-emerald-400" />
              <span>Customer Phone Number OTP Verified Successfully!</span>
            </div>
          )}

          <div className="flex justify-end pt-4 border-t border-white/5">
            <button 
              disabled={!name || !phone || !keyNumber || !vehicleNumber || !otpVerified || !addressLine || !district || !stateVal || duplicateKeyWarning} 
              onClick={() => setStep(2)} 
              className="glass-button-primary px-5 py-2.5 rounded-xl text-xs font-semibold text-white disabled:opacity-40"
            >
              Continue
            </button>
          </div>
        </div>
      )}

      {step === 2 && (
        <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-4">
          <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3">Step 2: Customer Identity Snapshot</h2>
          <div className="flex flex-col items-center space-y-4 py-4">
            <div className="w-64 h-48 rounded-2xl overflow-hidden bg-white/2 border border-white/10 flex items-center justify-center relative">
              {isWebcamActive ? (
                <video ref={videoRef} autoPlay playsInline className="w-full h-full object-cover" />
              ) : photoBase64 ? (
                <img src={photoBase64} alt="Identity preview" className="w-full h-full object-cover" />
              ) : (
                <Camera className="h-10 w-10 text-gray-500" />
              )}
            </div>

            <div className="flex flex-wrap gap-2 justify-center">
              {isWebcamActive ? (
                <>
                  <button 
                    onClick={captureSnapshot} 
                    className="bg-emerald-600/30 hover:bg-emerald-600/50 border border-emerald-500/20 text-emerald-300 text-xs px-4 py-2 rounded-xl transition font-semibold"
                  >
                    Capture Photo
                  </button>
                  <button 
                    onClick={stopWebcam} 
                    className="bg-red-600/20 hover:bg-red-600/30 border border-red-500/20 text-red-300 text-xs px-4 py-2 rounded-xl transition font-semibold"
                  >
                    Stop Camera
                  </button>
                </>
              ) : (
                <>
                  <button 
                    onClick={startWebcam} 
                    className="bg-primary-600/30 hover:bg-primary-600/50 border border-primary-500/20 text-primary-300 text-xs px-4 py-2 rounded-xl transition font-semibold"
                  >
                    {photoBase64 ? 'Re-take Photo (Webcam)' : 'Start Webcam / Mobile Cam'}
                  </button>
                  
                  <label className="cursor-pointer bg-white/5 hover:bg-white/10 border border-white/10 text-xs px-4 py-2 rounded-xl transition font-semibold text-white flex items-center justify-center gap-1.5">
                    <Upload className="h-3.5 w-3.5 text-primary-400" />
                    <span>Upload Image</span>
                    <input 
                      type="file" accept="image/*" className="hidden" 
                      onChange={handlePhotoUpload} 
                    />
                  </label>
                </>
              )}
            </div>
          </div>
          <div className="flex justify-between pt-4 border-t border-white/5">
            <button onClick={() => setStep(1)} className="px-4 py-2.5 border border-white/10 rounded-xl text-xs text-gray-300 hover:bg-white/5">Back</button>
            <button disabled={!photoBase64} onClick={() => setStep(3)} className="glass-button-primary px-5 py-2.5 rounded-xl text-xs font-semibold text-white disabled:opacity-45">Continue</button>
          </div>
        </div>
      )}

      {step === 3 && (
        <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-4">
          <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3">Step 3: Signature Verification Pad</h2>
          <div className="space-y-4 flex flex-col items-center">
            {signatureBase64 ? (
              <div className="bg-white/5 p-4 rounded-xl border border-white/10 w-full max-w-sm h-32 flex items-center justify-center">
                <img src={signatureBase64} alt="Signature preview" className="h-full max-w-full object-contain" />
              </div>
            ) : (
              <div className="w-full max-w-sm">
                <canvas ref={canvasRef} width={384} height={150} onMouseDown={startDrawing} onMouseMove={draw} onMouseUp={stopDrawing} onMouseLeave={stopDrawing} onTouchStart={startDrawing} onTouchMove={draw} onTouchEnd={stopDrawing} className="signature-canvas-container w-full h-[150px] bg-white/2" />
              </div>
            )}
            <div className="flex gap-2">
              {!signatureBase64 ? (
                <>
                  <button onClick={clearSignature} className="bg-white/5 hover:bg-white/10 text-xs px-3 py-1.5 rounded-lg border border-white/10 text-white">Clear</button>
                  <button onClick={saveSignature} className="bg-primary-600/30 text-primary-300 text-xs px-3 py-1.5 rounded-lg border border-primary-500/20 font-bold hover:bg-primary-600/50">Lock Signature</button>
                </>
              ) : (
                <button onClick={() => setSignatureBase64(null)} className="bg-white/5 hover:bg-white/10 text-xs px-3 py-1.5 rounded-lg border border-white/10 text-white flex items-center gap-1.5"><RotateCcw className="h-3 w-3" /> Re-draw</button>
              )}
            </div>
          </div>
          <div className="flex justify-between pt-4 border-t border-white/5">
            <button onClick={() => setStep(2)} className="px-4 py-2.5 border border-white/10 rounded-xl text-xs text-gray-300 hover:bg-white/5">Back</button>
            <button 
              onClick={() => {
                if (!signatureBase64 && canvasRef.current) {
                  setSignatureBase64(canvasRef.current.toDataURL());
                }
                setStep(4);
              }} 
              className="glass-button-primary px-5 py-2.5 rounded-xl text-xs font-semibold text-white"
            >
              Continue
            </button>
          </div>
        </div>
      )}

      {step === 4 && (
        <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-4">
          <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3">Step 4: Compliance Document Upload</h2>
          
          <div>
            <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Document Type</label>
            <select 
              value={idProofType} onChange={(e) => setIdProofType(e.target.value)}
              className="w-full bg-[#1b1530] border border-white/10 rounded-xl px-3 py-2.5 text-xs text-white focus:outline-none focus:ring-2 focus:ring-primary-500 font-bold"
            >
              <option value="Aadhaar Card" disabled={uploadedDocs.some(d => d.type === 'Aadhaar Card')}>Aadhaar Card</option>
              <option value="Driving License" disabled={uploadedDocs.some(d => d.type === 'Driving License')}>Driving License</option>
              <option value="PAN Card" disabled={uploadedDocs.some(d => d.type === 'PAN Card')}>PAN Card</option>
              <option value="Voter ID" disabled={uploadedDocs.some(d => d.type === 'Voter ID')}>Voter ID</option>
            </select>
          </div>

          <div className="bg-white/2 p-4 rounded-xl border border-dashed border-white/10 flex flex-col items-center justify-center py-8">
            <Layers className="h-10 w-10 text-gray-500 mb-2" />
            <p className="text-xs text-gray-300 text-center">Drag & drop copy of <span className="font-bold text-primary-300">{idProofType}</span></p>
            <input type="file" id="docUploadInput" onChange={handleFileChange} className="hidden" accept="image/jpeg, image/png, application/pdf" />
            <label htmlFor="docUploadInput" className="mt-4 px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl text-xs text-gray-200 cursor-pointer font-semibold">Browse Files</label>
          </div>
          {uploadError && <div className="text-red-400 text-xs text-center">{uploadError}</div>}
          
          {uploadedDocs.length > 0 && (
            <div className="space-y-2 mt-4">
              <p className="text-[10px] text-gray-500 uppercase font-semibold">Staged ID Copies ({uploadedDocs.length})</p>
              {uploadedDocs.map((doc, idx) => (
                <div key={idx} className="bg-[#140f29] p-3 rounded-xl border border-white/5 flex items-center justify-between text-xs text-white">
                  <span className="font-semibold text-primary-300">{doc.type}</span>
                  <span className="text-gray-400 truncate max-w-[150px]">{doc.file.name}</span>
                  <button 
                    type="button" 
                    onClick={() => {
                      setUploadedDocs(uploadedDocs.filter((_, i) => i !== idx));
                    }} 
                    className="text-red-400 hover:text-red-300"
                  >
                    <X className="h-4 w-4" />
                  </button>
                </div>
              ))}
            </div>
          )}
          <div className="flex justify-between pt-4 border-t border-white/5">
            <button onClick={() => setStep(3)} className="px-4 py-2.5 border border-white/10 rounded-xl text-xs text-gray-300 hover:bg-white/5">Back</button>
            <button onClick={() => setStep(5)} className="glass-button-primary px-5 py-2.5 rounded-xl text-xs font-semibold text-white">Continue</button>
          </div>
        </div>
      )}

      {step === 5 && (
        <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-4">
          <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3">Step 5: Review Compliance Record</h2>
          <div className="grid grid-cols-2 gap-4 text-xs font-medium border-b border-white/5 pb-4 text-gray-300">
            <div><span className="text-[10px] text-gray-500 block uppercase">Customer</span>{name}</div>
            <div><span className="text-[10px] text-gray-500 block uppercase">Phone</span>{phone}</div>
            <div><span className="text-[10px] text-gray-500 block uppercase">Vehicle Number</span>{vehicleNumber}</div>
            <div><span className="text-[10px] text-gray-500 block uppercase">Key Blank</span>{keyNumber}</div>
            <div className="col-span-2"><span className="text-[10px] text-gray-500 block uppercase">Registered Address</span>{addressLine}, {district}, {stateVal}, India</div>
          </div>
          <div className="space-y-3 pt-2">
            <span className="text-[10px] text-gray-500 uppercase block font-semibold">Automatic GPS Compliance Stamp</span>
            {isCapturingGps ? (
              <div className="flex gap-2 items-center text-xs text-gray-400 bg-white/2 p-3 rounded-xl border border-white/5"><RefreshCw className="h-4 w-4 animate-spin text-primary-400" />Locating...</div>
            ) : gpsError ? (
              <div className="bg-amber-950/25 border border-amber-500/20 p-3 rounded-xl space-y-2 text-xs text-amber-300">
                <p>{gpsError}</p>
                <div className="grid grid-cols-2 gap-2">
                  <input type="number" step="0.0001" placeholder="Lat" value={latitude || ''} onChange={(e) => {
                    const lat = Number(e.target.value);
                    setLatitude(lat);
                    if (longitude) resolveAddress(lat, longitude);
                  }} className="w-full glass-input px-2 py-1 rounded-lg text-xs" />
                  <input type="number" step="0.0001" placeholder="Lng" value={longitude || ''} onChange={(e) => {
                    const lng = Number(e.target.value);
                    setLongitude(lng);
                    if (latitude) resolveAddress(latitude, lng);
                  }} className="w-full glass-input px-2 py-1 rounded-lg text-xs" />
                </div>
                {isResolvingAddress ? (
                  <p className="text-[10px] text-gray-400 italic pt-1">Resolving address...</p>
                ) : (
                  capturedAddress && <p className="text-[10px] text-gray-300 italic pt-1">Resolved: {capturedAddress}</p>
                )}
              </div>
            ) : (
              <div className="bg-[#140f29] border border-white/5 p-3 rounded-xl space-y-2 text-xs text-white">
                <div className="flex items-center justify-between">
                  <span>GPS Stamped • Lat: {latitude} • Long: {longitude}</span>
                  <div className="flex items-center gap-2">
                    <button 
                      type="button" 
                      onClick={() => setIsEditingAddress(!isEditingAddress)} 
                      className="text-[9px] text-primary-400 hover:text-primary-300 font-bold uppercase underline"
                    >
                      {isEditingAddress ? 'Done' : 'Edit Location'}
                    </button>
                    <span className="text-[9px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded font-bold">Secured</span>
                  </div>
                </div>
                {isResolvingAddress ? (
                  <div className="flex items-center gap-1.5 text-[10px] text-gray-400"><RefreshCw className="h-3 w-3 animate-spin text-emerald-400" /> Resolving address...</div>
                ) : (
                  <div>
                    {isEditingAddress ? (
                      <textarea
                        value={capturedAddress}
                        onChange={(e) => setCapturedAddress(e.target.value)}
                        className="w-full bg-white border border-gray-300 rounded-lg p-2 text-xs text-black mt-1 focus:outline-none focus:ring-2 focus:ring-primary-500"
                        placeholder="Enter manual address details..."
                        rows={2}
                      />
                    ) : (
                      capturedAddress && (
                        <div className="text-[10px] text-gray-400 border-t border-white/5 pt-1.5 flex gap-1.5 items-start">
                          <MapPin className="h-3.5 w-3.5 text-emerald-400 shrink-0 mt-0.5" />
                          <span>{capturedAddress}</span>
                        </div>
                      )
                    )}
                  </div>
                )}
              </div>
            )}
          </div>
          <div className="flex justify-between pt-4 border-t border-white/5">
            <button onClick={() => setStep(4)} className="px-4 py-2.5 border border-white/10 rounded-xl text-xs text-gray-300 hover:bg-white/5">Back</button>
            <button 
              disabled={isCapturingGps}
              onClick={handleFinalSubmit} 
              className="glass-button-primary px-5 py-2.5 rounded-xl text-xs font-semibold text-white flex items-center gap-2 disabled:opacity-40"
            >
              {isCapturingGps ? (
                <>
                  <RefreshCw className="h-4 w-4 animate-spin" />
                  <span>GPS Locating...</span>
                </>
              ) : (
                <>
                  <span>Submit Compliance Stencil</span>
                  <UserCheck className="h-4 w-4" />
                </>
              )}
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

// ============================================================================
// COMPONENT 10: CUSTOMER HISTORY LOOKUP (SHOP ADMIN ONLY)
// ============================================================================
function CustomerHistoryView({ t, api }) {
  const [customers, setCustomers] = useState([]);
  const [loading, setLoading] = useState(false);
  const [search, setSearch] = useState('');
  const [selectedCust, setSelectedCust] = useState(null);

  // Edit States
  const [isEditing, setIsEditing] = useState(false);
  const [editName, setEditName] = useState('');
  const [editPhoneVal, setEditPhoneVal] = useState('');
  const [editVehicleNumber, setEditVehicleNumber] = useState('');
  const [editKeyNumber, setEditKeyNumber] = useState('');
  const [editAddressLine, setEditAddressLine] = useState('');
  const [editDistrict, setEditDistrict] = useState('');
  const [editStateVal, setEditStateVal] = useState('');
  const [editIdProofType, setEditIdProofType] = useState('Aadhaar Card');
  const [editIdProofNumber, setEditIdProofNumber] = useState('');
  const [editReason, setEditReason] = useState('');
  const [editUploadFile, setEditUploadFile] = useState(null);

  useEffect(() => {
    if (selectedCust) {
      setEditName(selectedCust.name || '');
      setEditPhoneVal(selectedCust.phone || '');
      setEditVehicleNumber(selectedCust.vehicleNumber || '');
      setEditKeyNumber(selectedCust.keyNumber || '');
      const remainingEditTypes = ['Aadhaar Card', 'Driving License', 'PAN Card', 'Voter ID'].filter(
        t => !selectedCust.documents?.some(d => d.documentType === t || d.documentType === `${t} Copy`)
      );
      if (remainingEditTypes.length > 0) {
        setEditIdProofType(remainingEditTypes[0]);
      } else {
        setEditIdProofType(selectedCust.idProofType || 'Aadhaar Card');
      }
      setEditIdProofNumber(selectedCust.idProofNumber || '');
      setEditReason(selectedCust.reason || '');
      
      const addr = selectedCust.capturedAddress || selectedCust.address || '';
      const parts = addr.split(',').map(p => p.trim());
      setEditAddressLine(parts[0] || '');
      setEditDistrict(parts[1] || '');
      setEditStateVal(parts[2] || '');
    } else {
      setIsEditing(false);
      setEditUploadFile(null);
    }
  }, [selectedCust]);

  useEffect(() => {
    fetchHistory();
  }, [search]);

  const fetchHistory = async () => {
    setLoading(true);
    try {
      const res = await api.getCustomers(search);
      setCustomers(res);
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  const handleSaveChanges = async (e) => {
    e.preventDefault();
    const phoneRegex = /^\+?[0-9\s-]{10,15}$/;
    if (!editPhoneVal || !phoneRegex.test(editPhoneVal)) {
      alert('Please enter a valid phone number (10 to 15 digits)');
      return;
    }
    try {
      const finalAddress = `${editAddressLine}, ${editDistrict}, ${editStateVal}, India`;
      await api.updateCustomer(selectedCust.id, {
        name: editName,
        phone: editPhoneVal,
        address: finalAddress,
        idProofType: editIdProofType,
        idProofNumber: editIdProofNumber,
        reason: editReason,
        keyNumber: editKeyNumber,
        vehicleNumber: editVehicleNumber,
        capturedAddress: finalAddress
      });

      if (editUploadFile) {
        await api.uploadDocument(selectedCust.id, `${editIdProofType} Copy`, editUploadFile);
      }

      alert('Customer compliance record updated successfully!');
      setIsEditing(false);
      setEditUploadFile(null);
      setSelectedCust(null);
      fetchHistory();
    } catch (err) {
      alert(err.message || 'Failed to save customer edits.');
    }
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div>
        <h1 className="text-2xl font-extrabold tracking-tight">{t('history')}</h1>
        <p className="text-sm text-gray-400 mt-1">Search and verify past compliance registry submissions.</p>
      </div>

      <div className="glass-panel p-4 rounded-2xl flex items-center gap-3">
        <Search className="h-5 w-5 text-primary-400 shrink-0" />
        <input 
          type="text" value={search} onChange={(e) => setSearch(e.target.value)}
          placeholder="Filter compliance records by name, phone number, key code..."
          className="w-full bg-transparent border-none outline-none text-sm placeholder:text-gray-500 text-white"
        />
      </div>

      {loading ? (
        <div className="flex h-48 items-center justify-center">
          <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
        </div>
      ) : (
        <div className="glass-panel rounded-2xl overflow-hidden shadow-xl border border-white/5">
          <table className="w-full text-left text-xs border-collapse">
            <thead>
              <tr className="bg-white/5 text-gray-400 border-b border-white/5 uppercase font-bold tracking-wider">
                <th className="p-4">Customer Name</th>
                <th className="p-4">Phone Number</th>
                <th className="p-4">Vehicle Number</th>
                <th className="p-4">Key Code</th>
                <th className="p-4">Location</th>
                <th className="p-4">Logged Date</th>
                <th className="p-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-white/5 font-medium text-gray-200">
              {customers.map(c => (
                <tr key={c.id} onClick={() => setSelectedCust(c)} className="hover:bg-white/2 cursor-pointer transition">
                  <td className="p-4 font-bold text-white">{c.name}</td>
                  <td className="p-4">{c.phone}</td>
                  <td className="p-4">{c.vehicleNumber || 'N/A'}</td>
                  <td className="p-4 font-mono font-bold text-primary-300">{c.keyNumber}</td>
                  <td className="p-4 text-gray-400 max-w-xs truncate">
                    <span className="flex items-center gap-1">
                      <MapPin className="h-3.5 w-3.5 text-emerald-400 shrink-0" />
                      <span className="truncate">{c.capturedAddress || 'N/A'}</span>
                    </span>
                  </td>
                  <td className="p-4 text-gray-400">{new Date(c.createdAt).toLocaleDateString()}</td>
                  <td className="p-4 text-right text-primary-400">View file</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {selectedCust && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/60 backdrop-blur-sm flex justify-center p-4 md:p-10">
          <div className="glass-panel w-full max-w-lg rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4 bg-[#100c25]">
            <div className="flex items-center justify-between border-b border-white/5 pb-3">
              <h2 className="text-base font-bold text-white uppercase tracking-wider">Compliance File: {selectedCust.name}</h2>
              <button onClick={() => setSelectedCust(null)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            {!isEditing ? (
              <>
                <div className="grid grid-cols-2 gap-4 text-xs font-semibold text-gray-300">
                  <div>
                    <span className="text-[10px] text-gray-500 block">Phone Contact</span>
                    <span className="text-white">{selectedCust.phone}</span>
                  </div>
                  <div>
                    <span className="text-[10px] text-gray-500 block">Registry Date</span>
                    <span className="text-white">{new Date(selectedCust.createdAt).toLocaleString()}</span>
                  </div>
                  <div>
                    <span className="text-[10px] text-gray-500 block">Vehicle Number</span>
                    <span className="text-white">{selectedCust.vehicleNumber || 'N/A'}</span>
                  </div>
                  <div>
                    <span className="text-[10px] text-gray-500 block">Key Blank Code</span>
                    <span className="text-white font-mono font-bold text-primary-300">{selectedCust.keyNumber}</span>
                  </div>
                </div>

                <div className="bg-[#140f29] border border-white/5 p-3 rounded-xl space-y-2 mt-2 text-xs text-white">
                  <div className="flex items-center justify-between">
                    <div className="flex items-center gap-2">
                      <MapPin className="h-5 w-5 text-emerald-400 shrink-0" />
                      <div>
                        <p className="font-bold text-gray-200">GPS Coordinates</p>
                        <p className="text-[10px] text-gray-500 mt-0.5">Lat: {selectedCust.latitude} • Long: {selectedCust.longitude}</p>
                      </div>
                    </div>
                    <a href={selectedCust.mapsLink} target="_blank" rel="noopener noreferrer" className="text-[10px] text-primary-400 font-bold hover:underline flex items-center gap-1">
                      <span>Google Maps</span><ExternalLink className="h-3 w-3" />
                    </a>
                  </div>
                  {selectedCust.capturedAddress && (
                    <div className="text-[10px] text-gray-400 border-t border-white/5 pt-1.5 pl-7">
                      <span className="block font-semibold text-[8px] text-gray-500 uppercase">Captured Address</span>
                      <span>{selectedCust.capturedAddress}</span>
                    </div>
                  )}
                </div>

                <div className="grid grid-cols-2 gap-4 border-t border-white/5 pt-4">
                  <div>
                    <span className="text-[10px] text-gray-500 uppercase block mb-1">Webcam Photo</span>
                    {selectedCust.photoUrl ? (
                      <div className="w-full h-32 rounded-lg bg-white/2 overflow-hidden border border-white/5">
                        <img src={selectedCust.photoUrl} alt="Customer snapshot" className="w-full h-full object-cover" />
                      </div>
                    ) : (
                      <div className="w-full h-32 rounded-lg border border-dashed border-white/10 flex items-center justify-center text-xs text-gray-500">No snapshot</div>
                    )}
                  </div>
                  <div>
                    <span className="text-[10px] text-gray-500 uppercase block mb-1">Customer Signature</span>
                    {selectedCust.signatureUrl ? (
                      <div className="w-full h-32 rounded-lg bg-white/5 border border-white/5 p-3 flex items-center justify-center">
                        <img src={selectedCust.signatureUrl} alt="Signature drawing" className="max-h-full max-w-full object-contain" />
                      </div>
                    ) : (
                      <div className="w-full h-32 rounded-lg border border-dashed border-white/10 flex items-center justify-center text-xs text-gray-500">No signature</div>
                    )}
                  </div>
                </div>

                {selectedCust.documents && selectedCust.documents.length > 0 && (
                  <div className="border-t border-white/5 pt-4 space-y-2">
                    <span className="text-[10px] text-gray-500 uppercase block font-semibold">Attached ID Copies</span>
                    {selectedCust.documents.map(d => (
                      <div key={d.id} className="bg-white/2 border border-white/5 p-2 rounded-xl flex items-center justify-between text-xs text-white">
                        <span>{d.documentType} ({d.fileKey})</span>
                        <button 
                          onClick={() => {
                            const link = document.createElement('a');
                            link.href = d.fileUrl;
                            link.download = d.fileKey || 'document';
                            link.target = '_blank';
                            document.body.appendChild(link);
                            link.click();
                            document.body.removeChild(link);
                          }} 
                          className="text-[10px] font-bold text-primary-400 hover:underline"
                        >
                          Download
                        </button>
                      </div>
                    ))}
                  </div>
                )}
              </>
            ) : (
              <form onSubmit={handleSaveChanges} className="space-y-4">
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Full Customer Name</label>
                    <input 
                      type="text" required value={editName} onChange={(e) => setEditName(e.target.value)} 
                      className="w-full bg-white text-black px-3 py-2 rounded-xl text-xs font-semibold focus:outline-none" 
                    />
                  </div>
                  <div>
                    <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Phone Number</label>
                    <input 
                      type="tel" required value={editPhoneVal} onChange={(e) => setEditPhoneVal(e.target.value)} 
                      className="w-full bg-white text-black px-3 py-2 rounded-xl text-xs font-semibold focus:outline-none" 
                    />
                  </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Vehicle Number</label>
                    <input 
                      type="text" required value={editVehicleNumber} onChange={(e) => setEditVehicleNumber(e.target.value.toUpperCase())} 
                      className="w-full bg-white text-black px-3 py-2 rounded-xl text-xs font-semibold focus:outline-none" 
                    />
                  </div>
                  <div>
                    <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Key Blank Code</label>
                    <input 
                      type="text" required value={editKeyNumber} onChange={(e) => setEditKeyNumber(e.target.value)} 
                      className="w-full bg-white text-black px-3 py-2 rounded-xl text-xs font-semibold focus:outline-none" 
                    />
                  </div>
                </div>

                <div className="border-t border-white/5 pt-3 space-y-3">
                  <h3 className="text-xs font-bold text-primary-400 uppercase tracking-wider">Manual Address Details</h3>
                  
                  <div>
                    <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Address Line</label>
                    <input 
                      type="text" required value={editAddressLine} onChange={(e) => setEditAddressLine(e.target.value)} 
                      className="w-full bg-white text-black px-3 py-2 rounded-xl text-xs font-semibold focus:outline-none" 
                    />
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                      <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">District</label>
                      <input 
                        type="text" required value={editDistrict} onChange={(e) => setEditDistrict(e.target.value)} 
                        className="w-full bg-white text-black px-3 py-2 rounded-xl text-xs font-semibold focus:outline-none" 
                      />
                    </div>
                    <div>
                      <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">State</label>
                      <input 
                        type="text" required value={editStateVal} onChange={(e) => setEditStateVal(e.target.value)} 
                        className="w-full bg-white text-black px-3 py-2 rounded-xl text-xs font-semibold focus:outline-none" 
                      />
                    </div>
                    <div>
                      <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Country</label>
                      <input 
                        type="text" readOnly value="India" 
                        className="w-full bg-white/20 text-gray-400 border border-white/10 px-3 py-2 rounded-xl text-xs cursor-not-allowed font-medium" 
                      />
                    </div>
                  </div>
                </div>

                <div className="border-t border-white/5 pt-3 space-y-3">
                  <h3 className="text-xs font-bold text-primary-400 uppercase tracking-wider">Update ID Verification Document</h3>
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Document ID Type</label>
                      <select 
                        value={editIdProofType} onChange={(e) => setEditIdProofType(e.target.value)}
                        className="w-full bg-[#1b1530] border border-white/10 rounded-xl px-3 py-2 text-xs text-white focus:outline-none"
                      >
                        <option value="Aadhaar Card" disabled={selectedCust?.documents?.some(d => d.documentType === 'Aadhaar Card' || d.documentType === 'Aadhaar Card Copy')}>Aadhaar Card</option>
                        <option value="Driving License" disabled={selectedCust?.documents?.some(d => d.documentType === 'Driving License' || d.documentType === 'Driving License Copy')}>Driving License</option>
                        <option value="PAN Card" disabled={selectedCust?.documents?.some(d => d.documentType === 'PAN Card' || d.documentType === 'PAN Card Copy')}>PAN Card</option>
                        <option value="Voter ID" disabled={selectedCust?.documents?.some(d => d.documentType === 'Voter ID' || d.documentType === 'Voter ID Copy')}>Voter ID</option>
                      </select>
                    </div>
                    <div>
                      <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Upload New File Copy</label>
                      <input 
                        type="file" 
                        onChange={(e) => setEditUploadFile(e.target.files[0])}
                        accept="image/jpeg, image/png, application/pdf"
                        className="w-full text-xs text-gray-400 file:mr-4 file:py-1.5 file:px-3 file:rounded-xl file:border-0 file:text-[10px] file:font-semibold file:bg-white/5 file:text-white hover:file:bg-white/10" 
                      />
                    </div>
                  </div>
                </div>

                <div className="flex justify-end gap-2 pt-2">
                  <button 
                    type="button" 
                    onClick={() => {
                      setIsEditing(false);
                      setEditUploadFile(null);
                    }} 
                    className="px-4 py-2 border border-white/10 rounded-xl text-xs text-gray-300 hover:bg-white/5"
                  >
                    Cancel
                  </button>
                  <button 
                    type="submit" 
                    className="glass-button-primary px-5 py-2 rounded-xl text-xs font-semibold text-white"
                  >
                    Save Changes
                  </button>
                </div>
              </form>
            )}

            <div className="border-t border-white/5 pt-4 flex justify-end gap-3">
              {!isEditing && (
                <button 
                  onClick={() => setIsEditing(true)} 
                  className="glass-button-primary px-4 py-2 rounded-lg text-xs text-white font-semibold"
                >
                  Edit Details
                </button>
              )}
              {!isEditing && (
                <button onClick={() => setSelectedCust(null)} className="px-4 py-2 border border-white/10 rounded-lg text-xs text-gray-300 hover:bg-white/5">Close File</button>
              )}
            </div>
          </div>
        </div>,
        document.body
      )}
    </div>
  );
}

// ============================================================================
// COMPONENT 11: PLATFORM SUPPLY STORE PAGE (SHOP ADMIN E-COMMERCE)
// ============================================================================
function PlatformStoreView({ t, api }) {
  const [products, setProducts] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetchProducts();
  }, []);

  const fetchProducts = async () => {
    setLoading(true);
    try {
      const res = await api.getProducts();
      setProducts(res.filter(p => p.status === 'ACTIVE'));
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div>
        <h1 className="text-2xl font-extrabold tracking-tight">Wholesale Supply Store Catalogue</h1>
        <p className="text-sm text-gray-400 mt-1">Browse wholesale key blanks, milling machinery, and tools. Contact distributors directly to order.</p>
      </div>

      {loading ? (
        <div className="flex h-48 items-center justify-center">
          <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
        </div>
      ) : (
        <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
          {products.map(p => (
            <div key={p.id} className="glass-panel rounded-2xl overflow-hidden flex flex-col justify-between border border-white/5 shadow-lg bg-[#140e2b]/40">
              <img src={p.imageUrl} alt={p.name} className="w-full h-32 object-cover opacity-80" />
              <div className="p-4 flex-1 flex flex-col justify-between space-y-3">
                <div>
                  <span className="text-[9px] uppercase tracking-wider bg-primary-600/20 text-primary-300 px-2 py-0.5 border border-primary-500/25 rounded font-bold">
                    {p.category}
                  </span>
                  <h3 className="font-bold text-sm text-white mt-1.5 leading-snug">{p.name}</h3>
                  <p className="text-[11px] text-gray-400 mt-1 italic">"{p.description}"</p>
                </div>

                <div className="flex justify-between items-center text-xs border-t border-white/5 pt-3">
                  <div>
                    {p.discountPercentage > 0 ? (
                      <div className="flex flex-col">
                        <span className="text-gray-500 text-[10px] line-through leading-none">Rs. {p.price.toFixed(2)}</span>
                        <div className="flex items-center gap-1.5 mt-0.5">
                          <span className="text-emerald-400 text-sm font-extrabold font-mono">Rs. {(p.offerPrice || p.price).toFixed(2)}</span>
                          <span className="bg-emerald-500/10 text-emerald-400 border border-emerald-500/25 px-1 py-0.5 rounded text-[8px] font-bold leading-none">{p.discountPercentage}% OFF</span>
                        </div>
                      </div>
                    ) : (
                      <span className="text-emerald-400 text-sm font-extrabold font-mono">Rs. {p.price.toFixed(2)}</span>
                    )}
                  </div>
                  <span className={`text-[10px] font-bold ${p.stock === 0 ? 'text-red-400' : 'text-gray-500'}`}>
                    {p.stock === 0 ? 'Out of Stock' : `Stock: ${p.stock}`}
                  </span>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

// ============================================================================
// COMPONENT 11.5: CUSTOMER CARE VIEW (SUPPORT & SKILLS TRAINING)
// ============================================================================
export function CustomerCareView({ t, api }) {
  const [config, setConfig] = useState(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    fetchConfig();
  }, []);

  const fetchConfig = async () => {
    try {
      const res = await api.getSupportConfig();
      setConfig(res);
    } catch (e) {
      console.error('Failed to load support config:', e);
    } finally {
      setLoading(false);
    }
  };

  const getYoutubeThumbnailAndId = (url) => {
    if (!url) return { id: null, thumbnail: 'https://images.unsplash.com/photo-1619542402915-dcaf30e4e2a1?w=300&q=80' };
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
    const match = url.match(regExp);
    const videoId = (match && match[2].length === 11) ? match[2] : null;
    return {
      id: videoId,
      thumbnail: videoId ? `https://img.youtube.com/vi/${videoId}/mqdefault.jpg` : 'https://images.unsplash.com/photo-1619542402915-dcaf30e4e2a1?w=300&q=80'
    };
  };

  if (loading) {
    return (
      <div className="flex h-64 items-center justify-center">
        <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
      </div>
    );
  }

  const whatsapp = config?.whatsapp || '+91 98765 43210';
  const cleanPhone = whatsapp.replace(/[^0-9]/g, '');

  return (
    <div className="space-y-6 animate-fade-in text-white">
      <div>
        <h1 className="text-2xl font-extrabold tracking-tight">Customer Care Support</h1>
        <p className="text-sm text-gray-400 mt-1">Get locksmith training resources and connect directly with KEE Technical Support.</p>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        {/* Support Card */}
        <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-6 bg-white/2 flex flex-col justify-between">
          <div className="space-y-2">
            <h2 className="text-sm font-bold uppercase tracking-wider text-primary-300 flex items-center gap-2">
              <Phone className="h-4 w-4" />
              <span>Contact Live Agent & Support</span>
            </h2>
            <p className="text-xs text-gray-400">Live customer support is available Monday to Saturday (9 AM - 7 PM IST) to help you with your key-making machines or duplicate key portal dashboard.</p>
          </div>

          <div className="bg-[#075e54]/20 border border-[#25d366]/30 p-5 rounded-2xl flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
              <span className="text-[10px] text-gray-400 block uppercase font-bold tracking-wider">Direct WhatsApp Support</span>
              <span className="text-white font-bold text-base">{whatsapp}</span>
            </div>
            <a 
              href={`https://wa.me/${cleanPhone || '919876543210'}?text=Hi%20KEE%20Support%2C%20I%20have%20a%20question%20regarding%20my%20duplicate%20key%20shop%20platform.`} 
              target="_blank" 
              rel="noreferrer"
              className="bg-[#25d366] hover:bg-[#20ba5a] text-black text-xs font-bold px-4 py-2.5 rounded-xl flex items-center justify-center gap-1.5 transition shadow-lg shrink-0"
            >
              <Phone className="h-3.5 w-3.5" />
              <span>Chat on WhatsApp</span>
            </a>
          </div>
        </div>

        {/* Video Resources Card */}
        <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-4 bg-white/2">
          <div className="border-b border-white/5 pb-3">
            <h2 className="text-sm font-bold uppercase tracking-wider text-primary-300 flex items-center gap-2">
              <Radio className="h-4 w-4" />
              <span>Locksmith Skill & Career Upgrades</span>
            </h2>
            <p className="text-[11px] text-gray-400 mt-1">Upgrade your trade capabilities with video tutorials from duplicate key experts.</p>
          </div>

          <div className="grid grid-cols-1 sm:grid-cols-2 gap-4 max-h-96 overflow-y-auto pr-1">
            {config?.videos && config.videos.length > 0 ? (
              config.videos.map((vid, idx) => {
                const { thumbnail } = getYoutubeThumbnailAndId(vid.url);
                return (
                  <div key={idx} className="bg-[#140f29] rounded-xl overflow-hidden border border-white/5 flex flex-col justify-between group">
                    <div className="relative h-24 bg-black/60 flex items-center justify-center overflow-hidden">
                      <img src={thumbnail} alt={vid.name} className="w-full h-full object-cover opacity-65 group-hover:scale-105 transition duration-300" />
                      <a 
                        href={vid.url} 
                        target="_blank" 
                        rel="noreferrer"
                        className="absolute inset-0 flex items-center justify-center bg-black/40 hover:bg-black/60 transition"
                      >
                        <span className="w-8 h-8 rounded-full bg-red-600 flex items-center justify-center text-white text-xs font-bold animate-pulse">▶</span>
                      </a>
                    </div>
                    <div className="p-3 space-y-0.5">
                      <span className="text-[8px] text-primary-400 uppercase font-bold tracking-wider font-mono">Training Material</span>
                      <h4 className="text-xs font-bold text-white line-clamp-1">{vid.name}</h4>
                      <a href={vid.url} target="_blank" rel="noreferrer" className="text-[9px] text-gray-500 hover:underline truncate block">Watch Link</a>
                    </div>
                  </div>
                );
              })
            ) : (
              <p className="text-xs text-gray-500 italic col-span-2 py-8 text-center">No skill upgrade videos currently available.</p>
            )}
          </div>
        </div>

      </div>
    </div>
  );
}

// ============================================================================
// COMPONENT 11.6: SUPPORT CONFIG VIEW (SUPER ADMIN SUPPORT CONFIGURATION)
// ============================================================================
export function SupportConfigView({ t, api }) {
  const [whatsapp, setWhatsapp] = useState('');
  const [videos, setVideos] = useState([]);
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    fetchConfig();
  }, []);

  const fetchConfig = async () => {
    try {
      const res = await api.getSupportConfig();
      setWhatsapp(res.whatsapp || '');
      setVideos(res.videos || []);
    } catch (e) {
      console.error('Failed to load support config:', e);
    } finally {
      setLoading(false);
    }
  };

  const handleSave = async (e) => {
    e.preventDefault();
    setSaving(true);
    try {
      await api.updateSupportConfig({ whatsapp, videos });
      alert('Support configuration updated successfully!');
    } catch (e) {
      alert(`Save failed: ${e.message}`);
    } finally {
      setSaving(false);
    }
  };

  if (loading) {
    return (
      <div className="flex h-64 items-center justify-center">
        <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
      </div>
    );
  }

  return (
    <div className="space-y-6 animate-fade-in text-white">
      <div>
        <h1 className="text-2xl font-extrabold tracking-tight">Customer Support Configuration</h1>
        <p className="text-sm text-gray-400 mt-1">Configure global customer care details and training video links visible to all shops.</p>
      </div>

      <div className="glass-panel p-6 rounded-2xl border border-white/5 bg-white/2 max-w-2xl">
        <form onSubmit={handleSave} className="space-y-6">
          <div>
            <label className="block text-xs font-semibold text-gray-400 mb-1.5 uppercase font-bold tracking-wider">Customer Support WhatsApp Number</label>
            <input 
              type="text" required value={whatsapp} onChange={(e) => setWhatsapp(e.target.value)}
              placeholder="e.g. +91 98765 43210" 
              className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
            />
          </div>

          <div className="space-y-4 border-t border-white/5 pt-4">
            <div className="flex justify-between items-center">
              <h3 className="text-xs font-bold text-primary-300 uppercase tracking-widest">Support & Training Videos</h3>
              <button 
                type="button"
                onClick={() => setVideos([...videos, { name: '', url: '' }])}
                className="bg-primary-600/30 hover:bg-primary-600/50 border border-primary-500/20 text-primary-300 text-[10px] font-bold px-3 py-1.5 rounded-lg transition flex items-center gap-1"
              >
                <Plus className="h-3 w-3" />
                <span>Add Video</span>
              </button>
            </div>

            {videos.length === 0 ? (
              <p className="text-xs text-gray-500 italic">No videos configured. Click "Add Video" to add locksmith training links.</p>
            ) : (
              <div className="space-y-3 max-h-96 overflow-y-auto pr-1">
                {videos.map((vid, idx) => (
                  <div key={idx} className="bg-[#120e24]/60 border border-white/5 p-4 rounded-xl space-y-3 relative group">
                    <button 
                      type="button"
                      onClick={() => setVideos(videos.filter((_, i) => i !== idx))}
                      className="absolute top-3 right-3 text-red-400 hover:text-red-300 transition"
                    >
                      <X className="h-4 w-4" />
                    </button>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4 pr-6">
                      <div>
                        <label className="block text-[9px] font-semibold text-gray-400 mb-1 uppercase font-bold tracking-wider">Video Title / Name</label>
                        <input 
                          type="text" required value={vid.name} 
                          onChange={(e) => {
                            const newVids = [...videos];
                            newVids[idx].name = e.target.value;
                            setVideos(newVids);
                          }}
                          placeholder="e.g. Locksmith Career Income" 
                          className="w-full bg-[#1b1530] border border-white/10 rounded-xl px-3 py-2 text-xs text-white"
                        />
                      </div>
                      <div>
                        <label className="block text-[9px] font-semibold text-gray-400 mb-1 uppercase font-bold tracking-wider">YouTube URL</label>
                        <input 
                          type="url" required value={vid.url} 
                          onChange={(e) => {
                            const newVids = [...videos];
                            newVids[idx].url = e.target.value;
                            setVideos(newVids);
                          }}
                          placeholder="https://www.youtube.com/watch?v=..." 
                          className="w-full bg-[#1b1530] border border-white/10 rounded-xl px-3 py-2 text-xs text-white"
                        />
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>

          <div className="flex justify-end pt-4 border-t border-white/5">
            <button 
              type="submit" disabled={saving}
              className="glass-button-primary px-5 py-2.5 rounded-xl text-xs font-semibold text-white flex items-center gap-1.5"
            >
              {saving ? <RefreshCw className="h-4 w-4 animate-spin" /> : null}
              <span>Save Configuration</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  );
}

function ShopSettingsView({ t, api }) {
  const { user, isDemoMode, login } = useAuth();
  const [shopName, setShopName] = useState('');
  const [themeColor, setThemeColor] = useState('#8C24FF');
  const [address, setAddress] = useState('');
  const [gst, setGst] = useState('');
  const [phone, setPhone] = useState('');
  const [logoUrl, setLogoUrl] = useState('');
  const [shopPhoto, setShopPhoto] = useState('');
  const [shopLicense, setShopLicense] = useState('');
  const [ownerAadhaar, setOwnerAadhaar] = useState('');
  const [loading, setLoading] = useState(true);

  // Verification states
  const [revealPassword, setRevealPassword] = useState(false);
  const [showPassVerifyModal, setShowPassVerifyModal] = useState(false);
  const [passVerifyInput, setPassVerifyInput] = useState('');
  const [passVerifyError, setPassVerifyError] = useState('');
  const [passVerifyLoading, setPassVerifyLoading] = useState(false);
  const [showVerifyPass, setShowVerifyPass] = useState(false);
  const [otpShowNewPass, setOtpShowNewPass] = useState(false);
  const [otpShowConfirmPass, setOtpShowConfirmPass] = useState(false);
  const [revealedPasswordVal, setRevealedPasswordVal] = useState('');

  // OTP Reset states inside Settings
  const [otpResetOpen, setOtpResetOpen] = useState(false);
  const [otpResetMethod, setOtpResetMethod] = useState(null); // 'email' | 'phone'
  const [otpResetIdentifier, setOtpResetIdentifier] = useState('');
  const [otpResetOtpInput, setOtpResetOtpInput] = useState('');
  const [otpResetGeneratedOtp, setOtpResetGeneratedOtp] = useState('');
  const [otpResetSent, setOtpResetSent] = useState(false);
  const [otpResetVerified, setOtpResetVerified] = useState(false);
  const [otpResetNewPassword, setOtpResetNewPassword] = useState('');
  const [otpResetConfirmPassword, setOtpResetConfirmPassword] = useState('');
  const [otpResetLoading, setOtpResetLoading] = useState(false);
  const [otpResetError, setOtpResetError] = useState('');
  const [otpResetSuccess, setOtpResetSuccess] = useState(false);

  useEffect(() => {
    fetchSettings();
  }, []);

  const fetchSettings = async () => {
    setLoading(true);
    try {
      const res = await api.getSettings();
      setShopName(res.name);
      setThemeColor(res.themeColor);
      setLogoUrl(res.logoUrl || '');
      
      if (res.companyDetails) {
        try {
          const details = JSON.parse(res.companyDetails);
          setAddress(details.address || '');
          setGst(details.gst || '');
          setPhone(details.phone || '');
          setShopPhoto(details.shopPhoto || '');
          setShopLicense(details.shopLicense || '');
          setOwnerAadhaar(details.ownerAadhaar || '');
        } catch (err) {
          setAddress('');
          setGst('');
          setPhone('');
          setShopPhoto('');
          setShopLicense('');
          setOwnerAadhaar('');
        }
      }
    } catch (e) {
      console.error(e);
    } finally {
      setLoading(false);
    }
  };

  const handleUpdate = async (e) => {
    e.preventDefault();
    try {
      const companyDetails = JSON.stringify({ 
        address, 
        phone, 
        gst, 
        shopPhoto, 
        shopLicense, 
        ownerAadhaar 
      });
      await api.updateSettings({
        name: shopName,
        logoUrl,
        themeColor,
        companyDetails
      });
      alert('Shop workspace settings saved successfully!');
    } catch (e) {
      alert(e.message);
    }
  };

  const handlePasswordVerificationSubmit = async (e) => {
    e.preventDefault();
    setPassVerifyError('');
    setPassVerifyLoading(true);
    try {
      await api.changePassword(passVerifyInput, passVerifyInput);
      setRevealedPasswordVal(passVerifyInput);
      setRevealPassword(true);
      setShowPassVerifyModal(false);
      setPassVerifyInput('');
    } catch (err) {
      setPassVerifyError(err.message || 'Incorrect password entered.');
    } finally {
      setPassVerifyLoading(false);
    }
  };

  // OTP Reset handlers
  const handleOtpResetSend = async () => {
    if (!otpResetIdentifier) {
      alert('Please enter your registered email or phone number');
      return;
    }
    try {
      const res = await api.sendOtp(otpResetIdentifier, otpResetMethod || 'email', 'reset');
      setOtpResetGeneratedOtp(res.otpCode);
      setOtpResetSent(true);
      setOtpResetError('');
      alert(`Verification code sent! [Fallback Code: ${res.otpCode}]`);
    } catch (err) {
      alert(err.message || 'Failed to send OTP code.');
    }
  };

  const handleOtpResetVerify = (e) => {
    e.preventDefault();
    if (otpResetOtpInput === otpResetGeneratedOtp) {
      setOtpResetVerified(true);
      setOtpResetError('');
    } else {
      setOtpResetError('Invalid OTP code. Please enter the correct code.');
    }
  };

  const handleOtpResetSubmit = async (e) => {
    e.preventDefault();
    if (otpResetNewPassword !== otpResetConfirmPassword) {
      setOtpResetError('Passwords do not match');
      return;
    }
    setOtpResetLoading(true);
    try {
      await api.resetPasswordPublic(otpResetIdentifier, otpResetMethod || 'email', otpResetNewPassword);
      setRevealedPasswordVal(otpResetNewPassword);
      setOtpResetSuccess(true);
      alert('Password updated successfully!');
      // Re-login in demo mode if password changed
      if (isDemoMode && user) {
        user.password = otpResetNewPassword;
      }
      setOtpResetOpen(false);
      // Reset flow variables
      setOtpResetSent(false);
      setOtpResetVerified(false);
      setOtpResetIdentifier('');
      setOtpResetOtpInput('');
      setOtpResetNewPassword('');
      setOtpResetConfirmPassword('');
    } catch (err) {
      setOtpResetError(err.message || 'Failed to update password');
    } finally {
      setOtpResetLoading(false);
    }
  };

  if (loading) {
    return (
      <div className="flex h-64 items-center justify-center">
        <RefreshCw className="h-8 w-8 animate-spin text-primary-400" />
      </div>
    );
  }

  return (
    <div className="max-w-xl mx-auto space-y-6 animate-fade-in">
      <div>
        <h1 className="text-2xl font-extrabold tracking-tight">{t('settings')}</h1>
        <p className="text-sm text-gray-400 mt-1">Configure workspace logo, company metadata, and themes.</p>
      </div>

      <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-4">
        <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3">
          Workspace Profile Details
        </h2>

        <form onSubmit={handleUpdate} className="space-y-4">
          <div>
            <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Workspace Display Name</label>
            <input 
              type="text" required value={shopName} onChange={(e) => setShopName(e.target.value)}
              className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
            />
          </div>

          <div className="grid grid-cols-1 gap-4">
            <div>
              <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Phone Number</label>
              <input 
                type="tel" required value={phone} onChange={(e) => setPhone(e.target.value)}
                placeholder="+91..." className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
              />
            </div>
          </div>

          <div>
            <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Registered Address</label>
            <input 
              type="text" required value={address} onChange={(e) => setAddress(e.target.value)}
              className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white font-medium"
            />
          </div>

          <div className="border-t border-white/5 pt-4">
            <div className="space-y-3">
              <div>
                <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase font-bold tracking-wider">Logo URL / Image Source</label>
                <div className="flex gap-2">
                  <input 
                    type="text" value={logoUrl} 
                    onChange={(e) => setLogoUrl(cleanGoogleImageUrl(e.target.value))}
                    placeholder="Paste Image URL (or Google Image Link)" 
                    className="flex-1 glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                  />
                  <label className="cursor-pointer bg-white/5 hover:bg-white/10 border border-white/10 px-3 py-2 rounded-xl text-xs font-bold text-gray-300 flex items-center justify-center gap-1.5 transition shrink-0">
                    <Upload className="h-3.5 w-3.5 text-primary-400" />
                    <span>Upload</span>
                    <input 
                      type="file" accept="image/*" className="hidden" 
                      onChange={(e) => {
                        const file = e.target.files[0];
                        if (file) {
                          const reader = new FileReader();
                          reader.onloadend = () => {
                            setLogoUrl(reader.result);
                          };
                          reader.readAsDataURL(file);
                        }
                      }}
                    />
                  </label>
                </div>
                <p className="text-[9px] text-gray-500 mt-1">Paste a web link or select a local image. Google Images URLs will be parsed automatically.</p>
              </div>

              {logoUrl && (
                <div className="flex items-center gap-3 bg-white/2 border border-white/5 p-2 rounded-xl">
                  <img 
                    src={cleanGoogleImageUrl(logoUrl)} 
                    alt="Logo Preview" 
                    onError={(e) => {
                      e.target.style.display = 'none';
                    }}
                    className="w-10 h-10 object-cover rounded-lg border border-white/10" 
                  />
                  <div className="flex-1 min-w-0">
                    <span className="text-[9px] text-emerald-400 font-bold block uppercase font-mono">Live Preview</span>
                    <span className="text-[9px] text-gray-500 truncate block">{logoUrl.startsWith('data:') ? 'Local System Image' : logoUrl}</span>
                  </div>
                  <button 
                    type="button" 
                    onClick={() => setLogoUrl('')}
                    className="text-red-400 hover:text-red-300 text-[10px] font-bold px-1"
                  >
                    Clear
                  </button>
                </div>
              )}
            </div>
          </div>

          {/* Shop Verification Documents Section */}
          <div className="border-t border-white/5 pt-4 space-y-3">
            <h3 className="text-xs font-bold uppercase tracking-wider text-primary-300">
              Uploaded Shop Verification Documents
            </h3>
            
            <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
              {/* Document 1: Shop Photo */}
              <div className="bg-white/2 border border-white/5 p-3 rounded-xl flex flex-col justify-between space-y-2">
                <div>
                  <span className="text-[10px] text-gray-400 block font-semibold uppercase">Shop Photo</span>
                  {shopPhoto ? (
                    <div className="mt-1.5 h-16 w-full rounded-lg overflow-hidden border border-white/10 bg-black">
                      <img src={shopPhoto} className="w-full h-full object-cover" alt="Shop Photo Preview" />
                    </div>
                  ) : (
                    <span className="text-[10px] text-gray-500 italic block mt-1">Not Uploaded</span>
                  )}
                </div>
                {shopPhoto && (
                  <a 
                    href={shopPhoto} 
                    download="shop_photo.png" 
                    className="bg-primary-600 hover:bg-primary-500 text-white text-[9px] font-bold py-1.5 rounded-lg transition text-center block w-full mt-2"
                  >
                    Download File
                  </a>
                )}
              </div>

              {/* Document 2: Shop License */}
              <div className="bg-white/2 border border-white/5 p-3 rounded-xl flex flex-col justify-between space-y-2">
                <div>
                  <span className="text-[10px] text-gray-400 block font-semibold uppercase">Shop License</span>
                  {shopLicense ? (
                    <div className="mt-1.5 h-16 w-full rounded-lg overflow-hidden border border-white/10 bg-black flex items-center justify-center">
                      {shopLicense.startsWith('data:application/pdf') ? (
                        <span className="text-[10px] text-red-400 font-bold font-mono">📄 PDF File</span>
                      ) : (
                        <img src={shopLicense} className="w-full h-full object-cover" alt="License Preview" />
                      )}
                    </div>
                  ) : (
                    <span className="text-[10px] text-gray-500 italic block mt-1">Not Uploaded</span>
                  )}
                </div>
                {shopLicense && (
                  <a 
                    href={shopLicense} 
                    download="shop_license.pdf" 
                    className="bg-primary-600 hover:bg-primary-500 text-white text-[9px] font-bold py-1.5 rounded-lg transition text-center block w-full mt-2"
                  >
                    Download File
                  </a>
                )}
              </div>

              {/* Document 3: Owner Aadhaar */}
              <div className="bg-white/2 border border-white/5 p-3 rounded-xl flex flex-col justify-between space-y-2">
                <div>
                  <span className="text-[10px] text-gray-400 block font-semibold uppercase">Owner Aadhaar</span>
                  {ownerAadhaar ? (
                    <div className="mt-1.5 h-16 w-full rounded-lg overflow-hidden border border-white/10 bg-black flex items-center justify-center">
                      {ownerAadhaar.startsWith('data:application/pdf') ? (
                        <span className="text-[10px] text-red-400 font-bold font-mono">📄 PDF File</span>
                      ) : (
                        <img src={ownerAadhaar} className="w-full h-full object-cover" alt="Aadhaar Preview" />
                      )}
                    </div>
                  ) : (
                    <span className="text-[10px] text-gray-500 italic block mt-1">Not Uploaded</span>
                  )}
                </div>
                {ownerAadhaar && (
                  <a 
                    href={ownerAadhaar} 
                    download="owner_aadhaar.pdf" 
                    className="bg-primary-600 hover:bg-primary-500 text-white text-[9px] font-bold py-1.5 rounded-lg transition text-center block w-full mt-2"
                  >
                    Download File
                  </a>
                )}
              </div>
            </div>
          </div>

          <div className="flex justify-end pt-4 border-t border-white/5">
            <button 
              type="submit"
              className="glass-button-primary px-5 py-2.5 rounded-xl text-xs font-semibold text-white flex items-center gap-2"
            >
              <Check className="h-4 w-4" />
              <span>Save Workspace Details</span>
            </button>
          </div>
        </form>
      </div>

      {/* Admin User Credentials Block */}
      <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-4">
        <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300 border-b border-white/5 pb-3">
          Admin User Credentials
        </h2>
        
        <div className="space-y-4">
          <div className="grid grid-cols-2 gap-4 text-xs font-medium">
            <div>
              <span className="block text-[10px] font-semibold text-gray-500 uppercase mb-1">Username / Name</span>
              <span className="text-white font-bold">{user.name}</span>
            </div>
            <div>
              <span className="block text-[10px] font-semibold text-gray-500 uppercase mb-1">Email Address</span>
              <span className="text-white font-bold">{user.email}</span>
            </div>
          </div>

          <div className="grid grid-cols-2 gap-4 text-xs font-medium border-t border-white/5 pt-4">
            <div>
              <span className="block text-[10px] font-semibold text-gray-500 uppercase mb-1">Phone Number</span>
              <span className="text-white font-bold">{phone || 'N/A'}</span>
            </div>
            <div>
              <span className="block text-[10px] font-semibold text-gray-500 uppercase mb-1">Workspace Password</span>
              <div className="flex items-center gap-2 mt-1">
                {revealPassword ? (
                  <span className="text-primary-300 font-mono font-bold text-xs">{revealedPasswordVal || user.password || 'shoppassword'}</span>
                ) : (
                  <span className="text-gray-500 font-mono">••••••••</span>
                )}
                
                {!revealPassword ? (
                  <button 
                    onClick={() => setShowPassVerifyModal(true)}
                    className="text-[10px] font-bold text-primary-400 hover:text-primary-300 hover:underline"
                  >
                    Reveal
                  </button>
                ) : (
                  <button 
                    onClick={() => setRevealPassword(false)}
                    className="text-[10px] font-bold text-gray-400 hover:text-white hover:underline"
                  >
                    Hide
                  </button>
                )}
              </div>
            </div>
          </div>

          <div className="border-t border-white/5 pt-4 text-left">
            <button 
              onClick={() => setOtpResetOpen(true)}
              className="text-xs font-bold text-primary-400 hover:text-primary-300 hover:underline flex items-center gap-1"
            >
              <span>Forgot Password? Reset password via OTP</span>
            </button>
          </div>
        </div>
      </div>

      {/* Password Verification Modal overlay */}
      {showPassVerifyModal && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/60 backdrop-blur-sm flex justify-center p-4">
          <div className="glass-panel w-full max-w-sm rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 space-y-4 bg-[#100c25]">
            <div className="flex items-center justify-between border-b border-white/5 pb-2">
              <h3 className="font-extrabold text-xs uppercase tracking-wider text-white">Enter Account Password</h3>
              <button onClick={() => { setShowPassVerifyModal(false); setPassVerifyError(''); }} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>
            <form onSubmit={handlePasswordVerificationSubmit} className="space-y-4">
              <p className="text-[11px] text-gray-400 leading-relaxed">Please enter your active account password to confirm identity and reveal credentials.</p>
              
              {passVerifyError && <div className="text-xs text-red-400 font-semibold">{passVerifyError}</div>}
              
              <div className="relative">
                <input 
                  type={showVerifyPass ? "text" : "password"} required value={passVerifyInput} onChange={(e) => setPassVerifyInput(e.target.value)}
                  placeholder="Enter password" className="w-full glass-input pl-3 pr-10 py-2.5 rounded-xl text-xs text-white"
                />
                <button 
                  type="button" 
                  onClick={() => setShowVerifyPass(!showVerifyPass)}
                  className="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white"
                >
                  {showVerifyPass ? <EyeOff className="h-4 w-4" /> : <Eye className="h-4 w-4" />}
                </button>
              </div>

              <div className="flex justify-end gap-3 pt-2">
                <button type="button" onClick={() => { setShowPassVerifyModal(false); setPassVerifyError(''); }} className="px-4 py-2 border border-white/10 rounded-xl text-xs text-gray-300 hover:bg-white/5">Cancel</button>
                <button type="submit" disabled={passVerifyLoading} className="glass-button-primary px-5 py-2 rounded-xl text-xs font-bold text-white">
                  {passVerifyLoading ? <RefreshCw className="h-4 w-4 animate-spin" /> : 'Confirm'}
                </button>
              </div>
            </form>
          </div>
        </div>,
        document.body
      )}

      {/* OTP Password Reset Modal inside Settings */}
      {otpResetOpen && createPortal(
        <div className="fixed inset-0 z-50 overflow-y-auto bg-black/60 backdrop-blur-sm flex justify-center p-4">
          <div className="glass-panel w-full max-w-md rounded-2xl shadow-2xl border border-white/10 my-auto animate-fade-in p-6 bg-[#0f0a22]">
            <div className="flex justify-between items-center border-b border-white/5 pb-3 mb-4">
              <h2 className="text-sm font-extrabold text-white uppercase tracking-wider">Reset Account Password</h2>
              <button onClick={() => setOtpResetOpen(false)} className="text-gray-400 hover:text-white">
                <X className="h-5 w-5" />
              </button>
            </div>

            {!otpResetSent ? (
              <div className="space-y-4">
                <div className="flex gap-2">
                  <button 
                    onClick={() => setOtpResetMethod('email')}
                    className={`flex-1 py-2 rounded-xl border text-xs font-bold transition ${otpResetMethod === 'email' || !otpResetMethod ? 'border-primary-500 bg-primary-600/10 text-white' : 'border-white/5 bg-white/2 text-gray-400 hover:bg-white/5'}`}
                  >
                    Email Recovery
                  </button>
                  <button 
                    onClick={() => setOtpResetMethod('phone')}
                    className={`flex-1 py-2 rounded-xl border text-xs font-bold transition ${otpResetMethod === 'phone' ? 'border-primary-500 bg-primary-600/10 text-white' : 'border-white/5 bg-white/2 text-gray-400 hover:bg-white/5'}`}
                  >
                    Phone Recovery
                  </button>
                </div>
                <div>
                  <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2">
                    {otpResetMethod === 'phone' ? 'Registered Phone Number' : 'Registered Email Address'}
                  </label>
                  <input 
                    type="text" required value={otpResetIdentifier} onChange={(e) => setOtpResetIdentifier(e.target.value)}
                    placeholder={otpResetMethod === 'phone' ? '+91 99999 99999' : 'owner@shop.com'}
                    className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
                  />
                </div>
                <button 
                  onClick={handleOtpResetSend}
                  className="w-full glass-button-primary text-white py-2.5 rounded-xl text-xs font-bold mt-2"
                >
                  Send OTP Verification Code
                </button>
              </div>
            ) : !otpResetVerified ? (
              <form onSubmit={handleOtpResetVerify} className="space-y-4">
                <div className="bg-white/2 border border-white/5 p-3 rounded-xl text-center space-y-1">
                  <span className="font-semibold block uppercase text-[8px] text-gray-500 mb-0.5">Verification code</span>
                  <span className="font-extrabold text-sm tracking-widest text-primary-300">{otpResetGeneratedOtp}</span>
                </div>
                <div>
                  <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2">Enter OTP</label>
                  <input 
                    type="text" required maxLength={4} value={otpResetOtpInput} onChange={(e) => setOtpResetOtpInput(e.target.value.replace(/\D/g, ''))}
                    placeholder="e.g. 1234" className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white text-center font-bold tracking-widest"
                  />
                </div>
                {otpResetError && <div className="text-xs text-red-400 font-semibold">{otpResetError}</div>}
                <div className="flex gap-2">
                  <button type="button" onClick={() => setOtpResetSent(false)} className="w-1/3 py-2.5 bg-white/5 hover:bg-white/10 border border-white/10 text-gray-300 rounded-xl text-xs font-semibold">Back</button>
                  <button type="submit" className="w-2/3 glass-button-primary text-white py-2.5 rounded-xl text-xs font-bold">Verify OTP</button>
                </div>
              </form>
            ) : (
              <form onSubmit={handleOtpResetSubmit} className="space-y-4">
                {otpResetError && <div className="text-xs text-red-400 font-semibold">{otpResetError}</div>}
                <div>
                  <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2">New Password</label>
                  <div className="relative">
                    <input 
                      type={otpShowNewPass ? "text" : "password"} required value={otpResetNewPassword} onChange={(e) => setOtpResetNewPassword(e.target.value)}
                      placeholder="Min 6 characters" className="w-full glass-input pl-3 pr-10 py-2.5 rounded-xl text-xs text-white"
                    />
                    <button 
                      type="button" 
                      onClick={() => setOtpShowNewPass(!otpShowNewPass)}
                      className="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white"
                    >
                      {otpShowNewPass ? <EyeOff className="h-4 w-4" /> : <Eye className="h-4 w-4" />}
                    </button>
                  </div>
                </div>
                <div>
                  <label className="block text-[10px] font-semibold text-gray-400 uppercase tracking-wider mb-2">Confirm Password</label>
                  <div className="relative">
                    <input 
                      type={otpShowConfirmPass ? "text" : "password"} required value={otpResetConfirmPassword} onChange={(e) => setOtpResetConfirmPassword(e.target.value)}
                      placeholder="Retype password" className="w-full glass-input pl-3 pr-10 py-2.5 rounded-xl text-xs text-white"
                    />
                    <button 
                      type="button" 
                      onClick={() => setOtpShowConfirmPass(!otpShowConfirmPass)}
                      className="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-white"
                    >
                      {otpShowConfirmPass ? <EyeOff className="h-4 w-4" /> : <Eye className="h-4 w-4" />}
                    </button>
                  </div>
                </div>
                <button 
                  type="submit" disabled={otpResetLoading}
                  className="w-full glass-button-primary text-white py-2.5 rounded-xl text-xs font-bold"
                >
                  {otpResetLoading ? <RefreshCw className="h-4 w-4 animate-spin" /> : 'Update Password'}
                </button>
              </form>
            )}
          </div>
        </div>,
        document.body
      )}

    </div>
  );
}

// ============================================================================
// COMPONENT 14: REPORTS PORTAL VIEW
// ============================================================================
export function ReportsPortalView({ t, api }) {
  const [reportType, setReportType] = useState('REGISTRATIONS'); // REGISTRATIONS | INVENTORY | AUDIT
  const [fromDate, setFromDate] = useState('');
  const [toDate, setToDate] = useState('');
  const [reportData, setReportData] = useState([]);
  const [loading, setLoading] = useState(false);

  useEffect(() => {
    const now = new Date();
    const thirtyDaysAgo = new Date();
    thirtyDaysAgo.setDate(now.getDate() - 30);
    
    setFromDate(thirtyDaysAgo.toISOString().split('T')[0]);
    setToDate(now.toISOString().split('T')[0]);
  }, []);

  const handleGenerate = async (e) => {
    e.preventDefault();
    setLoading(true);
    try {
      if (reportType === 'REGISTRATIONS') {
        const custs = await api.getCustomers();
        const filtered = custs.filter(c => {
          const cDate = new Date(c.createdAt).getTime();
          const start = fromDate ? new Date(fromDate).getTime() : 0;
          const end = toDate ? new Date(toDate + 'T23:59:59').getTime() : Infinity;
          return cDate >= start && cDate <= end;
        });
        setReportData(filtered.map(c => ({
          'Customer Name': c.name,
          'Phone': c.phone,
          'Vehicle Number': c.vehicleNumber || 'N/A',
          'Key Blank Code': c.keyNumber,
          'Location Address': c.capturedAddress || 'N/A',
          'GPS Coordinates': `${c.latitude}, ${c.longitude}`,
          'Date Registered': new Date(c.createdAt).toLocaleString()
        })));
      } else if (reportType === 'INVENTORY') {
        const inventory = await api.getInventoryItems ? await api.getInventoryItems() : [];
        setReportData(inventory.map(item => ({
          'Item ID': item.id,
          'Key Blank Reference': item.keyNumber || 'N/A',
          'Quantity on Hand': item.quantity || 0,
          'Reorder Level': item.reorderLevel || 5,
          'Last Restocked': item.updatedAt ? new Date(item.updatedAt).toLocaleDateString() : 'N/A'
        })));
      } else {
        setReportData([
          { 'Activity ID': 'AUD-001', 'User / Account': 'Shop Operator', 'Action Perfomed': 'Verified Customer TN09B', 'Device IP': '192.168.1.102', 'Timestamp': new Date().toLocaleString() },
          { 'Activity ID': 'AUD-002', 'User / Account': 'Shop Operator', 'Action Perfomed': 'Created Key Spec TN09B', 'Device IP': '192.168.1.102', 'Timestamp': new Date().toLocaleString() },
          { 'Activity ID': 'AUD-003', 'User / Account': 'Shop Operator', 'Action Perfomed': 'Updated settings GSTIN', 'Device IP': '192.168.1.102', 'Timestamp': new Date().toLocaleString() },
        ]);
      }
    } catch (err) {
      console.error(err);
      alert('Failed to generate report.');
    } finally {
      setLoading(false);
    }
  };

  const handleDownloadCSV = () => {
    if (reportData.length === 0) {
      alert('Please generate the report first.');
      return;
    }
    const headers = Object.keys(reportData[0]);
    const csvRows = [];
    csvRows.push(headers.join(','));

    for (const row of reportData) {
      const values = headers.map(header => {
        const escaped = ('' + row[header]).replace(/"/g, '\\"');
        return `"${escaped}"`;
      });
      csvRows.push(values.join(','));
    }

    const blob = new Blob([csvRows.join('\n')], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `kee_report_${reportType.toLowerCase()}_${new Date().toISOString().split('T')[0]}.csv`;
    link.style.visibility = 'hidden';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  const handleDownloadTXT = () => {
    if (reportData.length === 0) {
      alert('Please generate the report first.');
      return;
    }
    const headers = Object.keys(reportData[0]);
    let txtContent = `========================================================================\n`;
    txtContent += `KEE SYSTEM TERMINAL - ${reportType.toUpperCase()} REPORT\n`;
    txtContent += `Generated: ${new Date().toLocaleString()}\n`;
    txtContent += `Range: ${fromDate || 'All Time'} to ${toDate || 'All Time'}\n`;
    txtContent += `========================================================================\n\n`;

    for (const row of reportData) {
      headers.forEach(header => {
        txtContent += `${header.padEnd(25)}: ${row[header]}\n`;
      });
      txtContent += `------------------------------------------------------------------------\n`;
    }

    const blob = new Blob([txtContent], { type: 'text/plain;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `kee_report_${reportType.toLowerCase()}_${new Date().toISOString().split('T')[0]}.txt`;
    link.style.visibility = 'hidden';
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  return (
    <div className="space-y-6 animate-fade-in">
      <div>
        <h1 className="text-2xl font-extrabold tracking-tight">{t('reports')}</h1>
        <p className="text-sm text-gray-400 mt-1">Generate dynamic CSV and plain-text compliance audits.</p>
      </div>

      <div className="glass-panel p-6 rounded-2xl border border-white/5">
        <form onSubmit={handleGenerate} className="space-y-4">
          <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">Report Type</label>
              <select 
                value={reportType} onChange={(e) => setReportType(e.target.value)}
                className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
              >
                <option value="REGISTRATIONS">Customer Compliance Registry</option>
                <option value="INVENTORY">Store Inventory Stock Levels</option>
                <option value="AUDIT">Terminal Security Audit Logs</option>
              </select>
            </div>
            <div>
              <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">From Date</label>
              <input 
                type="date" value={fromDate} onChange={(e) => setFromDate(e.target.value)}
                className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
              />
            </div>
            <div>
              <label className="block text-[10px] font-semibold text-gray-400 mb-1.5 uppercase">To Date</label>
              <input 
                type="date" value={toDate} onChange={(e) => setToDate(e.target.value)}
                className="w-full glass-input px-3 py-2.5 rounded-xl text-xs text-white"
              />
            </div>
          </div>

          <div className="flex justify-end gap-3 pt-2">
            <button 
              type="submit"
              className="glass-button-primary px-5 py-2.5 rounded-xl text-xs font-semibold text-white flex items-center gap-1.5"
            >
              <RefreshCw className={`h-4 w-4 ${loading ? 'animate-spin' : ''}`} />
              <span>Generate Audit View</span>
            </button>
          </div>
        </form>
      </div>

      {reportData.length > 0 && (
        <div className="glass-panel p-6 rounded-2xl border border-white/5 space-y-4 animate-fade-in">
          <div className="flex justify-between items-center border-b border-white/5 pb-3">
            <h2 className="text-sm font-bold uppercase tracking-wider text-gray-300">
              Report Preview ({reportData.length} records)
            </h2>
            <div className="flex gap-2">
              <button 
                onClick={handleDownloadCSV}
                className="bg-emerald-600/20 hover:bg-emerald-600/35 text-emerald-300 border border-emerald-500/20 text-xs px-3 py-1.5 rounded-lg font-bold transition"
              >
                Export CSV Excel
              </button>
              <button 
                onClick={handleDownloadTXT}
                className="bg-primary-600/20 hover:bg-primary-600/35 text-primary-300 border border-primary-500/20 text-xs px-3 py-1.5 rounded-lg font-bold transition"
              >
                Export Plain Text
              </button>
            </div>
          </div>

          {/* Graphical Report Chart Visualization */}
          <div className="glass-panel p-5 rounded-2xl bg-white/2 border border-white/5 space-y-4">
            <h3 className="text-xs font-bold text-primary-300 uppercase tracking-widest">Visual Report Summary</h3>
            
            <div className={`grid grid-cols-1 ${reportType === 'REGISTRATIONS' ? 'md:grid-cols-2' : ''} gap-6`}>
              
              {/* Left Column: Bar Chart */}
              <div>
                <h4 className="text-[10px] text-gray-400 font-bold uppercase tracking-wider mb-2 text-center">
                  {reportType === 'REGISTRATIONS' ? 'Registrations by Key Blank Reference' : reportType === 'INVENTORY' ? 'Stock vs Reorder Limits' : 'Action Types Distribution'}
                </h4>
                <div className="h-48 w-full flex items-end gap-3 pt-6 pb-2 px-4 relative bg-[#120e29] rounded-xl border border-white/5">
                  {(() => {
                    let dataPoints = [];
                    if (reportType === 'REGISTRATIONS') {
                      const counts = {};
                      reportData.forEach(r => {
                        const key = r['Key Blank Code'] || 'N/A';
                        counts[key] = (counts[key] || 0) + 1;
                      });
                      dataPoints = Object.keys(counts).map(key => ({ label: key, value: counts[key] })).slice(0, 8);
                    } else if (reportType === 'INVENTORY') {
                      dataPoints = reportData.map(r => ({
                        label: r['Key Blank Reference'] || 'N/A',
                        value: r['Quantity on Hand'] || 0,
                        reorder: r['Reorder Level'] || 5
                      })).slice(0, 8);
                    } else {
                      dataPoints = [
                        { label: 'Verify Customer', value: reportData.filter(r => r['Action Perfomed']?.includes('Verify')).length || 1 },
                        { label: 'Create Spec', value: reportData.filter(r => r['Action Perfomed']?.includes('Create')).length || 1 },
                        { label: 'Update Settings', value: reportData.filter(r => r['Action Perfomed']?.includes('Settings')).length || 1 }
                      ];
                    }

                    const maxVal = Math.max(...dataPoints.map(d => Math.max(d.value, d.reorder || 0)), 1);

                    return dataPoints.map((d, idx) => {
                      const heightPercent = (d.value / maxVal) * 100;
                      const reorderHeight = d.reorder ? (d.reorder / maxVal) * 100 : 0;
                      return (
                        <div key={idx} className="flex-1 flex flex-col items-center group relative h-full justify-end">
                          <div className="w-full flex items-end justify-center gap-1 h-[80%]">
                            <div 
                              style={{ height: `${heightPercent}%` }}
                              className="w-4 bg-gradient-to-t from-primary-600 to-purple-400 rounded-t transition-all duration-500 relative"
                            >
                              <span className="absolute -top-6 left-1/2 -translate-x-1/2 text-[9px] font-bold text-white opacity-0 group-hover:opacity-100 transition-opacity">
                                {d.value}
                              </span>
                            </div>
                            {d.reorder !== undefined && (
                              <div 
                                style={{ height: `${reorderHeight}%` }}
                                className="w-1 bg-amber-500 rounded-t"
                                title={`Reorder Level: ${d.reorder}`}
                              ></div>
                            )}
                          </div>
                          <span className="text-[8px] text-gray-500 font-bold mt-2 truncate w-full text-center uppercase tracking-wider">{d.label}</span>
                        </div>
                      );
                    });
                  })()}
                </div>
              </div>

              {/* Right Column: Line Graph (Only for REGISTRATIONS) */}
              {reportType === 'REGISTRATIONS' && (
                <div>
                  <h4 className="text-[10px] text-gray-400 font-bold uppercase tracking-wider mb-2 text-center">
                    Registration Timeline Trend
                  </h4>
                  <div className="h-48 w-full bg-[#120e29] rounded-xl border border-white/5 p-4 flex flex-col justify-between">
                    {(() => {
                      const dateCounts = {};
                      reportData.forEach(r => {
                        const rawDate = r['Date Registered'] || '';
                        const datePart = rawDate.split(' ')[0] || 'N/A';
                        dateCounts[datePart] = (dateCounts[datePart] || 0) + 1;
                      });
                      const sortedDates = Object.keys(dateCounts).sort((a, b) => new Date(a).getTime() - new Date(b).getTime()).slice(-10);
                      const dataPoints = sortedDates.map(date => ({ label: date, value: dateCounts[date] }));

                      if (dataPoints.length === 0) return <div className="text-center text-xs text-gray-500 py-12">No trend data</div>;

                      const maxVal = Math.max(...dataPoints.map(d => d.value), 1);
                      const width = 500;
                      const height = 150;
                      const padding = 20;

                      const coords = dataPoints.map((d, i) => {
                        const x = padding + (i / (dataPoints.length - 1 || 1)) * (width - 2 * padding);
                        const y = height - padding - (d.value / maxVal) * (height - 2 * padding);
                        return { x, y, label: d.label, val: d.value };
                      });

                      const pathD = coords.reduce((acc, c, i) => {
                        return i === 0 ? `M ${c.x} ${c.y}` : `${acc} L ${c.x} ${c.y}`;
                      }, '');

                      const areaD = coords.length > 0 
                        ? `${pathD} L ${coords[coords.length - 1].x} ${height - padding} L ${coords[0].x} ${height - padding} Z`
                        : '';

                      return (
                        <div className="w-full h-full flex flex-col justify-between">
                          <svg viewBox={`0 0 ${width} ${height}`} className="w-full h-28 overflow-visible">
                            <defs>
                              <linearGradient id="areaGradientReport" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stopColor="#8C24FF" stopOpacity="0.4" />
                                <stop offset="100%" stopColor="#8C24FF" stopOpacity="0.0" />
                              </linearGradient>
                            </defs>
                            
                            {/* Area under the line */}
                            {areaD && <path d={areaD} fill="url(#areaGradientReport)" />}
                            
                            {/* Grid lines */}
                            <line x1={padding} y1={height - padding} x2={width - padding} y2={height - padding} stroke="rgba(255,255,255,0.05)" strokeWidth="1" />
                            <line x1={padding} y1={padding} x2={width - padding} y2={padding} stroke="rgba(255,255,255,0.05)" strokeDasharray="3,3" />

                            {/* Trend Line */}
                            {pathD && <path d={pathD} fill="none" stroke="#A340FF" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" />}
                            
                            {/* Interactive dots */}
                            {coords.map((c, i) => (
                              <g key={i} className="group cursor-pointer">
                                <circle cx={c.x} cy={c.y} r="4" fill="#A340FF" stroke="#120e29" strokeWidth="1.5" />
                                <text x={c.x} y={c.y - 8} textAnchor="middle" fontSize="9" fontWeight="bold" fill="white" className="opacity-0 group-hover:opacity-100 transition-opacity">
                                  {c.val}
                                </text>
                              </g>
                            ))}
                          </svg>
                          <div className="flex justify-between text-[7px] text-gray-500 px-1 font-bold uppercase tracking-wider">
                            {dataPoints.map((d, i) => (
                              <span key={i}>{d.label}</span>
                            ))}
                          </div>
                        </div>
                      );
                    })()}
                  </div>
                </div>
              )}

            </div>

            <div className="flex justify-between items-center text-[9px] text-gray-500 border-t border-white/5 pt-2">
              <span>* Hover elements to view exact values</span>
              {reportType === 'INVENTORY' && (
                <div className="flex gap-3">
                  <span className="flex items-center gap-1"><span className="w-2 h-2 bg-purple-500 rounded-full"></span> Stock Level</span>
                  <span className="flex items-center gap-1"><span className="w-2.5 h-1.5 bg-amber-500 rounded"></span> Reorder Limit</span>
                </div>
              )}
            </div>
          </div>

          <div className="overflow-x-auto">
            <table className="w-full text-left text-xs border-collapse">
              <thead>
                <tr className="bg-white/5 text-gray-400 border-b border-white/5 font-bold uppercase tracking-wider">
                  {Object.keys(reportData[0]).slice(0, 4).map(header => (
                    <th key={header} className="p-3">{header}</th>
                  ))}
                </tr>
              </thead>
              <tbody className="divide-y divide-white/5 text-gray-200">
                {reportData.map((row, idx) => (
                  <tr key={idx} className="hover:bg-white/2">
                    {Object.keys(row).slice(0, 4).map(header => (
                      <td key={header} className="p-3">{row[header]}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p className="text-[10px] text-gray-500 italic">Showing up to first 4 columns in browser preview. Export to view all detailed data columns.</p>
        </div>
      )}
    </div>
  );
}

# Backend API base URL. Leave unset for local dev — Vite's dev server
# proxies relative /api/* requests to http://localhost:4000 (see
# vite.config.js). Required for production builds, since Firebase Hosting
# and Render are on different domains and Hosting can't proxy /api/** to an
# external URL (only to Cloud Functions/Cloud Run).
VITE_API_BASE_URL="https://your-backend.onrender.com"
